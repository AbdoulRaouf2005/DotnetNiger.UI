<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>NU1900</NoWarn>
  </PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="8.0.23" />
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="8.0.23" />
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="8.0.23" PrivateAssets="all" />

		<PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="8.16.0" />
		<PackageReference Include="TinyMCE.Blazor" Version="2.2.1" />
	</ItemGroup>

  <ItemGroup>
    <Folder Include="Models\Entities\" />
  </ItemGroup>

  <Target Name="ApplyEnv" BeforeTargets="BeforeBuild">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Unrestricted -File scripts\apply-env.ps1" Condition="'$(OS)'=='Windows_NT'" />
    <Exec Command="pwsh -NoProfile -File scripts/apply-env.ps1" Condition="'$(OS)'!='Windows_NT'" />
  </Target>

</Project>
