
<article class="bg-white rounded-xl shadow-sm overflow-hidden cursor-pointer transition hover:shadow-md" @onclick="NavigateToEventDetails">
    <div class="h-32 sm:h-40 md:h-44 bg-gray-900 flex items-center justify-center">
        <img src="@(Event?.CoverImageUrl ?? "/Images/ImageBlog.jpg")" class="h-full w-full object-cover" alt="@Event?.Title">
    </div>
    <div class="p-3 sm:p-4 md:p-6">
        <div class="flex items-start justify-between gap-2">
            <span class="inline-block bg-pink-100 text-pink-600 text-[10px] sm:text-xs px-2 sm:px-3 py-1 rounded flex-shrink-0">@GetEventTypeLabel(Event?.EventType)</span>
            <span class="text-[10px] sm:text-xs md:text-sm text-gray-500 flex-shrink-0">@Event?.StartDate.ToString("dd MMM yyyy")</span>
        </div>

        <h3 class="mt-2 sm:mt-4 text-sm sm:text-base md:text-lg font-semibold text-gray-700">@Event?.Title</h3>
        <p class="mt-1 sm:mt-2 text-xs sm:text-sm text-gray-600 line-clamp-2">@Event?.Description</p>
        <div class="flex items-center justify-between mt-3 sm:mt-4 flex-wrap gap-2">
            <span class="text-[10px] sm:text-xs bg-green-50 text-green-600 px-2 py-1 rounded">@GetEventTypeLabel(Event?.EventType)</span>
            <div class="flex items-center gap-1">
                <i class="fa-solid fa-location-dot text-secondary text-xs sm:text-base"></i>
                <span class="text-xs sm:text-sm text-gray-500">@Event?.Location</span>
            </div>
        </div>
        <div class="mt-3 sm:mt-4 border-t pt-3 sm:pt-4">
            <div class="flex items-center justify-between w-full gap-2 flex-wrap">
                <div class="flex items-center gap-1 sm:gap-2">
                    <div class="flex -space-x-2">
                        <div class="w-5 sm:w-6 md:w-7 h-5 sm:h-6 md:h-7 bg-gradient-to-br from-secondary to-indigo-700 rounded-full border-2 border-white flex items-center justify-center text-white text-[8px] sm:text-xs font-bold flex-shrink-0"></div>
                        <div class="w-5 sm:w-6 md:w-7 h-5 sm:h-6 md:h-7 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full border-2 border-white flex items-center justify-center text-white text-[8px] sm:text-xs font-bold flex-shrink-0"></div>
                        <div class="w-5 sm:w-6 md:w-7 h-5 sm:h-6 md:h-7 bg-gradient-to-br from-purple-400 to-purple-600 rounded-full border-2 border-white flex items-center justify-center text-white text-[8px] sm:text-xs font-bold flex-shrink-0"></div>
                    </div>
                    <span class="text-[10px] sm:text-sm text-gray-600"><strong>@Event?.RegisteredCount</strong> inscrits</span>
                </div>
                <button class="bg-secondary text-white text-xs sm:text-sm px-2 sm:px-4 py-1 sm:py-2 rounded-full shadow transition hover:brightness-110 flex-shrink-0" 
                        @onclick:stopPropagation="true" 
                        @onclick="HandleRegisterClick">
                    S'inscrire
                </button>
            </div>
        </div>
    </div>
</article>

@code {
    [Inject]
    private NavigationManager? NavigationManager { get; set; }

    [Parameter]
    public EventDto? Event { get; set; }

    [Parameter]
    public EventCallback OnRegisterClick { get; set; }

    private void NavigateToEventDetails()
    {
        if (Event is null) return;

        // Préférer le slug s'il est disponible, sinon utiliser l'ID
        var route = !string.IsNullOrWhiteSpace(Event.Slug)
            ? $"/evenements/{Event.Slug}"
            : $"/evenements/{Event.Id}";

        NavigationManager?.NavigateTo(route);
    }

    private async Task HandleRegisterClick()
    {
        await OnRegisterClick.InvokeAsync();
    }

    private static string GetEventTypeLabel(string? eventType)
    {
        return eventType?.ToLowerInvariant() switch
        {
            "online" => "En ligne",
            "physical" => "Présentiel",
            "hybrid" => "Hybride",
            _ => string.IsNullOrWhiteSpace(eventType) ? "Événement" : eventType
        };
    }
}
