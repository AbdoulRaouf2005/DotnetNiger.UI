@* Composant admin : barre supérieure avec profil et actions rapides. *@
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IConfiguration Config

<header class="sticky z-20 w-full flex h-16 items-center justify-between bg-white px-8 sm:px-4 md:px-6 shadow-md">
      <div class="flex gap-4">
            <button class="sm:hidden" @onclick="ToggleSidebar">
                  <i class="fas fa-bars text-xl"></i>
            </button>
            <button class="hidden sm:flex items-center text-gray-500 hover:text-gray-800 transition-colors" @onclick="ToggleCollapsed" title="@(IsCollapsed ? "Développer" : "Réduire")">
                  <i class="fas @(IsCollapsed ? "fa-chevron-right" : "fa-chevron-left") text-xl"></i>
            </button>
            <div class="flex items-center text-2xl font-bold">
                  <img src="/Logo.svg" alt="Logo du dotnet Niger" class="w-10 h-10">
                  <span class="Link">Dotnet Niger</span>
            </div>
      </div>
      <div class="flex items-center space-x-4">
            @* <ThemeToggle /> *@
            <button @onclick="HandleLogout" class="flex items-center gap-2 rounded-lg bg-secondary px-3 py-2 text-white hover:bg-hover">
                  <span class="Button hidden sm:inline"> Deconnexion</span>
                  <i class="fas fa-sign-out-alt text-2xl sm:text-xl"></i>
            </button>
      </div>
</header>

@code {
      [Parameter]
      public EventCallback ToggleSidebar { get; set; }

      [Parameter]
      public EventCallback ToggleCollapsed { get; set; }

      [Parameter]
      public bool IsCollapsed { get; set; }


      private async Task HandleLogout()
      {
            await AuthService.LogoutAsync();
            var returnUrl = $"{NavigationManager.BaseUri.TrimEnd('/')}/auth/external-callback";
            var apiBase = Config["ApiBaseUrl"];
            if (string.IsNullOrWhiteSpace(apiBase)) return;
            var path = Config["IdentityEndpoints:Login"] ?? "/Account/Login";
            var loginUrl = $"{apiBase}{path}?returnUrl={Uri.EscapeDataString(returnUrl)}";
            NavigationManager.NavigateTo(loginUrl, forceLoad: true);
      }

}