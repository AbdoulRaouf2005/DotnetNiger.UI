@inject IJSRuntime JS
@implements IAsyncDisposable

<textarea id="@EditorId"></textarea>

@code {
    [Parameter] public string EditorId { get; set; } = "standaloneEditor";
    [Parameter] public string InitialContent { get; set; } = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("loadTinyMCE", EditorId, InitialContent);
        }
    }

    public async Task<string> GetContentAsync()
    {
        return await JS.InvokeAsync<string>("getTinyMCEContent", EditorId);
    }

    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("destroyTinyMCE", EditorId);
    }
}
