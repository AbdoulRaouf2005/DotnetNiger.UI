@using DotnetNiger.UI.Models.Responses
@using DotnetNiger.UI.Components.Admin.Shared

<div class="overflow-hidden rounded-lg bg-white shadow">
      <div class="overflow-x-auto">
            <table class="w-full">
                  <thead class="border-b border-gray-200 bg-gray-100">
                        <tr>
                              <th class="Button px-6 py-4 text-left text-text">Avatar</th>
                              <th class="Button px-6 py-4 text-left text-text">ID</th>
                              <th class="Button px-6 py-4 text-left text-text">Nom</th>
                              <th class="Button px-6 py-4 text-left text-text">Email</th>
                              <th class="Button px-6 py-4 text-left text-text">Role</th>
                              <th class="Button px-6 py-4 text-left text-text">Date création</th>
                              <th class="Button px-6 py-4 text-left text-text">Actions</th>
                        </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200">
                        @if (Users.Count == 0)
                        {
                              <tr>
                                    <td colspan="7" class="px-6 py-10 text-center text-sm text-gray-500">Aucun utilisateur ne correspond au filtre actuel.</td>
                              </tr>
                        }
                        else
                        {
                              @foreach (var user in Users)
                              {
                              <tr class="transition hover:bg-gray-50">
                                    <td class="px-6 py-4 text-sm font-medium text-text">
                                          <img src="@(string.IsNullOrWhiteSpace(user.AvatarUrl) ? "/Images/user.png" : user.AvatarUrl)" class="h-10 w-10 rounded-full object-cover" />
                                    </td>
                                    <td class="px-6 py-4 text-sm text-text">@user.Id.ToString()[..8]</td>
                                    <td class="px-6 py-4 text-sm text-text">@user.FullName</td>
                                    <td class="px-6 py-4 text-sm text-text">
                                          <span class="rounded-full bg-gray-100 px-2 py-1 text-xs font-medium text-gray-800">@user.Email</span>
                                    </td>
                                    <td class="px-6 py-4 text-sm">
                                          <div class="flex items-center gap-2">
                                                <div class="h-3 w-3 rounded-full @(user.IsActive ? "bg-emerald-500" : "bg-amber-500")"></div>
                                                <span class="text-gray-700">@GetPrimaryRole(user)</span>
                                          </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-text">@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="px-6 py-4 text-sm">
                                          <AdminActionDropdown ItemId="user.Id"
                                                               Status="@(user.IsActive ? "Active" : "Inactive")"
                                                               ViewLabel="Voir"
                                                               EditLabel="Éditer"
                                                               DeleteLabel="Supprimer"
                                                               ToggleStatusLabel="Activer / Désactiver"
                                                               OnView="OnView"
                                                               OnEdit="OnEdit"
                                                               OnDelete="OnDelete"
                                                               OnToggleStatus="OnToggleStatus" />
                                    </td>
                              </tr>
                              }
                        }
                  </tbody>
            </table>
      </div>
</div>

@code {
      [Parameter] public List<UserDto> Users { get; set; } = new();
      [Parameter] public EventCallback<Guid> OnView { get; set; }
      [Parameter] public EventCallback<Guid> OnEdit { get; set; }
      [Parameter] public EventCallback<Guid> OnDelete { get; set; }
      [Parameter] public EventCallback<Guid> OnToggleStatus { get; set; }

      private static string GetPrimaryRole(UserDto user)
            => user.Roles.FirstOrDefault() ?? "Member";
}
