@* Carte admin des événements avec menu d'actions harmonisé. *@
@using DotnetNiger.UI.Models.Responses
@inject NavigationManager NavigationManager

<div class="group overflow-hidden rounded-[22px] bg-white shadow-[0_10px_30px_rgba(15,23,42,0.08)] ring-1 ring-black/5">
    <div class="relative h-44 w-full overflow-hidden">
        <img src="@(Event?.CoverImageUrl ?? "/Images/ImageBlog.jpg")" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" alt="@Event?.Title">
    </div>

    <div class="p-5">
        <div class="mb-3 flex items-start justify-between gap-3">
            <div class="min-w-0">
                <h3 class="truncate text-lg font-semibold text-[#111827]">@Event?.Title</h3>
                <div class="mt-2 flex flex-wrap items-center gap-2">
                    <span class="rounded-full px-3 py-1 text-xs font-semibold @StatusCssClass">
                        <span class="mr-1 inline-block h-2 w-2 rounded-full @StatusDotCssClass"></span>
                        @StatusLabel
                    </span>
                    <span class="rounded-full bg-[#F4F2F2] px-3 py-1 text-xs font-semibold text-gray-700">@Event?.EventType</span>
                </div>
            </div>

            <AdminActionDropdown ItemId="@(Event?.Id ?? Guid.Empty)"
                                 Status="@(IsPending ? "Pending" : "Published")"
                                 ViewLabel="Voir l'événement"
                                 EditLabel="Modifier"
                                 DeleteLabel="Supprimer"
                                 ApproveLabel="Publier"
                                 RejectLabel="Rejeter"
                                 OnView="OpenEvent"
                                 OnEdit="EditEvent"
                                 OnDelete="DeleteEvent"
                                 OnApprove="SetPublished"
                                 OnReject="DeleteEvent" />
        </div>

        <p class="mb-4 line-clamp-3 text-sm leading-6 text-[#4b5563]">@Event?.Description</p>

        <div class="flex items-center justify-between gap-3 border-t border-gray-100 pt-4 text-sm text-[#4b5563]">
            <span class="truncate font-medium">@Event?.OrganizerName</span>
            <span class="whitespace-nowrap">@Event?.StartDate.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
    </div>
</div>
@code {

    [Parameter]
    public EventDto? Event { get; set; }

    [Parameter]
    public EventCallback OnEventDeleted { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSetPending { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSetPublished { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSetArchived { get; set; }

    private bool IsArchived => Event?.IsArchived == true;
    private bool IsPublished => Event?.IsPublished == true && !IsArchived;
    private bool IsPending => !IsPublished && !IsArchived;

    private string StatusLabel => IsArchived
        ? "Archivé"
        : IsPublished
            ? "Publié"
            : "En attente";

    private string StatusCssClass => IsArchived
        ? "bg-gray-100 text-gray-700"
        : IsPublished
            ? "bg-green-100 text-green-700"
            : "bg-amber-100 text-amber-700";

    private string StatusDotCssClass => IsArchived
        ? "bg-gray-500"
        : IsPublished
            ? "bg-green-500"
            : "bg-amber-500";

    private Task OpenEvent(Guid id)
    {
        if (Event is null) return Task.CompletedTask;
        NavigationManager.NavigateTo($"/admin/events/{Event.Id}");
        return Task.CompletedTask;
    }

    private Task EditEvent(Guid id)
    {
        if (Event is null) return Task.CompletedTask;
        NavigationManager.NavigateTo($"/admin/events/edit/{Event.Id}");
        return Task.CompletedTask;
    }

    private async Task DeleteEvent(Guid id)
    {
        if (Event is null) return;
        await OnEventDeleted.InvokeAsync();
    }

    private async Task SetPending(Guid id)
    {
        if (Event is null) return;
        await OnSetPending.InvokeAsync(Event.Id);
    }

    private async Task SetPublished(Guid id)
    {
        if (Event is null) return;
        await OnSetPublished.InvokeAsync(Event.Id);
    }

    private async Task SetArchived(Guid id)
    {
        if (Event is null) return;
        await OnSetArchived.InvokeAsync(Event.Id);
    }
}