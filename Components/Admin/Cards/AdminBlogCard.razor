@* Carte admin pour les articles avec menu d'actions à deux états. *@
@using DotnetNiger.UI.Models.Responses
@using DotnetNiger.UI.Models.Requests
@using System.Net
@using System.Text.RegularExpressions
@inject IPostService PostService
@inject NavigationManager NavigationManager
@inject IToastService ToastService

<div class="group overflow-hidden rounded-[22px] bg-white shadow-[0_10px_30px_rgba(15,23,42,0.08)] ring-1 ring-black/5">
    <div class="relative h-44 w-full overflow-hidden">
        <img src="@(post?.CoverImageUrl ?? "/Images/ImageBlog.jpg")" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" alt="@post?.Title">
    </div>

    <div class="p-5">
        <div class="mb-3 flex items-start justify-between gap-3">
            <div class="min-w-0">
                <h3 class="truncate text-lg font-semibold text-[#111827]">@post?.Title</h3>
                <div class="mt-2 flex flex-wrap items-center gap-2">
                    <span class="rounded-full bg-[#F4F2F2] px-3 py-1 text-xs font-semibold text-gray-700">@GetPostTypeLabel()</span>
                    <span class="rounded-full px-3 py-1 text-xs font-semibold @(IsPublished ? "bg-[#D1FAE5] text-[#16a34a]" : "bg-amber-100 text-amber-700")">@(IsPublished ? "Publié" : "Brouillon")</span>
                </div>
            </div>

            <AdminActionDropdown ItemId="@(post?.Id ?? Guid.Empty)"
                                 Status="@(IsPublished ? "Published" : "Pending")"
                                 ViewLabel="Voir l'article"
                                 EditLabel="Modifier"
                                 DeleteLabel="Supprimer"
                                 ApproveLabel="Publier"
                                 RejectLabel="Rejeter"
                                 OnView="OpenPost"
                                 OnEdit="EditPost"
                                 OnDelete="DeletePost"
                                 OnApprove="PublishPost"
                                 OnReject="DeletePost" />
        </div>

        <p class="mb-4 line-clamp-3 text-sm leading-6 text-[#4b5563]">@GetPreviewText()</p>

        <div class="flex items-center justify-between gap-3 border-t border-gray-100 pt-4 text-sm text-[#4b5563]">
            <span class="truncate font-medium">@post?.AuthorName</span>
            <span class="whitespace-nowrap">@GetDateLabel()</span>
        </div>
    </div>
</div>
@code {

    [Parameter]
    public PostDto? post { get; set; }

    [Parameter]
    public EventCallback OnPostDeleted { get; set; }

    private bool IsPublished => post?.PublishedAt != DateTime.MinValue;

    private string GetPostTypeLabel()
    {
        return string.IsNullOrWhiteSpace(post?.PostType) ? "Sans catégorie" : post!.PostType;
    }

    private string GetPreviewText()
    {
        var source = !string.IsNullOrWhiteSpace(post?.Excerpt) ? post.Excerpt : post?.Content;

        if (string.IsNullOrWhiteSpace(source))
        {
            return "Aucun aperçu disponible.";
        }

        var plainText = Regex.Replace(source, "<.*?>", string.Empty);
        plainText = WebUtility.HtmlDecode(plainText).Trim();

        return plainText.Length <= 140 ? plainText : $"{plainText[..140].Trim()}...";
    }

    private Task OpenPost(Guid id)
    {
        if (post is null) return Task.CompletedTask;
        NavigationManager.NavigateTo($"/admin/blog/{post.Id}");
        return Task.CompletedTask;
    }

    private Task EditPost(Guid id)
    {
        if (post is null) return Task.CompletedTask;
        NavigationManager.NavigateTo($"/admin/blog/edit/{post.Id}");
        return Task.CompletedTask;
    }

    private async Task DeletePost(Guid id)
    {
        if (post?.Id != null)
        {
            try
            {
                bool success = await PostService.DeletePostAsync(post.Id);
                if (success)
                {
                    ToastService.ShowToast("Article supprimé.", ToastLevel.Success);
                    await OnPostDeleted.InvokeAsync();
                    StateHasChanged();
                }
            }
            catch
            {
                ToastService.ShowToast("Erreur lors de la suppression.", ToastLevel.Error);
            }
        }
    }

    private async Task PublishPost(Guid id)
    {
        if (post is null)
        {
            return;
        }

        try
        {
            var request = new UpdatePostRequest
            {
                Title = post.Title,
                Content = post.Content,
                Excerpt = post.Excerpt,
                CoverImageUrl = post.CoverImageUrl,
                PostType = post.PostType,
                SeoDescription = string.IsNullOrWhiteSpace(post.Excerpt) ? post.Title : post.Excerpt,
                CategoryIds = post.Categories.Select(category => category.Id).ToList(),
                TagNames = post.Tags.Select(tag => tag.Name).ToList(),
                IsPublished = true
            };

            await PostService.UpdatePostAsync(post.Id, request);
            ToastService.ShowToast("Article publié.", ToastLevel.Success);
            await OnPostDeleted.InvokeAsync();
        }
        catch
        {
            ToastService.ShowToast("Erreur lors de la publication.", ToastLevel.Error);
        }
    }

    private string GetDateLabel()
    {
        return IsPublished ? post!.PublishedAt?.ToString("dd/MM/yyyy HH:mm") ?? "" : "En attente";
    }
}