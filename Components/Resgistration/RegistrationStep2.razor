@if (!IsVerified)
{
    <div class="py-6">
        <div class="text-center mb-6">
            <div class="w-16 h-16 rounded-full bg-purple-50 flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-envelope text-purple-600 text-2xl"></i>
            </div>
            <h2 class="text-xl font-bold text-gray-800">Vérifiez votre email</h2>
            <p class="text-gray-500 mt-2">
                Un code de confirmation a été envoyé à <strong class="text-gray-700">@Email</strong>
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-red-700 text-sm">
                @ErrorMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(SuccessMessage))
        {
            <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-green-700 text-sm">
                @SuccessMessage
            </div>
        }

        <div class="max-w-xs mx-auto mb-4">
            <label class="block text-xs font-medium text-gray-500 mb-2">Code de confirmation</label>
            <InputText @bind-Value="Code"
                       maxlength="6"
                       class="w-full text-center text-2xl tracking-widest rounded-lg border border-gray-200 px-4 py-3 text-sm focus:ring-1 focus:ring-purple-500"
                       placeholder="••••••" />
        </div>

        <div class="text-center mb-6">
            <button type="button" class="text-sm text-purple-600 hover:text-purple-800 font-medium" disabled="@IsResending" @onclick="HandleResend">
                @(IsResending ? "Renvoyé..." : "Renvoyer le code")
            </button>
        </div>

        <div class="flex gap-3">
            <button type="button" class="flex-1 rounded-full bg-white border py-3 text-sm" @onclick="HandleBack">← Retour</button>
            <button type="button" disabled="@IsVerifying || string.IsNullOrWhiteSpace(Code)" class="flex-1 rounded-full bg-purple-700 text-white py-3 text-sm disabled:opacity-70" @onclick="HandleVerify">
                @(IsVerifying ? "Vérification..." : "Vérifier mon code")
            </button>
        </div>
    </div>
}
else
{
    <div class="text-center py-6">
        <div class="w-16 h-16 rounded-full bg-green-50 flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-shield-check text-green-600 text-3xl"></i>
        </div>

        <h2 class="text-xl font-bold text-gray-800">Email confirmé</h2>

        <p class="text-gray-500 mt-3 max-w-md mx-auto">
            Votre adresse email a été vérifiée avec succès.
        </p>

        <div class="mt-4 bg-yellow-50 border border-yellow-100 rounded-lg p-4 text-sm text-yellow-700 text-left max-w-md mx-auto">
            <i class="fas fa-clock mr-1"></i>
            Votre compte est en attente de validation complète. Pour l'instant, vous pouvez uniquement participer aux événements.
        </div>

        <button type="button" class="mt-6 rounded-full bg-purple-700 text-white py-3 px-8 font-semibold hover:bg-purple-800 shadow-md" @onclick="HandleNext">
            Suivant →
        </button>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public string Email { get; set; } = string.Empty;

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public string? SuccessMessage { get; set; }

    [Parameter]
    public bool IsVerifying { get; set; }

    [Parameter]
    public bool IsResending { get; set; }

    [Parameter]
    public bool IsVerified { get; set; }

    [Parameter]
    public EventCallback<string> OnVerify { get; set; }

    [Parameter]
    public EventCallback OnResend { get; set; }

    [Parameter]
    public EventCallback OnBack { get; set; }

    [Parameter]
    public EventCallback OnNext { get; set; }

    private string Code { get; set; } = string.Empty;

    private Task HandleVerify() => OnVerify.InvokeAsync(Code);

    private Task HandleResend() => OnResend.InvokeAsync();

    private Task HandleBack() => OnBack.InvokeAsync();

    private Task HandleNext() => OnNext.InvokeAsync();
}
