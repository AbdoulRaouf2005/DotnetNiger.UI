@using DotnetNiger.UI.Models.Responses
@using System.Text.RegularExpressions
@using System.Net
@using System.Globalization

<a href="@GetPostUrl()" class="group block overflow-hidden rounded-lg bg-white shadow-sm transition-all duration-300 hover:shadow-md hover:-translate-y-2">
      <div class="block h-32 sm:h-40 md:h-44 overflow-hidden bg-secondary relative">
                 <img src="@(post?.CoverImageUrl ?? "/Images/ImageBlog.jpg")"
                   alt="@post?.Title"
                   class="h-full w-full object-cover transition group-hover:scale-105" />

            @* Overlay compteur oeil en haut à droite *@
            <span class="absolute top-2 right-2 sm:top-3 sm:right-3 inline-flex items-center gap-2 rounded-full bg-white/90 px-2 sm:px-3 py-1 text-[10px] sm:text-xs font-medium text-gray-800">
                  <i class="fas fa-eye"></i>
                  @post?.ViewCount
            </span>
      </div>

      <div class="space-y-2 sm:space-y-3 p-3 sm:p-4">
            @if (post?.Categories?.Any() == true)
            {
                  <span class="inline-flex rounded-lg bg-accent-bg px-2 py-1 text-[10px] sm:text-xs font-semibold text-secondary">
                        @post.Categories.FirstOrDefault()?.Name
                  </span>
            }

            <h3 class="text-sm sm:text-base md:text-lg lg:text-xl font-bold leading-snug text-gray-900">
                  <span class="">@post?.Title</span>
            </h3>

            <p class="text-xs sm:text-sm leading-relaxed text-gray-600">@GetPreviewText()</p>

            <div class="flex items-center justify-between text-[10px] sm:text-xs text-gray-700">
                  <span class="text-xs sm:text-sm text-gray-800">Par @post?.AuthorName</span>
                  <span class="text-[10px] sm:text-xs text-gray-600">@post?.PublishedAt?.ToString("dd MMM. yyyy", CultureInfo.GetCultureInfo("fr-FR"))</span>
            </div>
      </div>
</a>

@code {
      [Parameter]
      public PostDto? post { get; set; }

      private string GetPostUrl()
    {
        if (post is null) return "#";

        return !string.IsNullOrWhiteSpace(post.Slug)
            ? $"/blog/{post.Slug}"
            : $"/blog/{post.Id}";
    }

      private string GetPreviewText()
      {
            var source = post?.Content;

            if (string.IsNullOrWhiteSpace(source))
            {
                  return "Aucun aperçu disponible.";
            }

            var plainText = Regex.Replace(source, "<.*?>", string.Empty);
            plainText = WebUtility.HtmlDecode(plainText).Trim();

            return plainText.Length <= 256 ? plainText : $"{plainText[..256].Trim()}...";
      }
}
