@namespace DotnetNiger.UI.Components

@* Base skeleton element *@
@if (Type == SkeletonType.Custom)
{
    <div class="animate-pulse @Class" style="@Style"></div>
}
else if (Type == SkeletonType.Text)
{
    <div class="space-y-2 @Class">
        @for (int i = 0; i < Lines; i++)
        {
            <div class="h-3 rounded bg-gray-200" style="width: @(i == Lines - 1 ? "60%" : "100%")"></div>
        }
    </div>
}
else if (Type == SkeletonType.Title)
{
    <div class="h-6 rounded bg-gray-200 animate-pulse w-3/4 @Class"></div>
}
else if (Type == SkeletonType.Avatar)
{
    <div class="rounded-full bg-gray-200 animate-pulse flex-shrink-0 @Class" style="@(Size is not null ? $"width:{Size};height:{Size}" : "")"></div>
}
else if (Type == SkeletonType.Image)
{
    <div class="rounded-lg bg-gray-200 animate-pulse @Class" style="@Style"></div>
}
else if (Type == SkeletonType.Button)
{
    <div class="h-10 rounded-lg bg-gray-200 animate-pulse @Class" style="width: @(Width ?? "120px")"></div>
}
else if (Type == SkeletonType.Badge)
{
    <div class="h-6 rounded-full bg-gray-200 animate-pulse @Class" style="width: @(Width ?? "80px")"></div>
}

@code {
    [Parameter] public SkeletonType Type { get; set; } = SkeletonType.Text;
    [Parameter] public int Lines { get; set; } = 3;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public string? Size { get; set; }
    [Parameter] public string? Width { get; set; }
}
