@* Composant réutilisable d'upload d'image avec prévisualisation et suppression.
   Utilisation :
   <ImageUploader UploadType="UploadType.Event"
                  ExistingImageUrl="@model.CoverImageUrl"
                  OnImageUploaded="@(url => model.CoverImageUrl = url)"
                  OnImageDeleted="@(() => model.CoverImageUrl = null)" /> *@
@using DotnetNiger.UI.Models
@inject IUploadService UploadService

<div class="w-full">
    @if (isLoading)
    {
        <div class="flex flex-col items-center gap-3 py-8 border-2 border-dashed rounded-lg
                    border-gray-300 bg-gray-100">
            <i class="fa-solid fa-spinner fa-spin text-4xl text-blue-500"></i>
            <p class="text-gray-600 font-medium">Upload en cours...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(PreviewUrl))
    {
        <div class="relative border-2 border-green-300 bg-green-50 border-dashed rounded-lg p-6 text-center">
            <div class="relative inline-block">
                <img src="@PreviewUrl"
                     alt="Prévisualisation"
                     class="max-h-64 max-w-full rounded-lg object-contain shadow-md" />
                <button type="button"
                        @onclick="RemoveImage"
                        class="absolute -top-3 -right-3 bg-red-500 hover:bg-red-600 text-white w-8 h-8 rounded-full flex items-center justify-center shadow-lg transition-colors"
                        title="Supprimer l'image">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
        </div>
    }
    else
    {
        <label for="@_fileInputId"
               class="block border-2 border-dashed rounded-lg p-6 text-center transition-all duration-200 cursor-pointer
                      border-gray-300 hover:border-blue-400 bg-gray-50 hover:bg-blue-50">
            <div class="flex flex-col items-center gap-3 py-8">
                <i class="fa-solid fa-cloud-upload-alt text-5xl text-gray-400"></i>
                <div>
                    <p class="text-gray-600 font-medium">
                        <span class="text-blue-600 underline">Cliquez</span> pour sélectionner un fichier
                    </p>
                    <p class="text-gray-400 text-sm mt-1">
                        Formats : JPG, PNG, WebP, GIF &mdash; Max 5 Mo
                    </p>
                </div>
            </div>

            <InputFile OnChange="HandleFileSelected"
                       accept=".jpg,.jpeg,.png,.webp,.gif"
                       class="hidden"
                       id="@_fileInputId" />
        </label>
    }

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="mt-3 flex items-center gap-2 rounded-lg bg-red-50 p-3 text-sm text-red-700">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span>@ErrorMessage</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <div class="mt-3 flex items-center gap-2 rounded-lg bg-green-50 p-3 text-sm text-green-700">
            <i class="fa-solid fa-check-circle"></i>
            <span>@SuccessMessage</span>
        </div>
    }
</div>

@code {
    private string _fileInputId = $"image-uploader-{Guid.NewGuid():N}";
    private bool isLoading;
    private string? PreviewUrl;
    private string? ErrorMessage;
    private string? SuccessMessage;
    private string? _currentImageUrl;
    private string? _previousExistingImageUrl;

    [Parameter] public UploadType UploadType { get; set; } = UploadType.Event;
    [Parameter] public EventCallback<string> OnImageUploaded { get; set; }
    [Parameter] public EventCallback OnImageDeleted { get; set; }
    [Parameter] public string? ExistingImageUrl { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (ExistingImageUrl == _previousExistingImageUrl)
            return;

        _previousExistingImageUrl = ExistingImageUrl;
        await LoadExistingImageAsync();
    }

    private async Task LoadExistingImageAsync()
    {
        if (!string.IsNullOrWhiteSpace(ExistingImageUrl))
        {
            _currentImageUrl = ExistingImageUrl;
            PreviewUrl = await UploadService.ResolveImageUrlAsync(ExistingImageUrl) ?? ExistingImageUrl;
        }
        else
        {
            _currentImageUrl = null;
            PreviewUrl = null;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        await UploadFileAsync(file);
    }

    private async Task UploadFileAsync(IBrowserFile file)
    {
        isLoading = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var response = await UploadService.UploadImageAsync(file, UploadType);

            if (response.Success)
            {
                _currentImageUrl = response.ImageUrl;
                PreviewUrl = await UploadService.ResolveImageUrlAsync(response.ImageUrl) ?? response.ImageUrl;
                SuccessMessage = response.Message;
                await OnImageUploaded.InvokeAsync(response.ImageUrl);
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Erreur inattendue : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RemoveImage()
    {
        isLoading = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            if (!string.IsNullOrWhiteSpace(_currentImageUrl))
            {
                await UploadService.DeleteImageAsync(_currentImageUrl);
            }

            _currentImageUrl = null;
            PreviewUrl = null;
            SuccessMessage = "Image supprimée avec succès.";
            await OnImageDeleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Erreur lors de la suppression : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
