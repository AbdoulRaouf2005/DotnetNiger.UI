@inject IJSRuntime JS

<div class="mt-5 grid grid-cols-4 gap-2 sm:gap-3">
    <button type="button" @onclick="ShareWhatsApp"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-lg border border-gray-200 bg-gray-50 px-2 text-xs sm:text-sm font-semibold text-gray-700 transition hover:bg-gray-100"
            aria-label="Partager sur WhatsApp">
        <i class="fa-brands fa-whatsapp"></i>
        <span class="hidden sm:inline">WhatsApp</span>
    </button>
    <button type="button" @onclick="ShareFacebook"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-lg border border-gray-200 bg-gray-50 px-2 text-xs sm:text-sm font-semibold text-gray-700 transition hover:bg-gray-100"
            aria-label="Partager sur Facebook">
        <i class="fa-brands fa-facebook"></i>
        <span class="hidden sm:inline">Facebook</span>
    </button>
    <button type="button" @onclick="ShareLinkedIn"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-lg border border-gray-200 bg-gray-50 px-2 text-xs sm:text-sm font-semibold text-gray-700 transition hover:bg-gray-100"
            aria-label="Partager sur LinkedIn">
        <i class="fa-brands fa-linkedin-in"></i>
        <span class="hidden sm:inline">LinkedIn</span>
    </button>
    <button type="button" @onclick="CopyLink"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-lg border border-gray-200 bg-gray-50 px-2 text-xs sm:text-sm font-semibold text-gray-700 transition hover:bg-gray-100"
            aria-label="Copier le lien">
        <i class="fa-solid fa-link"></i>
        <span class="hidden sm:inline">Copier</span>
    </button>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Url { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }

    private void ShareWhatsApp()
    {
        var text = Uri.EscapeDataString($"{Title} - {Url}");
        _ = JS.InvokeVoidAsync("window.open", $"https://wa.me/?text={text}", "_blank");
    }

    private void ShareFacebook()
    {
        var u = Uri.EscapeDataString(Url);
        _ = JS.InvokeVoidAsync("window.open", $"https://www.facebook.com/sharer/sharer.php?u={u}", "_blank");
    }

    private void ShareLinkedIn()
    {
        var u = Uri.EscapeDataString(Url);
        _ = JS.InvokeVoidAsync("window.open", $"https://www.linkedin.com/sharing/share-offsite/?url={u}", "_blank");
    }

    private async Task CopyLink()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Url);
    }
}
