@* Composant partagé : barre de navigation principale du site public (desktop + mobile). *@

<nav class="sticky z-50 w-full bg-white shadow-lg">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 justify-between">
            <!-- Logo / Marque -->
            <div class="flex items-center">
                <NavLink href="/" class="flex items-center space-x-2">
                    <img src="/Logo.svg" alt="logo dotnet.niger" class="h-9 w-9">
                </NavLink>
            </div>

            <!-- Navigation Desktop (à droite) -->
            <div class="hidden items-center space-x-6 md:flex">
                <NavLink href="/" class="text-secondary transition duration-150 ease-in-out hover:text-hover"
                         Match="NavLinkMatch.All">
                    <span class="text-sm font-normal">Accueil</span>
                </NavLink>
                <NavLink href="/propos" class="text-secondary transition duration-150 ease-in-out hover:text-hover">
                    <span class="text-sm font-normal">À Propos</span>
                </NavLink>
                <NavLink href="/ressources" class="text-secondary transition duration-150 ease-in-out hover:text-hover">
                    <span class="text-sm font-normal">Ressources</span>
                </NavLink>
                <NavLink href="/community" class="text-secondary transition duration-150 ease-in-out hover:text-hover">
                    <span class="text-sm font-normal">Communauté</span>
                </NavLink>
                <NavLink href="/blog" class="text-secondary transition duration-150 ease-in-out hover:text-hover">
                    <span class="text-sm font-normal">Blog</span>
                </NavLink>
                <NavLink href="/evenements" class="text-secondary transition duration-150 ease-in-out hover:text-hover">
                    <span class="text-sm font-normal">Événements</span>
                </NavLink>
                <NavLink href="/partners"
                         class="text-secondary transition duration-150 ease-in-out hover:text-hover">
                    <span class="text-sm font-normal">Partenaires</span>
                </NavLink>
                <NavLink href="/contact" class="text-secondary transition duration-150 ease-in-out hover:text-hover">
                    <span class="text-sm font-normal">Contact</span>
                </NavLink>
                
                <TopBarAuthState />
            </div>

            <!-- Bouton menu mobile -->
            <div class="flex items-center md:hidden">
                <button @onclick="ToggleMobileMenu" class="text-secondary hover:text-hover focus:outline-none">
                    <i class="fa-solid fa-bars text-2xl"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Menu Mobile -->
    @if (mobileMenuOpen)
    {   
        <div class="absolute top-0 w-full h-screen z-10 inset-0 bg-black/50 md:hidden @(mobileMenuOpen ? string.Empty : "hidden")" @onclick="ToggleMobileMenu"></div>
        <div
            class="absolute z-30 flex flex-col justify-between top-0 right-0 w-full h-screen sm:w-96 border-t border-gray-200 bg-white md:hidden @(mobileMenuOpen ? "translate-x-0" : "-translate-x-full")">
            <div>
                <div class="h-16 flex items-center justify-end px-2">
                    <button class="" @onclick="ToggleMobileMenu">
                        <i class="fa-solid fa-xmark text-xl text-secondary"></i>
                    </button>
                </div>
                <div class="flex flex-col gap-4 px-2 pb-3 pt-2">
                    <NavLink href="/"
                             class="block px-3 py-2 text-secondary rounded-lg transition duration-150 ease-in-out hover:text-hover" ActiveClass="bg-active text-white"
                             Match="NavLinkMatch.All" @onclick="ToggleMobileMenu">
                        <span class="text-sm font-normal">Accueil</span>
                    </NavLink>
                    <NavLink href="/community"
                             class="block px-3 py-2 text-secondary rounded-lg transition duration-150 ease-in-out hover:text-hover" ActiveClass="bg-active text-white"
                             @onclick="ToggleMobileMenu">
                        <span class="text-sm font-normal">Communauté</span>
                    </NavLink>
                    <NavLink href="/propos"
                             class="block px-3 py-2 text-secondary rounded-lg transition duration-150 ease-in-out hover:text-hover" ActiveClass="bg-active text-white"
                             @onclick="ToggleMobileMenu">
                        <span class="text-sm font-normal">À Propos</span>
                    </NavLink>
                    <NavLink href="/ressources"
                             class="block px-3 py-2 text-secondary rounded-lg transition duration-150 ease-in-out hover:text-hover" ActiveClass="bg-active text-white"
                             @onclick="ToggleMobileMenu">
                        <span class="text-sm font-normal">Ressources</span>
                    </NavLink>
                    <NavLink href="/blog"
                             class="block px-3 py-2 text-secondary rounded-lg transition duration-150 ease-in-out hover:text-hover" ActiveClass="bg-active text-white"
                             @onclick="ToggleMobileMenu">
                        <span class="text-sm font-normal">Blog</span>
                    </NavLink>
                    <NavLink href="/evenements"
                             class="block px-3 py-2 text-secondary rounded-lg transition duration-150 ease-in-out hover:text-hover" ActiveClass="bg-active text-white"
                             @onclick="ToggleMobileMenu">
                        <span class="text-sm font-normal">Événements</span>
                    </NavLink>
                    <NavLink href="/partners"
                             class="block px-3 py-2 text-secondary rounded-lg transition duration-150 ease-in-out hover:text-hover" ActiveClass="bg-active text-white"
                             @onclick="ToggleMobileMenu">
                        <span class="text-sm font-normal">Partenaires</span>
                    </NavLink>
                    <NavLink href="/contact"
                             class="block px-3 py-2 text-secondary rounded-lg transition duration-150 ease-in-out hover:text-hover" ActiveClass="bg-active text-white"
                             @onclick="ToggleMobileMenu">
                        <span class="text-sm font-normal">Contact</span>
                    </NavLink>
                </div>
            </div>
            <div class="px-3 py-2 mb-4">
                <TopBarAuthState Mobile="true" OnActionCompleted="OnAuthActionFromMobile" />
            </div>
        </div>
    }
</nav>

@code {
    private bool mobileMenuOpen = false;

    private void ToggleMobileMenu()
    {
        mobileMenuOpen = !mobileMenuOpen;
    }


    private void OnAuthActionFromMobile()
    {
        mobileMenuOpen = false;
    }
}