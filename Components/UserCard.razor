@namespace DotnetNiger.UI.Components
@inject NavigationManager Navigation

@using DotnetNiger.UI.Models.Responses

<article @onclick="NavigateToProfile"
         role="button"
         tabindex="0"
         @onkeydown="HandleKeyDown"
         class="cursor-pointer rounded-lg border border-white bg-white p-3 sm:p-4 md:p-5 shadow-[0_10px_30px_rgba(15,23,42,0.06)] ring-1 ring-slate-100 transition hover:-translate-y-1 hover:shadow-[0_14px_34px_rgba(15,23,42,0.10)]">
      <div class="flex items-start justify-between gap-2 sm:gap-3">
            <div class="flex items-center gap-2 sm:gap-3 min-w-0">
                  <img src="@GetAvatarUrl()" alt="@GetDisplayName()" class="h-10 w-10 sm:h-12 sm:w-12 rounded-full border-2 border-[#ECE7FF] object-cover flex-shrink-0" />
                  <div class="min-w-0">
                        <h3 class="text-xs sm:text-sm font-bold text-slate-900 truncate">@GetDisplayName()</h3>
                        <p class="text-[10px] sm:text-xs font-semibold text-[#F97316]">@GetRole()</p>
                  </div>
            </div>
            <div class="flex items-center gap-2 text-slate-400 flex-shrink-0">
                  <i class="fa-solid fa-link text-[10px] sm:text-xs"></i>
            </div>
      </div>

      <div class="mt-2 sm:mt-4 flex items-center gap-1 sm:gap-2 text-[10px] sm:text-xs text-slate-500">
            <i class="fa-solid fa-location-dot flex-shrink-0"></i>
            <span class="truncate">@GetLocation()</span>
      </div>

      @if (User?.Skills?.Any() == true)
      {
            <div class="mt-3 sm:mt-4 flex flex-wrap gap-1 sm:gap-2">
                  @foreach (var skill in User!.Skills)
                  {
                        <span class="rounded-lg bg-green-500/25 px-2 sm:px-3 py-0.5 sm:py-1 text-[9px] sm:text-[11px] font-bold text-green-500">@skill</span>
                  }
            </div>
      }
</article>

@code {
      [Parameter]
      public UserDto? User { get; set; }

      private void NavigateToProfile()
      {
            if (User?.Id is not null)
                  Navigation.NavigateTo($"/member/{User.Id}");
      }

      private void HandleKeyDown(KeyboardEventArgs e)
      {
            if (e.Key == "Enter" || e.Key == " ")
                  NavigateToProfile();
      }

      private string GetDisplayName()
      {
            if (string.IsNullOrWhiteSpace(User?.FullName))
            {
                  return string.IsNullOrWhiteSpace(User?.Username) ? "Membre" : User!.Username;
            }

            return User!.FullName;
      }

      private string GetRole()
      {
            return User?.Roles?.FirstOrDefault() ?? "Membre";
      }

      private string GetLocation()
      {
            if (!string.IsNullOrWhiteSpace(User?.City) && !string.IsNullOrWhiteSpace(User?.Country))
            {
                  return $"{User.City}, {User.Country}";
            }

            if (!string.IsNullOrWhiteSpace(User?.City))
            {
                  return User.City;
            }

            if (!string.IsNullOrWhiteSpace(User?.Country))
            {
                  return User.Country;
            }

            return "Localisation indisponible";
      }

      private string GetAvatarUrl()
      {
            return string.IsNullOrWhiteSpace(User?.AvatarUrl) ? "/Images/upload/user.png" : User.AvatarUrl;
      }
}
