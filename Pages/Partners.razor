@page "/partners"
@inject IPartnerService PartnerService

<PageTitle>Partenaires - .NET Niger</PageTitle>

@if (isLoading)
{
    <div class="min-h-[60vh] flex items-center justify-center">
        <div class="inline-block h-10 w-10 animate-spin rounded-full border-4 border-solid border-secondary border-r-transparent"></div>
    </div>
}
else
{
    <main class="bg-white">
        <section class="bg-purple-50 py-8 sm:py-12 md:py-16">
            <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-base sm:text-lg md:text-2xl lg:text-3xl xl:text-4xl font-extrabold text-center text-secondary">Nos Partenaires Locaux</h2>
                <p class="mt-2 sm:mt-3 text-center text-xs sm:text-sm md:text-base leading-6 sm:leading-7 text-gray-600">Partenaires qui soutiennent et collaborent avec notre communauté</p>

                <div class="mt-8 sm:mt-10 grid gap-4 sm:gap-6 md:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                    @foreach (var partner in educationPartners)
                    {
                        <div class="bg-white rounded-xl p-4 sm:p-6 shadow-md">
                            <div class="flex justify-center">
                                @if (!string.IsNullOrWhiteSpace(partner.LogoUrl))
                                {
                                    <img src="@partner.LogoUrl" alt="@partner.Name" class="w-16 sm:w-20 md:w-24 h-16 sm:h-20 md:h-24 rounded-md object-contain" />
                                }
                                else
                                {
                                    <div class="w-16 sm:w-20 md:w-24 h-16 sm:h-20 md:h-24 bg-gray-200 rounded-md"></div>
                                }
                            </div>
                            <div class="mt-3 sm:mt-4 text-center">
                                <div class="text-[10px] sm:text-xs text-gray-500 uppercase">@partner.PartnerType</div>
                                @if (!string.IsNullOrWhiteSpace(partner.WebsiteUrl))
                                {
                                    <a href="@partner.WebsiteUrl" target="_blank" rel="noopener noreferrer"
                                       class="block mt-1 sm:mt-2 text-sm sm:text-base md:text-lg text-secondary font-semibold hover:underline">@partner.Name</a>
                                }
                                else
                                {
                                    <span class="block mt-1 sm:mt-2 text-sm sm:text-base md:text-lg text-secondary font-semibold">@partner.Name</span>
                                }
                                <p class="mt-2 text-xs sm:text-sm leading-6 sm:leading-7 text-gray-600">@partner.Description</p>
                                <div class="mt-3 sm:mt-4 flex items-center justify-center space-x-3 sm:space-x-4">
                                    <a class="text-sm sm:text-base text-secondary hover:text-[#512BD4]/50" aria-label="Facebook">
                                        <i class="fa-brands fa-facebook"></i>
                                    </a>
                                    <a class="text-sm sm:text-base text-secondary hover:text-[#512BD4]/50" aria-label="LinkedIn">
                                        <i class="fa-brands fa-linkedin"></i>
                                    </a>
                                    <a class="text-sm sm:text-base text-secondary hover:text-[#512BD4]/50" aria-label="X">
                                        <i class="fa-brands fa-x-twitter"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-6 sm:mt-8 flex justify-center">
                    <button class="bg-secondary text-white px-5 sm:px-6 py-2 sm:py-2 text-xs sm:text-sm md:text-base rounded-full shadow">VOIR TOUS</button>
                </div>
            </div>
        </section>

        <section class="py-8 sm:py-12 md:py-16">
            <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-base sm:text-lg md:text-2xl lg:text-3xl xl:text-4xl font-extrabold text-center text-secondary">Nos sponsors</h2>
                <p class="mt-2 sm:mt-3 text-center text-xs sm:text-sm md:text-base leading-6 sm:leading-7 text-gray-600">Sponsors qui soutiennent nos événements et initiatives communautaires</p>

                <div class="mt-6 sm:mt-8 grid gap-4 sm:gap-6 md:gap-8 grid-cols-1 md:grid-cols-2">
                    @foreach (var partner in sponsorPartners)
                    {
                        <div class="bg-white rounded-xl p-4 sm:p-6 shadow-md flex flex-col sm:flex-row items-start gap-4 sm:gap-6">
                            @if (!string.IsNullOrWhiteSpace(partner.LogoUrl))
                            {
                                <img src="@partner.LogoUrl" alt="@partner.Name" class="w-24 sm:w-28 md:w-28 h-16 sm:h-20 md:h-20 rounded-md flex-shrink-0 object-contain" />
                            }
                            else
                            {
                                <div class="w-24 sm:w-28 md:w-28 h-16 sm:h-20 md:h-20 bg-gray-200 rounded-md flex-shrink-0"></div>
                            }
                            <div class="flex-1">
                                <div class="text-sm sm:text-base md:text-lg font-semibold">@partner.Name</div>
                                <div class="text-xs sm:text-sm text-orange-500 mt-1">Sponsor</div>
                                <div class="text-[10px] sm:text-xs text-gray-400">Depuis @partner.CreatedAt.ToString("yyyy")</div>
                                <p class="mt-2 sm:mt-3 text-xs sm:text-sm leading-6 sm:leading-7 text-gray-600">@partner.Description</p>
                                <div class="mt-3 sm:mt-4 flex gap-2 sm:gap-3">
                                    @if (!string.IsNullOrWhiteSpace(partner.WebsiteUrl))
                                    {
                                        <a href="@partner.WebsiteUrl" target="_blank" rel="noopener noreferrer"
                                           class="bg-secondary text-white px-3 sm:px-4 py-1 sm:py-2 text-xs sm:text-sm rounded inline-block">Visiter</a>
                                    }
                                    <button class="border border-secondary text-secondary px-3 sm:px-4 py-1 sm:py-2 text-xs sm:text-sm rounded">En savoir plus</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-6 sm:mt-8 flex justify-center">
                    <button class="border border-secondary text-secondary px-5 sm:px-6 py-2 sm:py-2 text-xs sm:text-sm rounded-full">Devenir Sponsor</button>
                </div>
            </div>
        </section>

        <section class="bg-gray-100 py-10 sm:py-12">
            <div class="max-w-6xl mx-auto px-4 sm:px-6">
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-4 sm:gap-6">
                    <div class="bg-white rounded-lg shadow p-4 sm:p-6 text-center">
                        <div class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-secondary">@allPartners.Count+</div>
                        <div class="text-[10px] sm:text-xs text-gray-500 mt-2 leading-5">Partenaires Locaux</div>
                    </div>
                    <div class="bg-white rounded-lg shadow p-4 sm:p-6 text-center">
                        <div class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-secondary">@sponsorPartners.Count</div>
                        <div class="text-[10px] sm:text-xs text-gray-500 mt-2 leading-5">Sponsors Actifs</div>
                    </div>
                    <div class="bg-white rounded-lg shadow p-4 sm:p-6 text-center">
                        <div class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-secondary">500+</div>
                        <div class="text-[10px] sm:text-xs text-gray-500 mt-2 leading-5">Développeurs dans la Communauté</div>
                    </div>
                    <div class="bg-white rounded-lg shadow p-4 sm:p-6 text-center">
                        <div class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-secondary">24</div>
                        <div class="text-[10px] sm:text-xs text-gray-500 mt-2 leading-5">Événements cette Année</div>
                    </div>
                </div>
            </div>
        </section>
    </main>
}

@code {
    private bool isLoading = true;
    private List<PartnerResponse> allPartners = [];
    private List<PartnerResponse> educationPartners => allPartners
        .Where(p => p.PartnerType == "education").ToList();
    private List<PartnerResponse> sponsorPartners => allPartners
        .Where(p => p.PartnerType == "sponsor").ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allPartners = await PartnerService.GetAllActiveAsync(null);
        }
        catch
        {
            allPartners = [];
        }
        finally
        {
            isLoading = false;
        }
    }
}
