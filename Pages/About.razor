@page "/propos"

@using DotnetNiger.UI.Components.Cards;
@inject IUserService UserService

<PageTitle>À propos - .NET Niger</PageTitle>

<div class="bg-primary text-slate-800">
	<!-- HERO -->
	<section class="relative overflow-hidden px-4 py-20 sm:px-6 lg:px-8">
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(81,43,212,0.10),_transparent_36%),linear-gradient(180deg,_#fbfafc_0%,_#f4f2f2_100%)]">
		</div>
		<div class="absolute left-1/2 top-10 h-72 w-72 -translate-x-1/2 rounded-full bg-[#7c5cff]/10 blur-3xl">
		</div>

		<div class="relative mx-auto flex max-w-4xl flex-col items-center text-center">
			<h1
				class="max-w-3xl text-2xl font-extrabold leading-tight text-slate-900 sm:text-3xl md:text-4xl lg:text-5xl">
				Qui sommes-nous ?
			</h1>

			<p
				class="mt-4 sm:mt-6 max-w-3xl text-xs leading-6 text-slate-600 sm:text-sm sm:leading-7 md:text-base lg:text-lg">
				.NET Niger est plus qu'une simple communauté de développeurs : c'est un catalyseur de la
				transformation numérique au Sahel. Fondée par des passionnés de l'écosystème Microsoft, notre
				organisation s'est donnée pour mission de démocratiser l'accès aux technologies de pointe et de
				former une nouvelle génération d'ingénieurs capables de relever les défis les plus complexes de
				notre époque.
			</p>

			<div class="mt-7 sm:mt-8 flex flex-wrap items-center justify-center gap-3 sm:gap-4">
				<a href="#vision"
				   class="inline-flex items-center justify-center rounded-lg bg-secondary px-5 sm:px-6 py-2.5 sm:py-3 text-xs sm:text-sm font-semibold text-white shadow-[0_12px_30px_rgba(81,43,212,0.30)] transition hover:-translate-y-0.5 hover:bg-accent-hover">
					Découvrir Notre Vision
				</a>
				<a href="#equipe"
				   class="inline-flex items-center justify-center rounded-lg border border-secondary/15 bg-white px-5 sm:px-6 py-2.5 sm:py-3 text-xs sm:text-sm font-semibold text-secondary shadow-sm transition hover:-translate-y-0.5 hover:border-secondary/30 hover:bg-[#fbfaff]">
					Rencontrer l'équipe
				</a>
			</div>
		</div>
	</section>

	<!-- VISION -->
	<section id="vision" class="bg-border-soft px-4 py-12 sm:py-16 md:py-20 lg:px-8">
		<div class="mx-auto max-w-5xl text-center">
			<div
				class="mb-3 sm:mb-4 text-[10px] sm:text-[11px] font-bold uppercase tracking-[0.35em] text-accent-hover">
				Notre mission
			</div>
			<h2
				class="mx-auto max-w-3xl text-base sm:text-lg md:text-2xl lg:text-3xl xl:text-4xl font-extrabold leading-tight text-slate-900">
				Propulser le Talent Local au Sommet de la Tech Mondiale.
			</h2>
			<p
				class="mx-auto mt-4 sm:mt-6 max-w-3xl text-xs sm:text-sm md:text-base lg:text-lg leading-6 sm:leading-7 text-slate-600">
				Nous croyons que le Niger possède un potentiel technologique inexploité. Notre mission est de
				fournir les outils, les connaissances et le réseau nécessaires pour que chaque développeur .NET
				puisse exceller, innover et contribuer au progrès numérique de notre nation.
			</p>
		</div>
	</section>

	<!-- VALUES -->
	<section class="px-4 py-12 sm:py-16 md:py-20 lg:px-8">
		<div class="mx-auto max-w-6xl">
			<div class="text-center">
				<div
					class="mb-3 sm:mb-4 text-[10px] sm:text-[11px] font-bold uppercase tracking-[0.35em] text-accent-hover">
					Nos valeurs fondamentales
				</div>
				<h2
					class="text-base sm:text-lg md:text-2xl lg:text-3xl xl:text-4xl font-extrabold text-slate-900">
					Ce qui guide notre communauté
				</h2>
			</div>

			<div class="mt-8 sm:mt-12 grid gap-4 sm:gap-6 md:grid-cols-3">
				@foreach (var value in values)
				{
					<article
						class="rounded-lg border border-white bg-white p-4 sm:p-6 shadow-[0_8px_30px_rgba(15,23,42,0.06)] ring-1 ring-slate-100 transition hover:-translate-y-1 hover:shadow-[0_16px_38px_rgba(15,23,42,0.10)]">
						<div
							class="flex h-10 w-10 sm:h-11 sm:w-11 items-center justify-center rounded-lg bg-gradient-to-br @value.IconBackground text-base sm:text-lg @value.IconColor shadow-sm">
							<i class="@value.Icon"></i>
						</div>
						<h3 class="mt-4 sm:mt-5 text-sm sm:text-base md:text-lg font-bold text-slate-900">
							@value.Title</h3>
							<p class="mt-2 sm:mt-3 text-xs sm:text-sm leading-6 sm:leading-7 text-slate-600">
								@value.Description</p>
							</article>
						}
					</div>
				</div>
			</section>

			<!-- TIMELINE -->
			<section class="bg-surface px-4 py-12 sm:py-16 md:py-20 lg:px-8">
				<div class="mx-auto max-w-6xl">
					<div class="text-center">
						<div
							class="mb-3 sm:mb-4 text-[10px] sm:text-[11px] font-bold uppercase tracking-[0.35em] text-accent-hover">
							Timeline
						</div>
						<h2
							class="text-lg sm:text-xl md:text-2xl lg:text-3xl xl:text-4xl font-extrabold text-slate-900">
							Notre histoire
						</h2>
					</div>

					<div class="mt-8 sm:mt-12 grid gap-4 sm:gap-6 lg:grid-cols-3">
						@foreach (var milestone in milestones)
						{
							<article
								class="rounded-lg border border-white bg-white p-4 sm:p-6 shadow-[0_8px_30px_rgba(15,23,42,0.06)] ring-1 ring-slate-100">
								<div class="flex items-start justify-between gap-3 sm:gap-4">
									<div
										class="flex h-10 w-10 sm:h-12 sm:w-12 items-center justify-center rounded-full bg-border-soft text-base sm:text-xl text-secondary">
										<i class="@milestone.Icon"></i>
									</div>
									<span
										class="rounded-full @milestone.BadgeBackground px-2 sm:px-3 py-1 text-[10px] sm:text-xs font-bold text-white shadow-sm">
										@milestone.Year
									</span>
								</div>
								<h3 class="mt-4 sm:mt-5 text-sm sm:text-base md:text-lg font-bold @milestone.TitleColor">
									@milestone.Title</h3>
									<p class="mt-2 sm:mt-3 text-xs sm:text-sm leading-6 sm:leading-7 text-slate-600">
										@milestone.Description</p>
									</article>
								}
							</div>
						</div>
					</section>

					<!-- TEAM -->
					<section id="equipe" class="px-4 py-12 sm:py-16 sm:px-6 lg:px-8">
						<div class="mx-auto max-w-6xl">
							<div class="text-center">
								<h2 class="text-2xl font-extrabold text-slate-900 sm:text-3xl md:text-4xl">
									L'équipe de direction
								</h2>
								<p class="mt-3 text-xs sm:text-sm text-slate-500">
									Les visages derrière la communauté.
								</p>
							</div>

							@if (teamLoading)
							{
								<div class="mt-8 sm:mt-12 grid gap-4 sm:gap-6 lg:grid-cols-3">
									@for (int i = 0; i < 3; i++)
									{
										<article class="overflow-hidden rounded-lg border border-white bg-white shadow-[0_10px_28px_rgba(15,23,42,0.08)] ring-1 ring-slate-100">
											<Skeleton Type="SkeletonType.Custom" Class="h-56 sm:h-64 md:h-72 w-full" />
											<div class="space-y-3 p-4 sm:space-y-4 sm:p-5">
												<Skeleton Type="SkeletonType.Text" Lines="1" Class="w-3/4" />
												<Skeleton Type="SkeletonType.Text" Lines="1" Class="w-1/2" />
												<Skeleton Type="SkeletonType.Text" Lines="2" Class="w-full" />
											</div>
										</article>
									}
								</div>
							}
							else if (teamError)
							{
								<div class="mt-8 sm:mt-12 flex flex-col items-center justify-center py-12 text-center">
									<i class="fa-solid fa-exclamation-triangle text-3xl text-amber-500"></i>
									<p class="mt-3 text-sm text-slate-600">Impossible de charger l'équipe.</p>
									<button type="button" @onclick="LoadTeamAsync"
											class="mt-3 inline-flex items-center gap-2 rounded-lg bg-secondary px-4 py-2 text-xs font-semibold text-white transition hover:bg-accent-hover">
										<i class="fa-solid fa-rotate"></i> Réessayer
									</button>
								</div>
							}
							else if (teamMembers.Count == 0)
							{
								<div class="mt-8 sm:mt-12 flex flex-col items-center justify-center py-12 text-center">
									<i class="fa-solid fa-users-slash text-3xl text-slate-300"></i>
									<p class="mt-3 text-sm text-slate-500">Aucun membre dans l'équipe pour le moment.</p>
								</div>
							}
							else
							{
								<div class="mt-8 sm:mt-12 grid gap-4 sm:gap-6 lg:grid-cols-3">
									@foreach (var member in teamMembers)
									{
										<TeamMemberCard Member="member" />
									}
								</div>
							}
						</div>
					</section>
					</div>

@code {
	private readonly IReadOnlyList<ValueItem> values = new[]
	{
		new ValueItem("Collaboration", "fa-solid fa-people-group", "bg-border-soft", "text-secondary", "L'esprit de partage est au coeur de notre ADN. Ensemble, nous apprenons et grandissons à la fois."),
		new ValueItem("Innovation", "fa-solid fa-lightbulb", "bg-info-light-bg", "text-info", "Repousser les limites du possible avec .NET pour résoudre les défis locaux par le code."),
		new ValueItem("Excellence", "fa-solid fa-graduation-cap", "bg-info-light-bg", "text-info", "Nous visons la qualité technique et l'éthique professionnelle dans tous nos projets communautaires.")
	};

	private readonly IReadOnlyList<MilestoneItem> milestones = new[]
	{
		new MilestoneItem("2024", "La Fondation", "fa-solid fa-rocket", "bg-secondary", "text-accent", Description: "Un petit groupe de passionnés se réunit à Niamey pour poser les jalons de l'écosystème .NET au Niger, avec l'ambition de créer un pont vers l'innovation mondiale."),
		new MilestoneItem("2025", "L'Expansion", "fa-solid fa-users", "bg-secondary", "text-info", "Lancement du premier grand meetup communautaire réunissant plus de 100 développeurs et étudiants, marquant le début d'une dynamique de partage sans précédent."),
		new MilestoneItem("2026", "La Reconnaissance", "fa-solid fa-award", "bg-secondary", "text-info", "Signature de partenariats stratégiques avec des institutions locales et intégration officielle dans le réseau global des communautés .NET.")
	};

	private List<UserDto> teamMembers = [];
	private bool teamLoading;
	private bool teamError;

	protected override async Task OnInitializedAsync()
	{
		await LoadTeamAsync();
	}

	private async Task LoadTeamAsync()
	{
		teamLoading = true;
		teamError = false;
		try
		{
			var all = await UserService.GetUsersAsync();
			teamMembers = all
				.Where(u => u.IsActive && u.IsTeamMember)
				.OrderByDescending(u => u.CreatedAt)
				.ToList();
		}
		catch
		{
			teamError = true;
		}
		finally
		{
			teamLoading = false;
		}
	}

	private sealed record ValueItem(string Title, string Icon, string IconBackground, string IconColor, string Description);

	private sealed record MilestoneItem(string Year, string Title, string Icon, string BadgeBackground, string TitleColor,
string Description);
}
