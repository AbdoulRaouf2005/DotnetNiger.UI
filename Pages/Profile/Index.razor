@page "/profile"
@inject IProfileService ProfileService
@inject NavigationManager Navigation

<div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
    <div class="mb-6">
        <h1 class="text-2xl font-semibold tracking-tight text-slate-800 sm:text-3xl">Mon profil</h1>
        <p class="mt-2 text-slate-600">Consulte tes informations publiques et mets ton profil a jour.</p>
    </div>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-[390px_1fr]">
        <div class="space-y-6">
            <section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
                <div class="mb-5 flex justify-center">
                    <div class="relative">
                        <img src="@GetAvatarUrl(profil?.AvatarUrl)"
                             alt="Avatar"
                             class="h-40 w-40 rounded-full border-4 border-indigo-100 object-cover" />
                        <button @onclick='() => Navigation.NavigateTo("/profile/informations")'
                                title="Modifier l'avatar"
                                class="absolute -bottom-1 -right-1 inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-600 text-white shadow-md transition hover:bg-indigo-500">
                            <i class="fas fa-camera text-sm"></i>
                        </button>
                    </div>
                </div>

                <div class="space-y-2 text-center">
                    <h2 class="text-xl font-semibold tracking-tight text-slate-800 sm:text-4xl">@DisplayOrFallback(profil?.FullName, profil?.Username ?? "Utilisateur")</h2>
                    <p class="text-lg text-slate-500">@DisplayPrimaryRole(profil?.Roles)</p>
                </div>

                <div class="mt-7 space-y-3 text-sm text-slate-700">
                    <div class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-slate-100 px-4 py-2">
                        <i class="fas fa-map-marker-alt text-slate-500"></i>
                        <span>@BuildLocation(profil?.City, profil?.Country)</span>
                    </div>
                    <div class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-slate-100 px-4 py-2">
                        <i class="fas fa-envelope text-slate-500"></i>
                        <span>@DisplayOrFallback(profil?.Email, "Email non renseigne")</span>
                    </div>
                    <div class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-slate-100 px-4 py-2">
                        <i class="fas fa-phone text-slate-500"></i>
                        <span>@DisplayOrFallback(profil?.PhoneNumber, "Telephone non renseigne")</span>
                    </div>
                    <div class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-slate-100 px-4 py-2">
                        <i class="fas fa-calendar-alt text-slate-500"></i>
                        <span>Membre depuis @FormatMemberSince(profil?.CreatedAt)</span>
                    </div>
                    <div class="inline-flex w-full items-center justify-center gap-2 rounded-full @((profil?.IsActive ?? false) ? "bg-emerald-50 text-emerald-700" : "bg-slate-100 text-slate-600") px-4 py-2">
                        <span class="h-2.5 w-2.5 rounded-full @((profil?.IsActive ?? false) ? "bg-emerald-500" : "bg-slate-400")"></span>
                        <span>@((profil?.IsActive ?? false) ? "En ligne" : "Hors ligne")</span>
                    </div>
                </div>
            </section>

            <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="mb-4 flex items-center justify-between">
                    <h3 class="text-lg font-semibold text-slate-700">Reseaux sociaux</h3>
                    <button @onclick='() => Navigation.NavigateTo("/profile/informations")'
                            class="inline-flex items-center gap-2 text-sm font-semibold text-indigo-600 hover:text-indigo-500">
                        <i class="fas fa-pen text-xs"></i>
                        Modifier
                    </button>
                </div>

                @if (socialLinks.Count == 0)
                {
                    <p class="text-sm text-slate-500">Aucun lien social enregistre.</p>
                }
                else
                {
                    <div class="flex flex-wrap gap-3">
                        @foreach (var link in socialLinks)
                        {
                            <a href="@link.Url"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="inline-flex h-11 w-11 items-center justify-center rounded-lg bg-indigo-600 text-xl text-white transition hover:bg-indigo-500"
                               title="@link.Platform">
                                <i class="@link.Icone"></i>
                            </a>
                        }
                    </div>
                }
            </section>
        </div>

        <div class="space-y-6">
            <section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
                <div class="mb-4 flex items-center justify-between gap-4">
                    <h2 class="text-lg font-semibold tracking-tight text-slate-800">A propos</h2>
                    <button @onclick='() => Navigation.NavigateTo("/profile/informations")'
                            title="Modifier la biographie"
                            class="inline-flex h-10 w-10 items-center justify-center rounded-full text-slate-500 transition hover:bg-slate-100 hover:text-slate-700">
                        <i class="fas fa-pen"></i>
                    </button>
                </div>
                <p class="max-w-4xl text-lg leading-relaxed text-slate-600">@DisplayOrFallback(profil?.Bio, "Aucune biographie renseignee.")</p>
            </section>

            <section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
                <div class="mb-4 flex items-start justify-between gap-4">
                    <h2 class="text-lg font-semibold tracking-tight text-slate-800">Skills and Technologies</h2>
                    <button @onclick='() => Navigation.NavigateTo("/profile/informations")'
                            title="Modifier les competences"
                            class="inline-flex h-10 w-10 items-center justify-center rounded-full text-slate-500 transition hover:bg-slate-100 hover:text-slate-700">
                        <i class="fas fa-pen"></i>
                    </button>
                </div>

                <div class="flex flex-wrap gap-3">
                    @foreach (var skill in ResolveSkills(profil?.Skills))
                    {
                        <span class="rounded-md bg-indigo-100 px-4 py-2 text-sm font-semibold text-indigo-700">@skill</span>
                    }
                </div>
            </section>
        </div>
    </div>
</div>

@code {
    private UserDto? profil;
    private List<SocialLinkDto> socialLinks = new();

    protected override async Task OnInitializedAsync()
    {
        profil = await ProfileService.GetProfileAsync();
        socialLinks = await ProfileService.GetSocialLinksAsync();
    }

    private static string DisplayOrFallback(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;

    private static string BuildLocation(string? city, string? country)
    {
        var hasCity = !string.IsNullOrWhiteSpace(city);
        var hasCountry = !string.IsNullOrWhiteSpace(country);

        if (hasCity && hasCountry)
        {
            return $"{city}, {country}";
        }

        if (hasCity)
        {
            return city!;
        }

        if (hasCountry)
        {
            return country!;
        }

        return "Non renseignee";
    }

    private static IEnumerable<string> ResolveSkills(List<string>? skills)
    {
        if (skills is not null && skills.Count > 0)
        {
            return skills;
        }

        return ["C# / .NET 8", "ASP.NET Core", "Azure Cloud", "Entity Framework", "Microservices", "Docker", "Blazor", "TypeScript"];
    }

    private static string DisplayPrimaryRole(List<string>? roles)
        => (roles is not null && roles.Count > 0) ? roles[0] : "Membre .NET Niger";

    private static string GetAvatarUrl(string? avatarUrl)
        => string.IsNullOrWhiteSpace(avatarUrl) ? "/Images/Fond.jpeg" : avatarUrl;

    private static string FormatMemberSince(DateTime? createdAt)
        => createdAt.HasValue ? createdAt.Value.ToString("MMMM yyyy") : "Date inconnue";
}
