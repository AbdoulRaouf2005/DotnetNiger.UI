@page "/admin/projects/edit/{Id:guid}"
@* Page admin : édition d'un projet existant. *@
@using DotnetNiger.UI.Models.Requests
@using DotnetNiger.UI.Models.Responses
@inject NavigationManager Navigation
@inject IProjectService ProjectService
@inject IToastService ToastService

<div class="min-h-screen px-4 py-6 md:px-8 md:py-8">
    <div class="mx-auto max-w-4xl">
        <div class="mb-6 flex items-center justify-between gap-4">
            <AdminBreadcrumb />
            <button @onclick="GoBack" class="inline-flex items-center gap-2 rounded-lg bg-red-500 px-4 py-2 text-sm font-semibold text-white transition hover:brightness-95">
                <i class="fas fa-arrow-left"></i>
                <span>Retour</span>
            </button>
        </div>

        <div class="rounded-[22px] bg-white p-6 shadow-[0_10px_30px_rgba(15,23,42,0.08)] ring-1 ring-black/5 md:p-8">
            <h1 class="text-2xl font-bold text-[#111827]">Modifier le projet</h1>
            <p class="mt-1 text-sm text-[#6b7280]">Modifiez les informations du projet.</p>

            @if (isLoading)
            {
                <div class="mt-8 flex items-center justify-center py-12">
                    <i class="fas fa-spinner fa-spin text-2xl text-[#5b4df5]"></i>
                    <span class="ml-3 text-sm text-[#6b7280]">Chargement...</span>
                </div>
            }
            else if (notFound)
            {
                <div class="mt-8 rounded-lg bg-amber-50 px-4 py-6 text-center text-sm text-amber-700">
                    Projet introuvable.
                </div>
            }
            else
            {
                <EditForm Model="@updateRequest" OnValidSubmit="HandleSubmit" class="mt-8 space-y-6">
                    <DataAnnotationsValidator />

                    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                        <div>
                            <label class="block text-sm font-semibold text-[#111827]">Titre *</label>
                            <InputText @bind-Value="updateRequest.Title"
                                       class="mt-1 w-full rounded-lg border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-[#5b4df5] focus:ring-2 focus:ring-[#5b4df5]/20"
                                       placeholder="Nom du projet" />
                            <ValidationMessage For="@(() => updateRequest.Title)" class="mt-1 text-xs text-red-500" />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-[#111827]">Statut</label>
                            <InputSelect @bind-Value="updateRequest.Status"
                                         class="mt-1 w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-[#5b4df5] focus:ring-2 focus:ring-[#5b4df5]/20">
                                <option value="active">Actif</option>
                                <option value="archived">Archivé</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-[#111827]">Description *</label>
                        <InputTextArea @bind-Value="updateRequest.Description"
                                       rows="5"
                                       class="mt-1 w-full rounded-lg border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-[#5b4df5] focus:ring-2 focus:ring-[#5b4df5]/20"
                                       placeholder="Décrivez le projet..." />
                        <ValidationMessage For="@(() => updateRequest.Description)" class="mt-1 text-xs text-red-500" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-[#111827]">URL GitHub</label>
                        <InputText @bind-Value="updateRequest.GithubUrl"
                                   class="mt-1 w-full rounded-lg border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-[#5b4df5] focus:ring-2 focus:ring-[#5b4df5]/20"
                                   placeholder="https://github.com/..." />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-[#111827]">Technologies</label>
                        <InputText @bind-Value="updateRequest.Technologies"
                                   class="mt-1 w-full rounded-lg border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-[#5b4df5] focus:ring-2 focus:ring-[#5b4df5]/20"
                                   placeholder="ASP.NET Core, Blazor, PostgreSQL..." />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-[#111827]">Image URL</label>
                        <InputText @bind-Value="updateRequest.ImageUrl"
                                   class="mt-1 w-full rounded-lg border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-[#5b4df5] focus:ring-2 focus:ring-[#5b4df5]/20"
                                   placeholder="https://..." />
                    </div>

                    <div class="flex items-center gap-6">
                        <label class="flex items-center gap-2 text-sm text-[#111827]">
                            <InputCheckbox @bind-Value="updateRequest.IsFeatured" />
                            Projet à la une
                        </label>
                        <label class="flex items-center gap-2 text-sm text-[#111827]">
                            <InputCheckbox @bind-Value="updateRequest.IsPublished" />
                            Publié
                        </label>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600">@errorMessage</div>
                    }

                    <div class="flex gap-4">
                        <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-emerald-700">
                            <i class="fas fa-save"></i>
                            Enregistrer
                        </button>
                        <button type="button" @onclick="GoBack" class="inline-flex items-center gap-2 rounded-lg bg-gray-200 px-6 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-300">
                            Annuler
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private UpdateProjectRequest updateRequest = new();
    private string errorMessage = string.Empty;
    private bool isLoading = true;
    private bool notFound;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectAsync();
    }

    private async Task LoadProjectAsync()
    {
        isLoading = true;
        notFound = false;

        try
        {
            var project = await ProjectService.GetByIdAsync(Id);
            if (project is null)
            {
                notFound = true;
                return;
            }

            updateRequest = new UpdateProjectRequest
            {
                Title = project.Title,
                Description = project.Description,
                GithubUrl = project.GithubUrl,
                ImageUrl = project.ImageUrl,
                Technologies = project.Technologies,
                Status = project.Status,
                IsFeatured = project.IsFeatured,
                IsPublished = project.IsPublished
            };
        }
        catch
        {
            notFound = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/projects");
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;

        try
        {
            var updated = await ProjectService.UpdateAsync(Id, updateRequest);
            if (updated is null)
            {
                errorMessage = "Impossible de mettre à jour le projet.";
                ToastService.ShowToast("Erreur lors de la mise à jour.", ToastLevel.Error);
                return;
            }

            ToastService.ShowToast("Projet mis à jour avec succès.", ToastLevel.Success);
            Navigation.NavigateTo("/admin/projects");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            ToastService.ShowToast("Erreur lors de la mise à jour du projet.", ToastLevel.Error);
        }
    }
}
