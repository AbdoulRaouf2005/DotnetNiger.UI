@page "/admin/projects"
@* Page admin : gestion des projets (liste/grille + filtres + pagination). *@
@using DotnetNiger.UI.Models.Responses
@using DotnetNiger.UI.Components.Admin.Cards
@inject NavigationManager Navigation
@inject IProjectService ProjectService
@inject IToastService ToastService

@if (isLoading)
{
    <div class="min-h-screen px-4 py-6 md:px-8 md:py-8">
        <div class="mx-auto max-w-7xl">
            <div class="mb-8 flex items-center justify-between gap-4">
                <div class="space-y-2">
                    <Skeleton Type="SkeletonType.Title" Class="w-48" />
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-64" />
                </div>
                <Skeleton Type="SkeletonType.Button" Width="160px" />
            </div>

            <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-center">
                <Skeleton Type="SkeletonType.Custom" Class="h-12 rounded-lg flex-1" />
                <Skeleton Type="SkeletonType.Custom" Class="h-12 w-48 rounded-lg" />
            </div>

            <Skeleton Type="SkeletonType.Custom" Class="h-10 w-32 rounded-lg mb-6" />

            <div class="overflow-hidden rounded-lg bg-white shadow-[0_10px_30px_rgba(15,23,42,0.08)] ring-1 ring-black/5">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="border-b border-gray-100 bg-gray-50">
                            <tr>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Titre</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Auteur</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Statut</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Date</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @for (int i = 0; i < 6; i++)
                            {
                                <tr>
                                    <td class="px-6 py-4"><div class="flex items-center gap-3"><Skeleton Type="SkeletonType.Custom" Class="h-12 w-12 rounded-lg" /><div class="space-y-1"><Skeleton Type="SkeletonType.Text" Lines="1" Class="w-32" /><Skeleton Type="SkeletonType.Text" Lines="1" Class="w-24" /></div></div></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Text" Lines="1" Class="w-28" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Badge" Width="80px" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Text" Lines="1" Class="w-24" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Button" Width="32px" Class="h-8" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-6 flex justify-center">
                <Skeleton Type="SkeletonType.Custom" Class="h-10 w-64 rounded-lg" />
            </div>
        </div>
    </div>
}
else
{
    <div class="min-h-screen px-4 py-6 md:px-8 md:py-8">
        <div class="mx-auto max-w-7xl">
            <div class="mb-8 flex items-center justify-between gap-4">
                <section>
                    <AdminBreadcrumb />
                    <p class="mt-2 max-w-2xl text-sm leading-6 text-[#4b5563] md:text-base">Gérez les projets de la communauté.</p>
                </section>
                <button @onclick='() => Navigation.NavigateTo("/admin/projects/nouveau")'
                        class="inline-flex items-center gap-2 rounded-lg bg-red-500 px-4 py-2 text-sm font-semibold text-white shadow-[0_10px_20px_rgba(91,77,245,0.25)] transition hover:brightness-95">
                    <i class="fas fa-plus text-sm"></i>
                    <span class="hidden sm:block">Nouveau projet</span>
                </button>
            </div>

            <section class="mb-6 flex flex-col gap-4 md:flex-row md:items-center">
                <div class="flex-1 rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-black/5">
                    <div class="relative">
                        <i class="fas fa-search absolute left-0 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <input type="text" placeholder="Rechercher un projet..."
                               @bind="searchQuery" @bind:event="oninput"
                               class="w-full border-0 bg-transparent pl-7 text-sm text-gray-900 outline-none placeholder:text-gray-400" />
                    </div>
                </div>

                <select @bind="selectedStatus" class="cursor-pointer rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-900 shadow-sm outline-none transition hover:border-gray-300">
                    <option value="">Tous les statuts</option>
                    <option value="active">Actif</option>
                    <option value="archived">Archivé</option>
                </select>
            </section>

            <ViewToggle @bind-IsListView="isListView" />

            @if (isListView)
            {
                <div class="overflow-hidden rounded-lg bg-white shadow-[0_10px_30px_rgba(15,23,42,0.08)] ring-1 ring-black/5">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="border-b border-gray-100 bg-gray-50">
                                <tr>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Titre</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Auteur</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Statut</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Date</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                @if (pagedProjects.Count == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-500">Aucun projet disponible.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var project in pagedProjects)
                                    {
                                        <tr @key="project.Id" class="transition hover:bg-gray-50/80">
                                            <td class="px-6 py-4">
                                                <div class="flex items-center gap-3">
                                                    <div class="h-12 w-12 flex-shrink-0 overflow-hidden rounded-lg bg-[#EEEAFE] flex items-center justify-center text-[#5b4df5]">
                                                        <i class="fas fa-code-branch text-lg"></i>
                                                    </div>
                                                    <div class="min-w-0">
                                                        <p class="truncate text-sm font-semibold text-[#111827]">@project.Title</p>
                                                        <p class="truncate text-xs text-[#6b7280]">@project.Technologies</p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-[#4b5563]">@project.AuthorName</td>
                                            <td class="px-6 py-4 text-sm">
                                                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold @(project.Status == "active" ? "bg-[#D1FAE5] text-[#16a34a]" : "bg-gray-100 text-gray-700")">
                                                    @(project.Status == "active" ? "Actif" : "Archivé")
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-[#4b5563] whitespace-nowrap">@project.CreatedAt.ToString("dd/MM/yyyy")</td>
                                            <td class="px-6 py-4 text-sm">
                                                <AdminActionDropdown ItemId="project.Id"
                                                                      Status="@(project.IsPublished ? "Published" : "Pending")"
                                                                      ViewLabel="Voir"
                                                                      EditLabel="Modifier"
                                                                      DeleteLabel="Supprimer"
                                                                      OnView="HandleView"
                                                                      OnEdit="HandleEdit"
                                                                      OnDelete="HandleDelete" />
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3 md:gap-5 lg:gap-6">
                    @foreach (var project in pagedProjects)
                    {
                        <AdminProjectCard @key="project.Id" Project="project"
                                          OnProjectDeleted="LoadProjectsAsync" />
                    }
                </div>
            }

            <div class="mt-6">
                <Paginated @bind-CurrentPage="currentPage" TotalPages="@totalPages" />
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isListView = true;
    private string searchQueryValue = string.Empty;
    private string selectedStatusValue = string.Empty;
    private int currentPage = 1;
    private int pageSize = 10;
    private List<ProjectResponse> allProjects = new();

    private string searchQuery
    {
        get => searchQueryValue;
        set
        {
            if (searchQueryValue == value) return;
            searchQueryValue = value;
            currentPage = 1;
        }
    }

    private string selectedStatus
    {
        get => selectedStatusValue;
        set
        {
            if (selectedStatusValue == value) return;
            selectedStatusValue = value;
            currentPage = 1;
        }
    }

    private List<ProjectResponse> filteredProjects => allProjects
        .Where(p => string.IsNullOrEmpty(searchQuery) ||
                    p.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.Description.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(p => string.IsNullOrEmpty(selectedStatus) ||
                    p.Status.Equals(selectedStatus, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)filteredProjects.Count / pageSize));

    private List<ProjectResponse> pagedProjects => filteredProjects
        .Skip((SafeCurrentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();

    private int SafeCurrentPage => Math.Clamp(currentPage, 1, totalPages);

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectsAsync();
    }

    private async Task LoadProjectsAsync()
    {
        isLoading = true;
        allProjects = (await ProjectService.GetAllAsync(null, null)).Items;
        isLoading = false;
    }

    private Task HandleView(Guid id)
    {
        Navigation.NavigateTo($"/admin/projects/edit/{id}");
        return Task.CompletedTask;
    }

    private Task HandleEdit(Guid id)
    {
        Navigation.NavigateTo($"/admin/projects/edit/{id}");
        return Task.CompletedTask;
    }

    private async Task HandleDelete(Guid id)
    {
        var deleted = await ProjectService.DeleteAsync(id);
        if (deleted)
        {
            ToastService.ShowToast("Projet supprimé avec succès.", ToastLevel.Success);
            await LoadProjectsAsync();
        }
        else
        {
            ToastService.ShowToast("Erreur lors de la suppression.", ToastLevel.Error);
        }
    }
}
