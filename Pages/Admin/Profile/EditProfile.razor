@page "/admin/profile/informations"
@* Page admin : formulaire de mise à jour du profil utilisateur. *@
@inject IProfileService ProfileService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
    <AdminBreadcrumb />

    <header class="mb-8 space-y-3">
        <p class="max-w-3xl text-lg text-slate-600">Update your professional identity within the .NET Niger community atrium.</p>
    </header>

    <div class="space-y-6">
            <section class="rounded-2xl border border-slate-200 bg-slate-100/80 p-6 shadow-sm md:p-8">
                <div class="grid grid-cols-1 gap-6 md:grid-cols-[340px_1fr] md:gap-8">
                    <div>
                        <h2 class="text-4xl font-semibold tracking-tight text-slate-800">Personal Info</h2>
                        <p class="mt-4 text-lg leading-relaxed text-slate-600">How you appear to the community members and during networking events.</p>
                    </div>

                    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                        <div class="md:col-span-1">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Nom Complet</label>
                            <InputText @bind-Value="model.FullName" class="h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <div class="md:col-span-1">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Location</label>
                            <InputText @bind-Value="model.City" class="h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <div class="md:col-span-1">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Adresse Email</label>
                            <InputText Value="@displayEmail" ValueExpression="() => displayEmail" disabled class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-base text-slate-500" />
                        </div>
                        <div class="md:col-span-1">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Telephone</label>
                            <InputText @bind-Value="model.PhoneNumber" class="h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <div class="md:col-span-2">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Pays</label>
                            <InputText @bind-Value="model.Country" class="h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-2xl border border-slate-200 bg-slate-100/80 p-6 shadow-sm md:p-8">
                <div class="grid grid-cols-1 gap-6 md:grid-cols-[340px_1fr] md:gap-8">
                    <div>
                        <h2 class="text-4xl font-semibold tracking-tight text-slate-800">The Bio</h2>
                        <p class="mt-4 text-lg leading-relaxed text-slate-600">A short editorial piece about your journey and expertise.</p>
                    </div>

                    <div class="space-y-5">
                        <div>
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Biographie</label>
                            <InputTextArea @bind-Value="model.Bio" rows="5" class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-base leading-relaxed text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                            <div class="flex flex-col gap-5 sm:flex-row sm:items-center">
                                <div class="relative mx-auto h-24 w-24 overflow-hidden rounded-full border-4 border-indigo-100 bg-slate-100 sm:mx-0 sm:h-28 sm:w-28">
                                    <img src="@AvatarPreviewUrl" alt="Aperçu avatar" class="h-full w-full object-cover" />
                                </div>

                                <div class="flex-1 space-y-3">
                                    <label id="avatar-dropzone" for="avatar-input" class="group block cursor-pointer rounded-2xl border-2 border-dashed border-slate-300 bg-slate-50 px-4 py-5 text-center transition hover:border-indigo-400 hover:bg-indigo-50/60">
                                        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-indigo-100 text-indigo-600 transition group-hover:bg-indigo-600 group-hover:text-white">
                                            <i class="fas fa-cloud-upload-alt text-lg"></i>
                                        </div>
                                        <p class="mt-3 text-sm font-semibold text-slate-700">Glisser-déposer l'avatar ici</p>
                                        <p class="mt-1 text-xs text-slate-500">Ou cliquer pour choisir une image</p>
                                        <InputFile id="avatar-input" OnChange="HandleAvatarSelected" accept="image/*" class="hidden" />
                                    </label>

                                    <div>
                                        <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Avatar</label>
                                        <p class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-500">Le fichier sélectionné ou déposé met automatiquement à jour l'aperçu et la valeur du profil.</p>
                                    </div>

                                    <p class="text-sm text-slate-500">Choisis une image locale pour mettre à jour l'avatar, ou colle une URL si l'image est hébergée ailleurs.</p>
                                </div>
                            </div>

                            <div class="mt-5">
                                <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Avatar URL</label>
                                <InputText @bind-Value="model.AvatarUrl" class="h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-2xl border border-slate-200 bg-slate-100/80 p-6 shadow-sm md:p-8">
                <div class="mb-5 flex items-center justify-between gap-3">
                    <h2 class="text-3xl font-semibold tracking-tight text-slate-800">Liens sociaux</h2>
                    <span class="text-sm text-slate-500">Gestion rapide des plateformes</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(messageSocial))
                {
                    <p class="mb-4 rounded-lg bg-white px-4 py-2 text-sm text-slate-700">@messageSocial</p>
                }

                @if (socialLinks.Count == 0)
                {
                    <p class="mb-4 text-sm text-slate-600">Aucun lien social enregistre.</p>
                }
                else
                {
                    <ul class="mb-5 space-y-2">
                        @foreach (var link in socialLinks)
                        {
                            <li class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3">
                                <div class="text-sm text-slate-700">
                                    <span class="font-semibold">@link.Platform</span>
                                    <span class="mx-2 text-slate-300">|</span>
                                    <a href="@link.Url" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">@link.Url</a>
                                </div>
                                <button type="button"
                                        @onclick="() => DeleteSocialLink(link.Id)"
                                        class="inline-flex items-center rounded-lg border border-slate-200 bg-slate-100 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200">
                                    Supprimer
                                </button>
                            </li>
                        }
                    </ul>
                }

                <EditForm Model="socialModel" OnValidSubmit="HandleAddSocialLink">
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-[1fr_1fr_auto] md:items-end">
                        <div>
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Plateforme</label>
                            <InputText @bind-Value="socialModel.Platform" class="h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <div>
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">URL</label>
                            <InputText @bind-Value="socialModel.Url" class="h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <button type="submit" class="h-12 rounded-xl bg-indigo-600 px-6 font-semibold text-white hover:bg-indigo-500">
                            Ajouter
                        </button>
                    </div>
                </EditForm>
            </section>

            <div class="flex flex-wrap items-center gap-3 pt-1">
                <button type="button" @onclick="HandleSubmit" class="inline-flex h-12 items-center rounded-xl bg-indigo-600 px-8 font-semibold text-white transition hover:bg-indigo-500">
                    Enregistrer
                </button>
                <button type="button" @onclick="Annuler" class="inline-flex h-12 items-center rounded-xl border border-slate-300 bg-white px-8 font-semibold text-slate-700 transition hover:bg-slate-100">
                    Annuler
                </button>
            </div>
    </div>
</div>

@code {
    private UpdateProfileRequest model = new();
    private AddSocialLinkRequest socialModel = new();
    private List<SocialLinkDto> socialLinks = new();
    private string? messageSocial;
    private string displayEmail = string.Empty;
    private const string AvatarDropZoneId = "avatar-dropzone";
    private const string AvatarInputId = "avatar-input";
    private bool avatarDropZoneInitialized;

    protected override async Task OnInitializedAsync()
    {
        var profil = await ProfileService.GetProfileAsync();
        model = new UpdateProfileRequest
        {
            FullName = profil.FullName,
            PhoneNumber = profil.PhoneNumber,
            Country = profil.Country,
            City = profil.City,
            AvatarUrl = profil.AvatarUrl,
            Bio = profil.Bio
        };
        displayEmail = profil.Email;

        socialLinks = await ProfileService.GetSocialLinksAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || avatarDropZoneInitialized)
        {
            return;
        }

        avatarDropZoneInitialized = true;
        await JS.InvokeVoidAsync("initAvatarDropZone", AvatarDropZoneId, AvatarInputId);
    }

    private async Task HandleSubmit()
    {
        await ProfileService.UpdateProfileAsync(model);
        Navigation.NavigateTo("/admin/profile");
    }

    private async Task HandleAvatarSelected(InputFileChangeEventArgs eventArgs)
    {
        var file = eventArgs.File;
        if (file is null)
        {
            return;
        }

        const long maxFileSize = 2 * 1024 * 1024;
        await using var stream = file.OpenReadStream(maxFileSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        model.AvatarUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(memoryStream.ToArray())}";
    }

    private async Task HandleAddSocialLink()
    {
        messageSocial = null;

        if (string.IsNullOrWhiteSpace(socialModel.Platform) || string.IsNullOrWhiteSpace(socialModel.Url))
        {
            messageSocial = "La plateforme et l'URL sont obligatoires.";
            return;
        }

        var created = await ProfileService.AddSocialLinkAsync(socialModel);
        if (created is null)
        {
            messageSocial = "Impossible d'ajouter le lien social.";
            return;
        }

        socialLinks = await ProfileService.GetSocialLinksAsync();
        socialModel = new AddSocialLinkRequest();
        messageSocial = "Lien social ajouté avec succès.";
    }

    private async Task DeleteSocialLink(Guid id)
    {
        messageSocial = null;

        var deleted = await ProfileService.DeleteSocialLinkAsync(id);
        if (!deleted)
        {
            messageSocial = "Impossible de supprimer le lien social.";
            return;
        }

        socialLinks = await ProfileService.GetSocialLinksAsync();
        messageSocial = "Lien social supprimé avec succès.";
    }

    private void Annuler() => Navigation.NavigateTo("/admin/profile");

    private string AvatarPreviewUrl => string.IsNullOrWhiteSpace(model.AvatarUrl) ? "/Images/Fond.jpeg" : model.AvatarUrl;
}
