@page "/admin/profile/informations"
@* Page admin : formulaire de mise à jour du profil utilisateur. *@
@using DotnetNiger.UI.Models
@using DotnetNiger.UI.Components.Shared
@implements IDisposable
@using DotnetNiger.UI.Components.Admin
@inject IUserStateService UserStateService
@inject IProfileService ProfileService
@inject NavigationManager Navigation
@inject IUploadService UploadService
@inject IJSRuntime JS

@if (!isLoading)
{
    <div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
        <AdminBreadcrumb />

        <header class="mb-8 space-y-3">
            <p class="max-w-3xl text-lg text-slate-600">Update your professional identity within the .NET Niger community atrium.</p>
        </header>

        <div class="space-y-6">
            <section class="rounded-lg border border-slate-200 bg-slate-100/80 p-6 shadow-sm md:p-8">
                <div class="grid grid-cols-1 gap-6 md:grid-cols-[340px_1fr] md:gap-8">
                    <div>
                        <h2 class="text-4xl font-semibold tracking-tight text-slate-800">Personal Info</h2>
                        <p class="mt-4 text-lg leading-relaxed text-slate-600">How you appear to the community members and during networking events.</p>
                    </div>

                    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                        <div class="md:col-span-1">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Nom Complet</label>
                            <InputText @bind-Value="model.FullName" class="h-12 w-full rounded-lg border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <div class="md:col-span-1">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Location</label>
                            <InputText @bind-Value="model.City" class="h-12 w-full rounded-lg border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <div class="md:col-span-1">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Adresse Email</label>
                            <InputText Value="@displayEmail" ValueExpression="() => displayEmail" disabled class="h-12 w-full rounded-lg border border-slate-200 bg-slate-50 px-4 text-base text-slate-500" />
                        </div>
                        <div class="md:col-span-1">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Telephone</label>
                            <InputText @bind-Value="model.PhoneNumber" class="h-12 w-full rounded-lg border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <div class="md:col-span-2">
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Pays</label>
                            <InputText @bind-Value="model.Country" class="h-12 w-full rounded-lg border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-lg border border-slate-200 bg-slate-100/80 p-6 shadow-sm md:p-8">
                <div class="grid grid-cols-1 gap-6 md:grid-cols-[340px_1fr] md:gap-8">
                    <div>
                        <h2 class="text-4xl font-semibold tracking-tight text-slate-800">The Bio</h2>
                        <p class="mt-4 text-lg leading-relaxed text-slate-600">A short editorial piece about your journey and expertise.</p>
                    </div>

                    <div class="space-y-5">
                        <div>
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Biographie</label>
                            <Editor @ref="EditorRef" EditorId="bioEditor" InitialContent="@(model.Bio ?? string.Empty)" />
                        </div>
                        <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                            <div class="flex flex-col gap-5 sm:flex-row sm:items-center">
                                <div class="relative mx-auto h-24 w-24 overflow-hidden rounded-full border-4 border-indigo-100 bg-slate-100 sm:mx-0 sm:h-28 sm:w-28">
                                    <img src="@AvatarPreviewUrl" alt="Aperçu avatar" class="h-full w-full object-cover" />
                                </div>

                                <div class="flex-1 space-y-3">
                                    <div>
                                        <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Avatar</label>
                                        <InputFile accept=".jpg,.jpeg,.png,.webp,.gif"
                                                   OnChange="HandleFileSelected"
                                                   class="block w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 file:mr-3 file:rounded-md file:border-0 file:bg-secondary file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-white hover:file:brightness-110" />
                                        <p class="mt-1 text-xs text-slate-500">Formats : JPG, PNG, WebP, GIF — Max 5 Mo</p>
                                    </div>

                                    @if (isUploading)
                                    {
                                        <div class="flex items-center gap-2 text-sm text-blue-600">
                                            <i class="fa-solid fa-spinner fa-spin"></i>
                                            Upload en cours...
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(uploadError))
                                    {
                                        <div class="flex items-center gap-2 rounded-lg bg-red-50 p-2 text-xs text-red-700">
                                            <i class="fa-solid fa-circle-exclamation"></i>
                                            @uploadError
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="mt-5">
                                <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Avatar URL</label>
                                <div class="flex gap-2">
                                    <InputText @bind-Value="model.AvatarUrl" class="h-12 flex-1 rounded-lg border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                                    @if (!string.IsNullOrWhiteSpace(model.AvatarUrl))
                                    {
                                        <button type="button" @onclick="ClearAvatar"
                                                class="rounded-lg bg-red-500 px-3 text-sm font-semibold text-white transition hover:bg-red-600">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-lg border border-slate-200 bg-slate-100/80 p-6 shadow-sm md:p-8">
                <div class="mb-5 flex items-center justify-between gap-3">
                    <h2 class="text-3xl font-semibold tracking-tight text-slate-800">Liens sociaux</h2>
                    <span class="text-sm text-slate-500">Gestion rapide des plateformes</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(messageSocial))
                {
                    <p class="mb-4 rounded-lg bg-white px-4 py-2 text-sm text-slate-700">@messageSocial</p>
                }

                @if (socialLinks.Count == 0)
                {
                    <p class="mb-4 text-sm text-slate-600">Aucun lien social enregistre.</p>
                }
                else
                {
                    <ul class="mb-5 space-y-2">
                        @foreach (var link in socialLinks)
                        {
                            <li class="flex flex-wrap items-center justify-between gap-3 rounded-lg border border-slate-200 bg-white px-4 py-3">
                                <div class="text-sm text-slate-700">
                                    <span class="font-semibold">@link.Platform</span>
                                    <span class="mx-2 text-slate-300">|</span>
                                    <a href="@link.Url" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">@link.Url</a>
                                </div>
                                <button type="button"
                                        @onclick="() => DeleteSocialLink(link.Id)"
                                        class="inline-flex items-center rounded-lg border border-slate-200 bg-slate-100 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200">
                                    Supprimer
                                </button>
                            </li>
                        }
                    </ul>
                }

                <EditForm Model="socialModel" OnValidSubmit="HandleAddSocialLink">
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-[1fr_1fr_auto] md:items-end">
                        <div>
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">Plateforme</label>
                            <InputText @bind-Value="socialModel.Platform" class="h-12 w-full rounded-lg border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <div>
                            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-500">URL</label>
                            <InputText @bind-Value="socialModel.Url" class="h-12 w-full rounded-lg border border-slate-200 bg-white px-4 text-base text-slate-700 focus:border-indigo-400 focus:outline-none" />
                        </div>
                        <button type="submit" class="h-12 rounded-lg bg-indigo-600 px-6 font-semibold text-white hover:bg-indigo-500">
                            Ajouter
                        </button>
                    </div>
                </EditForm>
            </section>

            <div class="flex flex-wrap items-center gap-3 pt-1">
                <button type="button" @onclick="HandleSubmit" class="inline-flex h-12 items-center rounded-lg bg-indigo-600 px-8 font-semibold text-white transition hover:bg-indigo-500">
                    Enregistrer
                </button>
                <button type="button" @onclick="Annuler" class="inline-flex h-12 items-center rounded-lg border border-slate-300 bg-white px-8 font-semibold text-slate-700 transition hover:bg-slate-100">
                    Annuler
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
        <AdminBreadcrumb />

        <div class="space-y-6">
            <section class="rounded-lg border border-slate-200 bg-slate-100/80 p-6 shadow-sm md:p-8">
                <div class="space-y-5">
                    <Skeleton Type="SkeletonType.Title" Class="w-1/3" />
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-1/2" />
                    <div class="space-y-4">
                        <div class="flex items-center justify-center">
                            <Skeleton Type="SkeletonType.Avatar" Size="112px" Class="h-28 w-28" />
                        </div>
                        <Skeleton Type="SkeletonType.Button" Class="w-full" />
                        <Skeleton Type="SkeletonType.Text" Lines="2" />
                        <Skeleton Type="SkeletonType.Custom" Class="h-12 rounded-lg w-full" />
                    </div>
                </div>
            </section>

            <section class="rounded-lg border border-slate-200 bg-slate-100/80 p-6 shadow-sm md:p-8">
                <div class="space-y-5">
                    <Skeleton Type="SkeletonType.Title" Class="w-1/3" />
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-1/2" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-32 rounded-lg w-full" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-12 rounded-lg w-full" />
                </div>
            </section>

            <section class="rounded-lg border border-slate-200 bg-slate-100/80 p-6 shadow-sm md:p-8">
                <div class="mb-5">
                    <Skeleton Type="SkeletonType.Title" Class="w-1/3" />
                </div>
                <Skeleton Type="SkeletonType.Text" Lines="2" />
                <div class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-[1fr_1fr_auto]">
                    <Skeleton Type="SkeletonType.Custom" Class="h-12 rounded-lg w-full" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-12 rounded-lg w-full" />
                    <Skeleton Type="SkeletonType.Button" Class="h-12" Width="100px" />
                </div>
            </section>

            <div class="flex gap-3">
                <Skeleton Type="SkeletonType.Button" Class="h-12" Width="140px" />
                <Skeleton Type="SkeletonType.Button" Class="h-12" Width="140px" />
            </div>
        </div>
    </div>
}

@code {
    private Editor EditorRef { get; set; } = default!;
    private UpdateProfileRequest model = new();
    private AddSocialLinkRequest socialModel = new();
    private List<SocialLinkDto> socialLinks = new();
    private string? messageSocial;
    private string displayEmail = string.Empty;
    private bool isLoading = true;
    private bool isUploading;
    private string? uploadError;

    protected override async Task OnInitializedAsync()
    {
        UserStateService.OnChange += HandleStateChanged;

        try
        {
            if (UserStateService.CurrentUser is null)
                await UserStateService.LoadUserFromStorageAsync();

            if (UserStateService.CurrentUser is null)
            {
                var profil = await ProfileService.GetProfileAsync();
                if (profil.Id != Guid.Empty)
                    await UserStateService.SetUserAsync(profil);
            }

            SyncFormFromState();
        }
        finally
        {
            isLoading = false;
        }
    }

    public void Dispose()
    {
        UserStateService.OnChange -= HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        SyncFormFromState();
        InvokeAsync(StateHasChanged);
    }

    private void SyncFormFromState()
    {
        var user = UserStateService.CurrentUser;
        if (user is null) return;

        model = new UpdateProfileRequest
        {
            FullName    = user.FullName,
            PhoneNumber = user.PhoneNumber,
            Country     = user.Country,
            City        = user.City,
            AvatarUrl   = user.AvatarUrl,
            Bio         = user.Bio
        };
        displayEmail = user.Email;
        socialLinks  = user.SocialLinks ?? new();
    }

    private async Task HandleSubmit()
    {
        model.Bio = await EditorRef.GetContentAsync();
        // ProfileService.UpdateProfileAsync synchronise UserStateService en interne.
        await ProfileService.UpdateProfileAsync(model);
        Navigation.NavigateTo("/admin/profile");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadError = null;
        var file = e.File;
        if (file is null) return;

        if (file.Size > 5 * 1024 * 1024)
        {
            uploadError = "Le fichier ne doit pas dépasser 5 Mo.";
            return;
        }

        isUploading = true;
        try
        {
            using var memoryStream = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();

            using var dimStream = new MemoryStream(bytes);
            using var dotNetRef = new DotNetStreamReference(dimStream);
            var dims = await JS.InvokeAsync<ImageDimensions>("getImageDimensionsFromStream", dotNetRef);

            if (dims.width > 1200 || dims.height > 1200)
            {
                uploadError = $"L'image dépasse 1200×1200 px (actuelle : {dims.width}×{dims.height} px).";
                return;
            }

            var base64 = Convert.ToBase64String(bytes);
            var response = await UploadService.UploadImageBase64Async(base64, file.Name, UploadType.User);
            if (response.Success)
                model.AvatarUrl = response.ImageUrl;
            else
                uploadError = response.Message ?? "Erreur lors de l'upload.";
        }
        catch (Exception ex)
        {
            uploadError = $"Erreur : {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }

    private void ClearAvatar()
    {
        model.AvatarUrl = string.Empty;
    }

    private async Task HandleAddSocialLink()
    {
        messageSocial = null;

        if (string.IsNullOrWhiteSpace(socialModel.Platform) || string.IsNullOrWhiteSpace(socialModel.Url))
        {
            messageSocial = "La plateforme et l'URL sont obligatoires.";
            return;
        }

        // ProfileService.AddSocialLinkAsync synchronise UserStateService en interne.
        var created = await ProfileService.AddSocialLinkAsync(socialModel);
        if (created is null)
        {
            messageSocial = "Impossible d'ajouter le lien social.";
            return;
        }

        socialLinks   = await ProfileService.GetSocialLinksAsync();
        socialModel   = new AddSocialLinkRequest();
        messageSocial = "Lien social ajouté avec succès.";
    }

    private async Task DeleteSocialLink(Guid id)
    {
        messageSocial = null;

        // ProfileService.DeleteSocialLinkAsync synchronise UserStateService en interne.
        var deleted = await ProfileService.DeleteSocialLinkAsync(id);
        if (!deleted)
        {
            messageSocial = "Impossible de supprimer le lien social.";
            return;
        }

        socialLinks   = await ProfileService.GetSocialLinksAsync();
        messageSocial = "Lien social supprimé avec succès.";
    }

    private void Annuler() => Navigation.NavigateTo("/admin/profile");

    private string AvatarPreviewUrl => string.IsNullOrWhiteSpace(model.AvatarUrl) ? "/Images/Fond.jpeg" : model.AvatarUrl;

    private class ImageDimensions
    {
        public int width { get; set; }
        public int height { get; set; }
    }
}
