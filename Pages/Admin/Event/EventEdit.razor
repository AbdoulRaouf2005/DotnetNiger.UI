@page "/admin/events/edit/{Id:guid}"
@* Page admin : édition d'un événement. *@
@using DotnetNiger.UI.Models
@using DotnetNiger.UI.Models.Requests
@using DotnetNiger.UI.Models.Responses
@using DotnetNiger.UI.Components.Admin
@using DotnetNiger.UI.Components.Shared
@inject NavigationManager Navigation
@inject IEventService EventService
@inject IToastService ToastService
@inject IUserService UserService
@inject PreviewStateService PreviewState

<div class="p-6 bg-primary">
    @if (isLoading)
    {
        <div class="flex justify-between items-center mb-6">
            <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-48" />
            <Skeleton Type="SkeletonType.Button" Width="100px" />
        </div>
        <div class="bg-white rounded-lg shadow p-6">
            <Skeleton Type="SkeletonType.Title" Class="w-64 mb-6" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="space-y-2">
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-20" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-10 rounded-lg w-full" />
                </div>
                <div class="space-y-2">
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-20" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-10 rounded-lg w-full" />
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="space-y-2">
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-20" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-10 rounded-lg w-full" />
                </div>
                <div class="space-y-2">
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-32" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-32 rounded-lg w-full" />
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="space-y-2">
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-20" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-10 rounded-lg w-full" />
                </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
                <Skeleton Type="SkeletonType.Custom" Class="h-20 rounded-lg w-full" />
                <Skeleton Type="SkeletonType.Custom" Class="h-20 rounded-lg w-full" />
                <Skeleton Type="SkeletonType.Custom" Class="h-20 rounded-lg w-full" />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="space-y-2">
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-24" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-10 rounded-lg w-full" />
                </div>
                <div class="space-y-2">
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-24" />
                    <Skeleton Type="SkeletonType.Custom" Class="h-10 rounded-lg w-full" />
                </div>
            </div>
            <div class="mb-6 space-y-2">
                <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-24" />
                <Skeleton Type="SkeletonType.Custom" Class="h-48 rounded-lg w-full" />
            </div>
            <div class="flex gap-4">
                <Skeleton Type="SkeletonType.Button" Width="160px" />
                <Skeleton Type="SkeletonType.Button" Width="120px" />
            </div>
        </div>
    }
    else
    {
        <div class="flex justify-between items-center mb-6">
            <AdminBreadcrumb />
            <button @onclick="GoBack" class="bg-red-500 hover:bg-red-600 text-white min-h-12 px-4 py-2 rounded-lg flex items-center gap-2">
                <i class="fas fa-arrow-left text-2xl"></i>
                <span class="Button">Retour</span>
            </button>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
            <EditForm Model="@eventRequest" OnValidSubmit="PublishAsync">
            <DataAnnotationsValidator />

            <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">

                @* ── Block 1 : informations principales ── *@
                <div class="lg:col-span-2 order-2 lg:order-1 space-y-6">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold mb-2">Titre</label>
                            <InputText @bind-Value="eventRequest.Title"
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                       placeholder="Titre de l'événement" />
                            <ValidationMessage For="@(() => eventRequest.Title)" class="text-red-500 text-sm mt-1" />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold mb-2">Capacité</label>
                            <InputNumber @bind-Value="eventRequest.Capacity"
                                         class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                         placeholder="100" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2">Auteur</label>
                        <InputText @bind-Value="organizerName"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                   placeholder="Nom de l'organisateur" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2">Catégorie</label>
                        <InputSelect @bind-Value="eventRequest.Category"
                                     class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                            <option value="">Sélectionner une catégorie</option>
                            <option value="Présentation">Présentation</option>
                            <option value="Meeting">Meeting</option>
                            <option value="Hackathon">Hackathon</option>
                            <option value="Challenge">Challenge</option>
                            <option value="Conférence">Conférence</option>
                            <option value="Workshop">Workshop</option>
                            <option value="Webinaire">Webinaire</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => eventRequest.Category)" class="text-red-500 text-sm mt-1" />
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold mb-2">Date du début</label>
                            <div class="relative">
                                <InputDate @bind-Value="eventRequest.StartDate"
                                           Type="InputDateType.DateTimeLocal"
                                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
                                <i class="fas fa-calendar-alt absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                            </div>
                            <ValidationMessage For="@(() => eventRequest.StartDate)" class="text-red-500 text-sm mt-1" />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold mb-2">Date de fin</label>
                            <div class="relative">
                                <InputDate @bind-Value="eventRequest.EndDate"
                                           Type="InputDateType.DateTimeLocal"
                                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
                                <i class="fas fa-calendar-alt absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                            </div>
                            <ValidationMessage For="@(() => eventRequest.EndDate)" class="text-red-500 text-sm mt-1" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2">Description</label>
                        <Editor @ref="EditorRef" EditorId="eventDescriptionEdit" InitialContent="@(eventRequest.Description ?? string.Empty)" />
                        @if (showDescriptionError)
                        {
                            <p class="text-red-500 text-sm mt-1">La description est obligatoire.</p>
                        }
                    </div>

                    @* Galerie photos *@
                    <div>
                        <label class="block text-sm font-semibold mb-2">Galerie photos</label>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
                            @foreach (var (url, index) in galleryImageUrls.Select((u, i) => (u, i)))
                            {
                                <div class="relative group">
                                    <img src="@url" class="h-24 w-full rounded-lg object-cover border border-gray-200" />
                                    <button type="button" @onclick="() => RemoveGalleryImage(index)"
                                            class="absolute -top-2 -right-2 flex h-6 w-6 items-center justify-center rounded-full bg-red-500 text-white text-xs shadow opacity-0 group-hover:opacity-100 transition hover:bg-red-600">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            }
                        </div>
                        @if (showGalleryUploader)
                        {
                            <ImageUploader key="@galleryUploaderKey"
                                           UploadType="UploadType.Event"
                                           OnImageUploaded="HandleGalleryImageUploaded"
                                           OnImageDeleted="HandleGalleryImageDeleted" />
                        }
                        else
                        {
                            <button type="button" @onclick="() => showGalleryUploader = true"
                                    class="w-full border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-secondary transition">
                                <i class="fas fa-plus text-gray-400"></i>
                                <p class="text-sm text-gray-500 mt-1">Ajouter une photo</p>
                            </button>
                        }
                    </div>

                    @* Intervenants *@
                    <div>
                        <label class="block text-sm font-semibold mb-3">Intervenants</label>

                        <div class="space-y-3 mb-4">
                            @for (int i = 0; i < speakers.Count; i++)
                            {
                                <div class="flex items-center gap-3 bg-gray-50 rounded-lg p-3">
                                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-secondary/10 flex items-center justify-center overflow-hidden">
                                        @if (!string.IsNullOrWhiteSpace(speakers[i].AvatarUrl))
                                        {
                                            <img src="@speakers[i].AvatarUrl" alt="@speakers[i].Name" class="h-full w-full object-cover" />
                                        }
                                        else
                                        {
                                            <span class="text-secondary font-bold text-sm">
                                                @(speakers[i].Name.Length > 0 ? speakers[i].Name[..1].ToUpper() : "?")
                                            </span>
                                        }
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-sm font-semibold text-gray-800">@speakers[i].Name</p>
                                        <input @bind="speakers[i].Role"
                                               class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 mt-1"
                                               placeholder="Rôle (ex: Intervenant)" />
                                    </div>
                                    <button type="button" @onclick="() => RemoveSpeaker(i)"
                                            class="text-red-500 hover:text-red-700 p-2">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            }
                        </div>

                        @if (showMemberSearch)
                        {
                            <div class="relative">
                                <input value="@memberSearchQuery"
                                       @oninput="OnMemberSearchChanged"
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm"
                                       placeholder="Rechercher un membre..." />
                                @if (filteredMembers.Count > 0)
                                {
                                    <div class="absolute z-10 mt-1 w-full bg-white border border-gray-200 rounded-lg shadow-lg max-h-60 overflow-y-auto">
                                        @foreach (var member in filteredMembers)
                                        {
                                            <button type="button" @onclick="() => AddSpeakerFromMember(member)"
                                                    class="flex items-center gap-3 w-full px-4 py-2.5 hover:bg-gray-50 text-left">
                                                <div class="w-8 h-8 rounded-full bg-secondary/10 flex-shrink-0 flex items-center justify-center overflow-hidden">
                                                    @if (!string.IsNullOrWhiteSpace(member.AvatarUrl))
                                                    {
                                                        <img src="@member.AvatarUrl" alt="@member.FullName" class="h-full w-full object-cover" />
                                                    }
                                                    else
                                                    {
                                                        <span class="text-secondary font-bold text-xs">@(string.IsNullOrWhiteSpace(member.FullName) ? "?" : member.FullName[..1].ToUpper())</span>
                                                    }
                                                </div>
                                                <div>
                                                    <p class="text-sm font-semibold text-gray-800">@member.FullName</p>
                                                    <p class="text-xs text-gray-500">@@@member.Username</p>
                                                </div>
                                            </button>
                                        }
                                    </div>
                                }
                                else if (!string.IsNullOrWhiteSpace(memberSearchQuery))
                                {
                                    <div class="absolute z-10 mt-1 w-full bg-white border border-gray-200 rounded-lg shadow-lg p-4 text-sm text-gray-500 text-center">
                                        Aucun membre trouvé.
                                    </div>
                                }
                            </div>
                            <button type="button" @onclick="() => showMemberSearch = false"
                                    class="mt-2 text-xs text-gray-500 hover:text-gray-700">
                                Annuler
                            </button>
                        }
                        else
                        {
                            <button type="button" @onclick="ToggleMemberSearch"
                                    class="inline-flex items-center gap-2 text-sm font-semibold text-secondary hover:text-accent-hover">
                                <i class="fas fa-plus-circle"></i>
                                Ajouter un intervenant
                            </button>
                        }
                    </div>
                </div>

                @* ── Block 2 : image + mode + champs dynamiques ── *@
                <div class="order-1 lg:order-2 space-y-6">

                    <div>
                        <label class="block text-sm font-semibold mb-2">Image de couverture</label>
                        <ImageUploader UploadType="UploadType.Event"
                                       ExistingImageUrl="@eventRequest.CoverImageUrl"
                                       OnImageUploaded="HandleImageUploaded"
                                       OnImageDeleted="HandleImageDeleted" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-3">Mode de l'événement</label>
                        <div class="flex flex-col gap-3">
                            <button type="button" @onclick='() => SetEventMode("online")'
                                    class='flex items-center gap-3 rounded-lg border-2 p-4 transition @(eventMode == "online" ? "border-secondary bg-secondary/5 ring-2 ring-secondary/20" : "border-gray-200 bg-white hover:border-gray-300")'>
                                <div class='flex h-10 w-10 items-center justify-center rounded-lg @(eventMode == "online" ? "bg-secondary text-white" : "bg-gray-100 text-gray-500")'>
                                    <i class="fas fa-globe"></i>
                                </div>
                                <div class="text-left">
                                    <p class='text-sm font-semibold @(eventMode == "online" ? "text-secondary" : "text-gray-800")'>En ligne</p>
                                    <p class="text-xs text-gray-500">Lien de visioconférence</p>
                                </div>
                            </button>
                            <button type="button" @onclick='() => SetEventMode("physical")'
                                    class='flex items-center gap-3 rounded-lg border-2 p-4 transition @(eventMode == "physical" ? "border-secondary bg-secondary/5 ring-2 ring-secondary/20" : "border-gray-200 bg-white hover:border-gray-300")'>
                                <div class='flex h-10 w-10 items-center justify-center rounded-lg @(eventMode == "physical" ? "bg-secondary text-white" : "bg-gray-100 text-gray-500")'>
                                    <i class="fas fa-building"></i>
                                </div>
                                <div class="text-left">
                                    <p class='text-sm font-semibold @(eventMode == "physical" ? "text-secondary" : "text-gray-800")'>Présentiel</p>
                                    <p class="text-xs text-gray-500">Lieu physique</p>
                                </div>
                            </button>
                            <button type="button" @onclick='() => SetEventMode("hybrid")'
                                    class='flex items-center gap-3 rounded-lg border-2 p-4 transition @(eventMode == "hybrid" ? "border-secondary bg-secondary/5 ring-2 ring-secondary/20" : "border-gray-200 bg-white hover:border-gray-300")'>
                                <div class='flex h-10 w-10 items-center justify-center rounded-lg @(eventMode == "hybrid" ? "bg-secondary text-white" : "bg-gray-100 text-gray-500")'>
                                    <i class="fas fa-globe"></i><i class="fas fa-plus text-[8px] mx-0.5"></i><i class="fas fa-building"></i>
                                </div>
                                <div class="text-left">
                                    <p class='text-sm font-semibold @(eventMode == "hybrid" ? "text-secondary" : "text-gray-800")'>Hybride</p>
                                    <p class="text-xs text-gray-500">Lieu + Lien en ligne</p>
                                </div>
                            </button>
                        </div>
                    </div>

                    <div class='@((eventMode == "online") ? "hidden" : "")'>
                        <label class="block text-sm font-semibold mb-2">Lieu</label>
                        <InputText @bind-Value="eventRequest.Location"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none"
                                   placeholder="Adresse du lieu" />
                    </div>

                    <div class='@((eventMode == "physical") ? "hidden" : "")'>
                        <label class="block text-sm font-semibold mb-2">Lien de visioconférence</label>
                        <InputText @bind-Value="eventRequest.MeetupLink"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none"
                                   placeholder="https://meet.example.com/..." />
                    </div>
                </div>

            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="mt-6 rounded-lg bg-red-50 p-3 text-sm text-red-600">@errorMessage</div>
            }

            <div class="mt-6 flex gap-4">
                <button type="button"
                        @onclick="SetPendingAsync"
                        class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-lg flex items-center gap-2">
                    <i class="fas fa-clock"></i>
                    En attente
                </button>
                <button type="button" @onclick="HandlePreview"
                        class="bg-gray-500 hover:bg-gray-600 text-white px-6 py-3 rounded-lg flex items-center gap-2">
                    <i class="fas fa-eye"></i>
                    Aperçu
                </button>
                <button type="submit"
                        class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-green-700">
                    <i class="fas fa-paper-plane"></i>
                    Publier
                </button>
            </div>
        </EditForm>
    </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private bool isLoading = true;
    private CreateEventRequest eventRequest = new();
    private string organizerName = string.Empty;
    private string errorMessage = string.Empty;
    private string eventMode = "physical";
    private bool   showDescriptionError;
    private Editor EditorRef = default!;

    private List<string> galleryImageUrls = new();
    private bool showGalleryUploader;
    private int galleryUploaderKey;

    private List<SpeakerDto> speakers = new();
    private List<UserDto> allMembers = new();
    private List<UserDto> filteredMembers = new();
    private bool showMemberSearch;
    private string memberSearchQuery = string.Empty;

    private void RemoveSpeaker(int index)
    {
        speakers.RemoveAt(index);
    }

    private void SetEventMode(string mode)
    {
        eventMode = mode;
        eventRequest.EventType = mode switch
        {
            "online" => "Online",
            "physical" => "Physical",
            "hybrid" => "Hybrid",
            _ => eventRequest.EventType
        };
        if (mode == "physical")
        {
            eventRequest.MeetupLink = "";
        }
        else if (mode == "online")
        {
            eventRequest.Location = "";
        }
    }

    private void ToggleMemberSearch()
    {
        showMemberSearch = !showMemberSearch;
        if (showMemberSearch)
        {
            memberSearchQuery = string.Empty;
            UpdateFilteredMembers();
        }
    }

    private void OnMemberSearchChanged(ChangeEventArgs e)
    {
        memberSearchQuery = e.Value?.ToString() ?? string.Empty;
        UpdateFilteredMembers();
    }

    private void UpdateFilteredMembers()
    {
        var query = memberSearchQuery?.ToLowerInvariant() ?? string.Empty;
        var selectedIds = speakers.Select(s => s.UserId).ToHashSet();
        filteredMembers = allMembers
            .Where(m => !selectedIds.Contains(m.Id))
            .Where(m => string.IsNullOrWhiteSpace(query) ||
                        m.FullName.ToLowerInvariant().Contains(query) ||
                        m.Username.ToLowerInvariant().Contains(query))
            .ToList();
    }

    private void AddSpeakerFromMember(UserDto member)
    {
        speakers.Add(new SpeakerDto
        {
            UserId = member.Id,
            Name = member.FullName,
            AvatarUrl = member.AvatarUrl ?? string.Empty,
            Role = "Intervenant"
        });
        showMemberSearch = false;
        memberSearchQuery = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            allMembers = await UserService.GetUsersAsync();

            var existingEvent = await EventService.GetEventByIdAsync(Id);
            if (existingEvent is null)
            {
                errorMessage = "é‰vénement introuvable.";
                return;
            }

            organizerName = existingEvent.OrganizerName;
            eventRequest = MapToRequest(existingEvent);
            galleryImageUrls = existingEvent.GalleryImageUrls?.ToList() ?? new();
            eventRequest.GalleryImageUrls = galleryImageUrls;
            eventMode = eventRequest.EventType?.ToLowerInvariant() switch
            {
                "online" => "online",
                "hybrid" => "hybrid",
                _ => "physical"
            };
            speakers = existingEvent.Speakers?.Select(s => new SpeakerDto
            {
                UserId = s.UserId,
                Name = s.Name,
                Role = s.Role,
                AvatarUrl = s.AvatarUrl
            }).ToList() ?? new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/events");
    }

    private void HandleImageUploaded(string imageUrl)
    {
        eventRequest.CoverImageUrl = imageUrl;
    }

    private void HandleImageDeleted()
    {
        eventRequest.CoverImageUrl = string.Empty;
    }

    private async Task SetPendingAsync()
    {
        eventRequest.IsPublished = false;
        eventRequest.IsArchived = false;
        await SaveAsync();
    }

    private async Task PublishAsync()
    {
        eventRequest.IsPublished = true;
        eventRequest.IsArchived = false;
        await SaveAsync();
    }

    private void HandleGalleryImageUploaded(string url)
    {
        galleryImageUrls.Add(url);
        eventRequest.GalleryImageUrls = galleryImageUrls;
        showGalleryUploader = false;
        galleryUploaderKey++;
    }

    private void HandleGalleryImageDeleted()
    {
        showGalleryUploader = false;
        galleryUploaderKey++;
    }

    private void RemoveGalleryImage(int index)
    {
        galleryImageUrls.RemoveAt(index);
        eventRequest.GalleryImageUrls = galleryImageUrls;
    }

    private async Task HandlePreview()
    {
        eventRequest.Description = await EditorRef.GetContentAsync();
        eventRequest.Speakers = speakers.ToList();
        eventRequest.GalleryImageUrls = galleryImageUrls;

        var previewDto = new EventDto
        {
            Id = Id,
            Title = eventRequest.Title,
            Description = eventRequest.Description,
            Location = eventRequest.Location,
            Category = eventRequest.Category,
            EventType = eventRequest.EventType,
            StartDate = eventRequest.StartDate,
            EndDate = eventRequest.EndDate,
            CoverImageUrl = eventRequest.CoverImageUrl,
            Capacity = eventRequest.Capacity,
            MeetupLink = eventRequest.MeetupLink,
            RegisteredCount = 0,
            GalleryImageUrls = galleryImageUrls,
            Speakers = speakers.ToList(),
            OrganizerName = organizerName,
            IsPublished = false
        };

        PreviewState.SetEventPreview(previewDto, $"/admin/events/edit/{Id}");
        Navigation.NavigateTo("/preview/event");
    }

    private async Task SaveAsync()
    {
        errorMessage = string.Empty;
        showDescriptionError = false;

        eventRequest.Description = await EditorRef.GetContentAsync();

        if (string.IsNullOrWhiteSpace(eventRequest.Description) ||
            eventRequest.Description is "<p></p>" or "<p><br></p>")
        {
            showDescriptionError = true;
            return;
        }

        eventRequest.Speakers = speakers.ToList();

        try
        {
            var updated = await EventService.UpdateEventAsync(Id, eventRequest);
            if (updated is null)
            {
                errorMessage = "Impossible de mettre à jour l'événement.";
                ToastService.ShowToast("Erreur lors de la mise à jour.", ToastLevel.Error);
                return;
            }
            ToastService.ShowToast("é‰vénement mis à jour.", ToastLevel.Success);
            GoBack();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            ToastService.ShowToast("Erreur lors de la mise à jour.", ToastLevel.Error);
        }
    }
    private static CreateEventRequest MapToRequest(EventDto ev)
    {
        return new CreateEventRequest
        {
            Title = ev.Title,
            Description = ev.Description,
            Location = ev.Location,
            Category = ev.Category,
            EventType = ev.EventType,
            StartDate = ev.StartDate,
            EndDate = ev.EndDate,
            CoverImageUrl = ev.CoverImageUrl,
            Capacity = ev.Capacity,
            MeetupLink = ev.MeetupLink,
            IsPublished = ev.IsPublished,
            GalleryImageUrls = ev.GalleryImageUrls?.ToList() ?? new(),
            Speakers = ev.Speakers?.Select(s => new SpeakerDto
            {
                UserId = s.UserId,
                Name = s.Name,
                Role = s.Role,
                AvatarUrl = s.AvatarUrl
            }).ToList() ?? new(),
        };
    }
}
