@page "/admin/events"
@* Page admin : gestion des événements (liste/grille + filtres). *@
@using DotnetNiger.UI.Components.Admin.Cards
@inject NavigationManager NavigationManager
@inject IEventService EventService

<div class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(91,77,245,0.09),_transparent_34%),linear-gradient(180deg,_#faf9fc_0%,_#f4f2f7_100%)] px-4 py-6 md:px-8 md:py-8">
    <div class="mx-auto max-w-7xl">
        <div class="mb-8 flex items-center justify-between gap-4">
            <AdminBreadcrumb />
            <button @onclick='() => NavigationManager.NavigateTo("/admin/events/nouveau")'
                    class="inline-flex items-center gap-2 rounded-2xl bg-[#5b4df5] px-4 py-3 text-sm font-semibold text-white shadow-[0_10px_20px_rgba(91,77,245,0.25)] transition hover:brightness-95">
                <i class="fas fa-plus text-sm"></i>
                <span class="hidden sm:block">Nouveau</span>
            </button>
        </div>

        <section class="mb-8">
            <h1 class="text-3xl font-bold tracking-tight text-[#111827] md:text-4xl">Gestion des évènements</h1>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-[#4b5563] md:text-base">Filtrez, modérez et consultez les événements avec une interface cohérente avec le dashboard.</p>
        </section>

        <section class="mb-6 flex flex-col gap-4 md:flex-row md:items-center">
            <div class="flex-1 rounded-2xl bg-white px-4 py-3 shadow-sm ring-1 ring-black/5">
                <div class="relative">
                    <i class="fas fa-search absolute left-0 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <input type="text" placeholder="Rechercher un évènement..."
                           @bind="searchQuery" @bind:event="oninput"
                           class="w-full border-0 bg-transparent pl-7 text-sm text-[#111827] outline-none placeholder:text-gray-400" />
                </div>
            </div>

            <select @bind="selectedStatus" class="cursor-pointer rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm text-[#111827] shadow-sm outline-none transition hover:border-gray-300">
                <option value="">Tous</option>
                <option value="published">Publié</option>
                <option value="pending">En attente</option>
            </select>
            <select @bind="selectedType" class="cursor-pointer rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm text-[#111827] shadow-sm outline-none transition hover:border-gray-300">
                <option value="">Type</option>
                <option value="Online">En ligne</option>
                <option value="Physical">Présentiel</option>
                <option value="Hybrid">Hybride</option>
            </select>
            <select @bind="selectedPeriod" class="cursor-pointer rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm text-[#111827] shadow-sm outline-none transition hover:border-gray-300">
                <option value="">Période</option>
                <option value="today">Aujourd'hui</option>
                <option value="week">Cette semaine</option>
                <option value="month">Ce mois</option>
                <option value="year">Cette année</option>
            </select>
        </section>

        <div class="mb-6 flex gap-2">
            <button @onclick="() => isListView = true"
                    class="@(isListView ? "bg-[#111827] text-white" : "bg-white text-[#111827] ring-1 ring-black/10") inline-flex items-center justify-center rounded-2xl px-4 py-3 transition hover:shadow-sm">
                <i class="fas fa-list text-lg"></i>
            </button>
            <button @onclick="() => isListView = false"
                    class="@(!isListView ? "bg-[#111827] text-white" : "bg-white text-[#111827] ring-1 ring-black/10") inline-flex items-center justify-center rounded-2xl px-4 py-3 transition hover:shadow-sm">
                <i class="fas fa-th text-lg"></i>
            </button>
        </div>

        @if (isListView)
        {
            <EventTable Event="@pagedEvents" OnChanged="LoadEventsAsync" />
        }
        else
        {
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3 md:gap-5 lg:gap-6">
                @foreach (var ev in pagedEvents)
                {
                    <AdminEventCard Event="@ev"
                               OnEventDeleted="LoadEventsAsync"
                               OnSetPending="SetPending"
                               OnSetPublished="SetPublished"
                               OnSetArchived="SetArchived" />
                }
            </div>
        }

        <div class="mt-6">
            <Paginated @bind-CurrentPage="currentPage" TotalPages="@totalPages" />
        </div>
    </div>
</div>

@code {
    private bool isListView = true;
    private string searchQueryValue = string.Empty;
    private string selectedStatusValue = string.Empty;
    private string selectedTypeValue = string.Empty;
    private string selectedPeriodValue = string.Empty;
    private int currentPage = 1;
    private int pageSize = 7;
    private List<EventDto> allEvents = new();

    private string searchQuery
    {
        get => searchQueryValue;
        set
        {
            if (searchQueryValue == value) return;
            searchQueryValue = value;
            currentPage = 1;
        }
    }

    private string selectedStatus
    {
        get => selectedStatusValue;
        set
        {
            if (selectedStatusValue == value) return;
            selectedStatusValue = value;
            currentPage = 1;
        }
    }

    private string selectedType
    {
        get => selectedTypeValue;
        set
        {
            if (selectedTypeValue == value) return;
            selectedTypeValue = value;
            currentPage = 1;
        }
    }

    private string selectedPeriod
    {
        get => selectedPeriodValue;
        set
        {
            if (selectedPeriodValue == value) return;
            selectedPeriodValue = value;
            currentPage = 1;
        }
    }

    private List<EventDto> filteredEvents => allEvents
        .Where(e => string.IsNullOrEmpty(searchQuery) ||
                    e.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    e.OrganizerName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    e.Location.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(e => string.IsNullOrEmpty(selectedStatus) ||
                    (selectedStatus == "published" && e.IsPublished ) ||
                    (selectedStatus == "pending" && !e.IsPublished ))
                    
        .Where(e => string.IsNullOrEmpty(selectedType) ||
                    e.EventType.Equals(selectedType, StringComparison.OrdinalIgnoreCase))
        .Where(e => string.IsNullOrEmpty(selectedPeriod) ||
                    (selectedPeriod == "today" && e.StartDate.Date == DateTime.Today) ||
                    (selectedPeriod == "week" && e.StartDate >= DateTime.Today.AddDays(-7)) ||
                    (selectedPeriod == "month" && e.StartDate >= DateTime.Today.AddDays(-30)) ||
                    (selectedPeriod == "year" && e.StartDate.Year == DateTime.Today.Year))
        .ToList();

    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)filteredEvents.Count / pageSize));

    private List<EventDto> pagedEvents => filteredEvents
        .Skip((SafeCurrentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();

    private int SafeCurrentPage => Math.Clamp(currentPage, 1, totalPages);

    protected override async Task OnInitializedAsync()
    {
        await LoadEventsAsync();
    }

    private async Task LoadEventsAsync()
    {
        allEvents = await EventService.GetAllEventsAsync();
    }

    private async Task DeleteEvent(Guid id)
    {
        await EventService.DeleteEventAsync(id);
        await LoadEventsAsync();
    }

    private async Task TogglePublish(Guid id)
    {
        await EventService.ApproveEventAsync(id);
        allEvents = await EventService.GetAllEventsAsync();
    }

    private async Task SetPending(Guid id)
    {
        var ev = allEvents.FirstOrDefault(e => e.Id == id);
        if (ev is null)
            return;

        await PersistStatusAsync(ev, isPublished: false, isArchived: false);
    }

    private async Task SetPublished(Guid id)
    {
        var ev = allEvents.FirstOrDefault(e => e.Id == id);
        if (ev is null)
            return;

        await PersistStatusAsync(ev, isPublished: true, isArchived: false);
    }

    private async Task SetArchived(Guid id)
    {
        var ev = allEvents.FirstOrDefault(e => e.Id == id);
        if (ev is null)
            return;

        await PersistStatusAsync(ev, isPublished: false, isArchived: true);
    }

    private async Task PersistStatusAsync(EventDto ev, bool isPublished, bool isArchived)
    {
        var request = new CreateEventRequest
        {
            Title = ev.Title,
            Description = ev.Description,
            Location = ev.Location,
            EventType = ev.EventType,
            StartDate = ev.StartDate,
            EndDate = ev.EndDate,
            CoverImageUrl = ev.CoverImageUrl,
            Capacity = ev.Capacity,
            MeetupLink = ev.MeetupLink,
        };

        var updated = await EventService.UpdateEventAsync(ev.Id, request);
        if (updated is null)
            return;

        await LoadEventsAsync();
    }
}
