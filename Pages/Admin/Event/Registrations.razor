@page "/admin/events/{EventId:guid}/inscriptions"
@using System.Globalization
@inject IEventService EventService
@inject NavigationManager NavigationManager

<section class="min-h-screen bg-[#ececef] px-4 py-8 sm:px-6 sm:py-10 lg:px-10">
    <div class="mx-auto w-full max-w-6xl space-y-4">
        <div class="flex items-center justify-between gap-4">
            <nav aria-label="Fil d'ariane" class="text-xs sm:text-sm text-slate-500">
                <ol class="flex flex-wrap items-center gap-2">
                    <li><a href="/admin" class="transition-colors hover:text-slate-700">Admin</a></li>
                    <li><i class="fas fa-angle-right text-[10px] text-slate-400" aria-hidden="true"></i></li>
                    <li><a href="/admin/events" class="transition-colors hover:text-slate-700">Événements</a></li>
                    <li><i class="fas fa-angle-right text-[10px] text-slate-400" aria-hidden="true"></i></li>
                    <li class="font-semibold text-slate-700">Inscrits</li>
                </ol>
            </nav>

            <button @onclick="GoBack"
                    class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-black/5 transition hover:bg-gray-50">
                <i class="fas fa-arrow-left text-sm"></i>
                <span>Retour</span>
            </button>
        </div>

        @if (IsLoading)
        {
            <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-black/5">
                <div class="border-b border-gray-100 px-6 py-5">
                    <Skeleton Type="SkeletonType.Title" Class="w-48" />
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-72 mt-2" />
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="border-b border-gray-100 bg-gray-50">
                            <tr>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Participant</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Date d'inscription</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Statut</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Présence</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @for (int i = 0; i < 5; i++)
                            {
                                <tr>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Custom" Class="h-10 w-40 rounded-lg" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Text" Lines="1" Class="w-28" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Badge" Width="80px" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Badge" Width="60px" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(LoadError))
        {
            <div class="rounded-lg bg-red-50 p-4 sm:p-6 text-xs sm:text-sm text-red-600 shadow-sm">@LoadError</div>
        }
        else if (RegistrationList is not null)
        {
            <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-black/5">
                <div class="border-b border-gray-100 px-6 py-5">
                    <div class="flex items-center justify-between">
                        <div>
                            <h1 class="text-xl font-bold text-gray-900">@EventTitle</h1>
                            <p class="mt-1 text-sm text-gray-500">
                                @RegistrationList.Count inscrit@(RegistrationList.Count > 1 ? "s" : "")
                            </p>
                        </div>
                        <button @onclick="GoToEventDetails"
                                class="inline-flex items-center gap-2 rounded-lg bg-secondary px-4 py-2 text-sm font-semibold text-white transition hover:brightness-110">
                            <i class="fas fa-eye text-sm"></i>
                            <span>Voir l'événement</span>
                        </button>
                    </div>
                </div>

                @if (RegistrationList.Count == 0)
                {
                    <div class="flex flex-col items-center justify-center py-16 text-center">
                        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-gray-100">
                            <i class="fa-solid fa-users text-2xl text-gray-400"></i>
                        </div>
                        <h3 class="mt-4 text-lg font-semibold text-gray-900">Aucun inscrit</h3>
                        <p class="mt-1 text-sm text-gray-500">Personne ne s'est encore inscrit à cet événement.</p>
                    </div>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="border-b border-gray-100 bg-gray-50">
                                <tr>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Participant</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Date d'inscription</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Statut</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Présence</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                @foreach (var reg in RegistrationList.OrderByDescending(r => r.RegisteredAt))
                                {
                                    <tr class="transition hover:bg-gray-50">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="h-10 w-10 flex-shrink-0 overflow-hidden rounded-full bg-gray-200">
                                                    @if (!string.IsNullOrWhiteSpace(reg.AvatarUrl))
                                                    {
                                                        <img src="@reg.AvatarUrl" alt="@reg.UserName" class="h-full w-full object-cover" />
                                                    }
                                                    else
                                                    {
                                                        <span class="flex h-full w-full items-center justify-center text-sm font-semibold text-gray-600">
                                                            @GetInitials(reg.UserName)
                                                        </span>
                                                    }
                                                </div>
                                                <div class="min-w-0">
                                                    <p class="text-sm font-medium text-gray-900">@reg.UserName</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                            @reg.RegisteredAt.ToString("dd MMM yyyy HH:mm", FrCulture)
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold @GetStatusStyle(reg.RegistrationStatus)">
                                                @GetStatusLabel(reg.RegistrationStatus)
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            @if (reg.IsAttended)
                                            {
                                                <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2.5 py-1 text-xs font-semibold text-green-700">
                                                    <i class="fa-solid fa-check-circle"></i>
                                                    Présent
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-600">
                                                    <i class="fa-regular fa-circle"></i>
                                                    Absent
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public Guid EventId { get; set; }

    private static readonly CultureInfo FrCulture = CultureInfo.GetCultureInfo("fr-FR");
    private List<EventRegistrationDto>? RegistrationList { get; set; }
    private string EventTitle { get; set; } = string.Empty;
    private bool IsLoading { get; set; } = true;
    private string? LoadError { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (EventId == Guid.Empty)
        {
            IsLoading = false;
            LoadError = "Identifiant d'événement invalide.";
            return;
        }

        try
        {
            RegistrationList = await EventService.GetRegistrationsByEventAsync(EventId);

            var evt = await EventService.GetEventByIdAsync(EventId);
            EventTitle = evt?.Title ?? "Événement introuvable";
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/admin/events");
    }

    private void GoToEventDetails()
    {
        NavigationManager.NavigateTo($"/admin/events/{EventId}");
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
            : parts[0][..1].ToUpperInvariant();
    }

    private static string GetStatusStyle(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "confirmed" => "bg-green-100 text-green-700",
            "pending" => "bg-amber-100 text-amber-700",
            "cancelled" => "bg-red-100 text-red-700",
            _ => "bg-gray-100 text-gray-600"
        };
    }

    private static string GetStatusLabel(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "confirmed" => "Confirmé",
            "pending" => "En attente",
            "cancelled" => "Annulé",
            _ => status ?? "Inconnu"
        };
    }
}
