@page "/admin/events/{Id:guid}"
@using Microsoft.AspNetCore.Components.Web
@using DotnetNiger.UI.Models.Responses
@using DotnetNiger.UI.Services.Contracts
@using System.Globalization
@inject IEventService EventService
@inject NavigationManager NavigationManager

@{
    var frCulture = CultureInfo.GetCultureInfo("fr-FR");
    var galleryImages = CurrentEvent?.GalleryImageUrls?.Where(u => !string.IsNullOrWhiteSpace(u)).ToList() ?? new();
}

<section class="min-h-screen bg-[#ececef] px-4 py-8 sm:px-6 sm:py-10 lg:px-10">
    <div class="mx-auto w-full max-w-6xl space-y-4">
        <nav aria-label="Fil d'ariane" class="text-xs sm:text-sm text-slate-500">
            <ol class="flex flex-wrap items-center gap-2">
                <li><a href="/admin" class="transition-colors hover:text-slate-700">Admin</a></li>
                <li><i class="fas fa-angle-right text-[10px] text-slate-400" aria-hidden="true"></i></li>
                <li><a href="/admin/events" class="transition-colors hover:text-slate-700">Événements</a></li>
                <li><i class="fas fa-angle-right text-[10px] text-slate-400" aria-hidden="true"></i></li>
                <li class="font-semibold text-slate-700">Détail</li>
            </ol>
        </nav>

        @if (IsLoading)
        {
            <div class="lg:grid lg:grid-cols-3 lg:gap-6">
                <div class="lg:col-span-2 space-y-4">
                    <div class="overflow-hidden rounded-lg bg-white shadow-sm">
                        <Skeleton Type="SkeletonType.Custom" Class="h-64 sm:h-80 w-full rounded-none" />
                        <div class="space-y-4 p-4 sm:p-8">
                            <Skeleton Type="SkeletonType.Badge" Width="100px" />
                            <Skeleton Type="SkeletonType.Title" Class="w-3/4" />
                            <div class="flex gap-3">
                                <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-1/3" />
                                <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-1/3" />
                            </div>
                            <Skeleton Type="SkeletonType.Text" Lines="4" />
                        </div>
                    </div>
                    <div class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                        <Skeleton Type="SkeletonType.Title" Class="w-1/2" />
                        <Skeleton Type="SkeletonType.Text" Lines="5" Class="mt-3" />
                    </div>
                </div>
                <div class="hidden lg:block lg:col-span-1 space-y-4">
                    <div class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                        <Skeleton Type="SkeletonType.Badge" Width="60px" />
                        <Skeleton Type="SkeletonType.Title" Class="w-3/4" />
                        <div class="mt-4 space-y-2">
                            <Skeleton Type="SkeletonType.Text" Lines="3" />
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(LoadError))
        {
            <div class="rounded-lg bg-red-50 p-4 sm:p-6 text-xs sm:text-sm text-red-600 shadow-sm">@LoadError</div>
        }
        else if (CurrentEvent is not null)
        {
            <div class="flex items-center justify-between gap-4">
                <span></span>
                <button @onclick="GoBack"
                        class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-black/5 transition hover:bg-gray-50">
                    <i class="fas fa-arrow-left text-sm"></i>
                    <span>Retour</span>
                </button>
            </div>

            <div class="lg:grid lg:grid-cols-3 lg:gap-6">
                @* --- Bloc 1 : Contenu principal --- *@
                <div class="lg:col-span-2 space-y-4">
                    @* --- Hero card --- *@
                    <article class="overflow-hidden rounded-lg bg-white shadow-sm">
                        <div class="overflow-hidden rounded-md bg-[#0b1220] shadow-[0_18px_40px_rgba(15,23,42,0.16)] mx-4 sm:mx-8 mt-4 sm:mt-8 aspect-video">
                            <img src="@GetEventCoverUrl()" alt="@CurrentEvent.Title" class="h-full w-full object-cover" />
                        </div>
                        <div class="space-y-4 p-4 sm:space-y-5 sm:p-8">
                            <div class="flex justify-between items-center">
                                <span class="inline-flex items-center gap-1 rounded-lg bg-blue-100 px-2.5 py-1 text-[10px] sm:text-xs font-semibold text-blue-700">
                                    <i class="fa-solid fa-satellite-dish text-[9px] sm:text-[10px]"></i>
                                    @GetEventTypeLabel(CurrentEvent.EventType)
                                </span>
                                <span class="inline-flex items-center gap-1 rounded-lg @(CurrentEvent.IsPublished ? "bg-green-100 text-green-700" : "bg-amber-100 text-amber-700") px-2.5 py-1 text-[10px] sm:text-xs font-semibold">
                                    @(CurrentEvent.IsPublished ? "Publié" : "En attente")
                                </span>
                            </div>

                            <h1 class="text-xl sm:text-2xl md:text-3xl font-extrabold leading-tight text-gray-700">
                                @CurrentEvent.Title
                            </h1>

                            <div class="flex flex-wrap items-center gap-3 text-xs sm:text-sm text-gray-600">
                                <span class="inline-flex items-center gap-1.5 sm:gap-2">
                                    <i class="fa-regular fa-calendar text-secondary"></i>
                                    @CurrentEvent.StartDate.ToString("dd MMMM yyyy HH:mm", frCulture)
                                </span>
                                <span class="inline-flex items-center gap-1.5 sm:gap-2">
                                    <i class="fa-solid fa-location-dot text-secondary"></i>
                                    @CurrentEvent.Location
                                </span>
                            </div>

                            @* Admin action buttons *@
                            <div class="flex flex-wrap items-center gap-2 pt-2">
                                <button @onclick="EditEvent"
                                        class="inline-flex h-10 items-center justify-center rounded-lg bg-white px-4 text-xs sm:text-sm font-semibold text-gray-700 ring-1 ring-gray-200 transition hover:bg-gray-50">
                                    Modifier
                                </button>
                                <button @onclick="ViewRegistrations"
                                        class="inline-flex h-10 items-center justify-center rounded-lg bg-secondary px-4 text-xs sm:text-sm font-semibold text-white transition hover:brightness-110">
                                    <i class="fas fa-users mr-1.5"></i>
                                    Inscrits (@CurrentEvent.RegisteredCount)
                                </button>
                                @if (CurrentEvent.IsPublished)
                                {
                                    <button @onclick="ArchiveEvent"
                                            class="inline-flex h-10 items-center justify-center rounded-lg bg-amber-500 px-4 text-xs sm:text-sm font-semibold text-white transition hover:brightness-95">
                                        Archiver
                                    </button>
                                }
                                else
                                {
                                    <button @onclick="PublishEvent"
                                            class="inline-flex h-10 items-center justify-center rounded-lg bg-secondary px-4 text-xs sm:text-sm font-semibold text-white transition hover:brightness-110">
                                        Publier
                                    </button>
                                }
                                <button @onclick="DeleteEvent"
                                        class="inline-flex h-10 items-center justify-center rounded-lg bg-red-600 px-4 text-xs sm:text-sm font-semibold text-white transition hover:brightness-95">
                                    Supprimer
                                </button>
                            </div>

                            @* Meetup link *@
                            @if (!string.IsNullOrWhiteSpace(CurrentEvent.MeetupLink) && CurrentEvent.EventType is "Online" or "Hybrid")
                            {
                                <a href="@CurrentEvent.MeetupLink" target="_blank" rel="noopener noreferrer"
                                   class="inline-flex items-center gap-2 rounded-lg bg-secondary px-4 py-2 text-xs sm:text-sm font-semibold text-white transition hover:brightness-110">
                                    <i class="fa-solid fa-video"></i>
                                    Rejoindre en @(CurrentEvent.EventType == "Online" ? "ligne" : "visioconférence")
                                </a>
                            }

                            @* Registration info *@
                            <div class="flex flex-wrap items-center gap-3 rounded-lg bg-gray-50 px-4 py-3">
                                <div class="flex items-center gap-2 ml-auto">
                                    <div>
                                        <p class="text-xs sm:text-sm font-semibold text-gray-700">
                                            @CurrentEvent.RegisteredCount inscrits
                                        </p>
                                        <p class="text-[11px] sm:text-xs text-gray-500">
                                            Capacité : @CurrentEvent.Capacity
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </article>

                    @* --- À propos --- *@
                    <article class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                        <h2 class="text-lg sm:text-xl md:text-3xl font-bold text-gray-700">
                            À propos de l'événement
                        </h2>
                        <p class="prose prose-sm max-w-none break-words mt-3">
                            @((MarkupString)CurrentEvent.Description)
                        </p>
                    </article>

                    @* --- Intervenants --- *@
                    @if (CurrentEvent.Speakers.Count > 0)
                    {
                        <article class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                            <div class="text-center">
                                <h2 class="text-lg sm:text-xl md:text-3xl font-bold text-gray-700">Intervenants</h2>
                                <p class="mt-2 text-xs sm:text-sm text-gray-500 sm:text-base">
                                    Des experts passionnés partageant leur savoir.
                                </p>
                            </div>
                            <div class="mt-5 sm:mt-7 grid grid-cols-2 gap-3 sm:gap-5 sm:grid-cols-4">
                                @foreach (var speaker in CurrentEvent.Speakers)
                                {
                                    <div class="text-center">
                                        <div class="mx-auto flex h-16 w-16 sm:h-20 sm:w-20 items-center justify-center rounded-full bg-gradient-to-br from-secondary to-indigo-700 text-sm sm:text-lg font-bold text-white ring-2 ring-indigo-200 overflow-hidden">
                                            @if (!string.IsNullOrWhiteSpace(speaker.AvatarUrl))
                                            {
                                                <img src="@speaker.AvatarUrl" alt="@speaker.Name" class="h-full w-full object-cover" />
                                            }
                                            else
                                            {
                                                <span>@(speaker.Name.Length > 0 ? speaker.Name[..1].ToUpper() : "?")</span>
                                            }
                                        </div>
                                        <h3 class="mt-2 sm:mt-3 text-xs sm:text-sm font-semibold text-gray-700">
                                            @speaker.Name
                                        </h3>
                                        <p class="text-[10px] sm:text-xs text-gray-500">@speaker.Role</p>
                                    </div>
                                }
                            </div>
                        </article>
                    }

                    @* --- Galerie photos --- *@
                    @if (galleryImages.Count > 0)
                    {
                        <article class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                            <h2 class="text-lg sm:text-xl md:text-3xl font-bold text-gray-700">Galerie photos</h2>
                            <div class="mt-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
                                @foreach (var img in galleryImages)
                                {
                                    <a href="@img" target="_blank" class="block">
                                        <img src="@img"
                                             class="h-28 sm:h-32 w-full rounded-lg object-cover border border-gray-200 hover:opacity-90 transition" />
                                    </a>
                                }
                            </div>
                        </article>
                    }
                    else if (CurrentEvent.Medias?.Any() == true)
                    {
                        <article class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                            <h2 class="text-lg sm:text-xl md:text-3xl font-bold text-gray-700">Médias</h2>
                            <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
                                @foreach (var media in CurrentEvent.Medias)
                                {
                                    <div class="overflow-hidden rounded-lg bg-gray-100">
                                        <img src="@media.Url" alt="@CurrentEvent.Title" class="h-32 w-full object-cover" />
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </div>

                @* --- Bloc 2 : Sidebar admin --- *@
                <div class="hidden lg:block lg:col-span-1 lg:sticky lg:top-8 lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto space-y-4">
                    <aside class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-[10px] sm:text-sm font-semibold uppercase tracking-[0.18em] text-gray-400">
                                    Administration
                                </p>
                                <h2 class="mt-1 text-lg sm:text-xl font-bold text-gray-800">
                                    Informations
                                </h2>
                                <p class="mt-2 text-xs sm:text-sm leading-relaxed text-gray-500">
                                    Métadonnées de l'événement.
                                </p>
                            </div>
                            <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-indigo-50 text-secondary">
                                <i class="fa-solid fa-circle-info"></i>
                            </div>
                        </div>

                        <div class="mt-5 space-y-3 text-xs sm:text-sm text-gray-600">
                            <div class="flex items-center justify-between gap-3 border-b border-gray-100 pb-2">
                                <span>Slug</span>
                                <span class="font-mono text-gray-900">@CurrentEvent.Slug</span>
                            </div>
                            <div class="flex items-center justify-between gap-3 border-b border-gray-100 pb-2">
                                <span>Début</span>
                                <span class="font-mono text-gray-900">@CurrentEvent.StartDate.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="flex items-center justify-between gap-3 border-b border-gray-100 pb-2">
                                <span>Fin</span>
                                <span class="font-mono text-gray-900">@CurrentEvent.EndDate.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="flex items-center justify-between gap-3 border-b border-gray-100 pb-2">
                                <span>Type</span>
                                <span class="font-mono text-gray-900">@CurrentEvent.EventType</span>
                            </div>
                            <div class="flex items-center justify-between gap-3 border-b border-gray-100 pb-2">
                                <span>Organisateur</span>
                                <span class="font-mono text-gray-900">@CurrentEvent.OrganizerName</span>
                            </div>
                            <div class="flex items-center justify-between gap-3">
                                <span>État</span>
                                <span class="font-mono text-gray-900">@(CurrentEvent.IsPublished ? "Publié" : "En attente")</span>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public Guid Id { get; set; }

    private static readonly CultureInfo FrCulture = CultureInfo.GetCultureInfo("fr-FR");
    private EventDto? CurrentEvent { get; set; }
    private bool IsLoading { get; set; } = true;
    private string? LoadError { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Id == Guid.Empty)
        {
            IsLoading = false;
            LoadError = "Identifiant d'événement invalide.";
            return;
        }

        try
        {
            CurrentEvent = await EventService.GetEventByIdAsync(Id);
            if (CurrentEvent is null)
            {
                LoadError = "L'événement demandé n'existe pas.";
            }
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static string GetEventTypeLabel(string? eventType)
    {
        return eventType?.ToLowerInvariant() switch
        {
            "online" => "En ligne",
            "physical" => "Présentiel",
            "hybrid" => "Hybride",
            _ => string.IsNullOrWhiteSpace(eventType) ? "Événement" : eventType
        };
    }

    private string GetEventCoverUrl()
    {
        return string.IsNullOrWhiteSpace(CurrentEvent?.CoverImageUrl)
            ? "/Images/Fond1.jpeg"
            : CurrentEvent.CoverImageUrl;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/admin/events");
    }

    private void ViewRegistrations()
    {
        if (CurrentEvent is null) return;
        NavigationManager.NavigateTo($"/admin/events/{CurrentEvent.Id}/inscriptions");
    }

    private void EditEvent()
    {
        if (CurrentEvent is null) return;
        NavigationManager.NavigateTo($"/admin/events/edit/{CurrentEvent.Id}");
    }

    private async Task PublishEvent()
    {
        if (CurrentEvent is null) return;
        await EventService.ApproveEventAsync(CurrentEvent.Id);
        CurrentEvent.IsPublished = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ArchiveEvent()
    {
        if (CurrentEvent is null || !CurrentEvent.IsPublished) return;
        await EventService.ApproveEventAsync(CurrentEvent.Id);
        CurrentEvent.IsPublished = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteEvent()
    {
        if (CurrentEvent is null) return;
        await EventService.DeleteEventAsync(CurrentEvent.Id);
        NavigationManager.NavigateTo("/admin/events");
    }
}