@page "/admin/blog/create"
@* Page admin : création d'article avec éditeur riche. *@
@using DotnetNiger.UI.Components.Admin
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IPostService PostService
@inject IUserStateService UserStateService
@inject IProfileService ProfileService

<div class="min-h-screen bg-[#F4F2F2] p-6">
    <div class="mb-6 flex items-center justify-between">
        <AdminBreadcrumb />
    </div>

    <div class="rounded-xl bg-white p-6 shadow">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Titre</label>
                <input @bind="postRequest.Title" type="text" class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none" />
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Type d'article</label>
                <select @bind="postRequest.PostType" class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 focus:outline-none">
                    <option value="">Sélectionner</option>
                    <option value="Tutorial">Tutorial</option>
                    <option value="Article">Article</option>
                    <option value="Interview">Interview</option>
                </select>
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Image de couverture</label>
                <div class="flex items-center overflow-hidden rounded-lg border border-gray-300">
                    <label class="cursor-pointer bg-gray-200 px-4 py-3 text-sm text-gray-700">
                        Choisir un fichier
                        <InputFile type="file" accept="image/*" class="hidden" Onchange="HandleImage"/>
                    </label>
                    <span class="px-3 text-sm text-gray-500">@postRequest.CoverImageUrl</span>
                </div>
            </div> 
        </div>


        <div class="mt-6">
            <textarea id="blogDescription" class="w-full min-h-96"></textarea>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="mt-4 rounded-md bg-red-50 p-3 text-sm text-red-600">@errorMessage</div>
        }

        <div class="mt-6 flex flex-wrap gap-4">
            <button class="flex items-center gap-2 rounded-lg bg-green-500 px-6 py-3 text-white transition hover:bg-green-600" @onclick="@HandleSubmit">
                <i class="fas fa-paper-plane"></i>
                Publier
            </button>
            <button class="flex items-center gap-2 rounded-lg bg-gray-700 px-6 py-3 text-white transition hover:bg-gray-800">
                <i class="fas fa-eye"></i>
                Aperçu
            </button>
        </div>
    </div>
</div>

@code {
    private CreatePostRequest postRequest = new();
    private string errorMessage = string.Empty;

    private Guid currentUserId;


    protected override async Task OnInitializedAsync()
    {
        // Charger depuis UserStateService ; fallback sur ProfileService puis synchroniser.
        if (UserStateService.CurrentUser is null)
            await UserStateService.LoadUserFromStorageAsync();

        if (UserStateService.CurrentUser is null)
        {
            var profil = await ProfileService.GetProfileAsync();
            await UserStateService.SetUserAsync(profil);
        }

        currentUserId = UserStateService.UserId;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initTinyMCE", "blogDescription"); }
            catch (Exception ex) { Console.Error.WriteLine($"TinyMCE: {ex.Message}"); }
        }
    }
    private async Task HandleImage(InputFileChangeEventArgs eventArgs)
    {
        var file = eventArgs.File;
        if (file is null)
        {
            return;
        }

        const long maxFileSize = 2 * 1024 * 1024;
        await using var stream = file.OpenReadStream(maxFileSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        postRequest.CoverImageUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(memoryStream.ToArray())}";
    }

    private async Task HandleSubmit()
    {
        try
        {
            errorMessage = string.Empty;

            postRequest.Content = await JS.InvokeAsync<string>("getTinyMCEContent", "blogDescription");

            if (string.IsNullOrWhiteSpace(postRequest.Title))
            {
                errorMessage = "Le titre est obligatoire.";
                return;
            }

            if (string.IsNullOrWhiteSpace(postRequest.PostType))
            {
                errorMessage = "Le type d'article est obligatoire.";
                return;
            }

            if (string.IsNullOrWhiteSpace(postRequest.Content))
            {
                errorMessage = "Le contenu de l'article est obligatoire.";
                return;
            }

            postRequest.Excerpt = BuildExcerpt(postRequest.Content);

            await PostService.CreatePostAsync(postRequest,currentUserId);
            NavigationManager.NavigateTo("/admin/blog");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private static string BuildExcerpt(string content)
    {
        if (string.IsNullOrWhiteSpace(content))
        {
            return string.Empty;
        }

        var plainText = System.Text.RegularExpressions.Regex.Replace(content, "<.*?>", string.Empty);
        plainText = System.Net.WebUtility.HtmlDecode(plainText).Trim();

        return plainText.Length <= 180 ? plainText : $"{plainText[..180].Trim()}...";
    }

}
