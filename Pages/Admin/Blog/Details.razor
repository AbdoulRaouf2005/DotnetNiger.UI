@page "/admin/blog/{Id:guid}"
@layout AdminLayout
@* Page admin : détail d'article avec actions de modération. *@
@using DotnetNiger.UI.Models.Responses
@using DotnetNiger.UI.Models.Requests
@using DotnetNiger.UI.Components.Admin
@using DotnetNiger.UI.Components.Admin.Shared
@using DotnetNiger.UI.Services.Contracts
@using System.Net
@using System.Text.RegularExpressions
@inject IPostService PostService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IToastService ToastService

<section class="bg-[#f6f3f7] px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
	<div class="mx-auto w-full max-w-3xl">
		<div class="mb-4 flex items-center justify-between gap-4">
			<nav aria-label="Fil d'ariane" class="text-xs sm:text-sm text-slate-500">
				<ol class="flex flex-wrap items-center gap-2">
					<li><a href="/admin" class="transition-colors hover:text-slate-700">Admin</a></li>
					<li><i class="fas fa-angle-right text-[10px] text-slate-400" aria-hidden="true"></i></li>
					<li><a href="/admin/blog" class="transition-colors hover:text-slate-700">Blog</a></li>
					<li><i class="fas fa-angle-right text-[10px] text-slate-400" aria-hidden="true"></i></li>
					<li class="font-semibold text-slate-700">Détail</li>
				</ol>
			</nav>
			<button @onclick="GoBack" class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-black/5 transition hover:bg-gray-50">
				<i class="fas fa-arrow-left text-sm"></i>
				<span>Retour</span>
			</button>
		</div>

		@if (isLoading)
		{
			<div class="py-20 text-center text-sm sm:text-base text-gray-600">Chargement...</div>
		}
		else if (post is null)
		{
			<div class="py-20 text-center">
				<h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900">Article non trouvé</h1>
				<p class="mt-3 text-sm sm:text-base text-gray-600">L'article demandé n'existe pas.</p>
			</div>
		}
		else
		{
			<div class="space-y-6 sm:space-y-7">
				<div class="flex flex-wrap items-center gap-2 text-[11px] sm:text-[13px] text-gray-500">
					@if (post.Categories?.Any() == true)
					{
						@foreach (var category in post.Categories.Take(1))
						{
							<span class="rounded-full bg-[#d6e7ff] px-2.5 py-1 text-[9px] sm:text-[10px] font-semibold uppercase tracking-[0.12em] text-[#3b82f6]">@category.Name</span>
						}
					}
					<span>@post.AuthorName</span>
					<span>•</span>
					<span>@post.PublishedAt?.ToString("dd MMM yyyy")</span>
					@if (post.ViewCount > 0)
					{
						<span>•</span>
						<span><i class="fa-solid fa-eye text-[10px] mr-1"></i>@post.ViewCount vues</span>
					}
				</div>

				<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
					<div class="space-y-2">
						<div class="flex flex-wrap items-center gap-2">
							<span class="rounded-full bg-[#F4F2F2] px-3 py-1 text-[10px] sm:text-xs font-semibold text-gray-700">@GetPostTypeLabel()</span>
							<span class="rounded-full px-3 py-1 text-[10px] sm:text-xs font-semibold @(IsPublished ? "bg-[#D1FAE5] text-[#16a34a]" : "bg-amber-100 text-amber-700")">@(IsPublished ? "Publié" : "Brouillon")</span>
						</div>

						<h1 class="text-2xl sm:text-3xl md:text-[2.8rem] font-extrabold leading-[1.1] tracking-[-0.03em] text-gray-900">
							@post.Title
						</h1>
					</div>

					<div class="flex flex-wrap gap-2">
						<button @onclick="() => EditPost(post.Id)" class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-black/5 transition hover:bg-gray-50">
							<i class="fas fa-pen text-xs"></i>
							Modifier
						</button>
						@if (!IsPublished)
						{
							<button @onclick="() => PublishPost(post.Id)" class="inline-flex items-center gap-2 rounded-full bg-[#5b4df5] px-4 py-2 text-sm font-semibold text-white shadow-[0_10px_20px_rgba(91,77,245,0.25)] transition hover:brightness-95">
								<i class="fas fa-check text-xs"></i>
								Publier
							</button>
						}
						else
						{
							<button @onclick="() => UnpublishPost(post.Id)" class="inline-flex items-center gap-2 rounded-full bg-amber-500 px-4 py-2 text-sm font-semibold text-white shadow-[0_10px_20px_rgba(245,158,11,0.20)] transition hover:brightness-95">
								<i class="fas fa-times text-xs"></i>
								Dépublier
							</button>
						}
						<button @onclick="() => DeletePost(post.Id)" class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-red-600 shadow-sm ring-1 ring-red-100 transition hover:bg-red-50">
							<i class="fas fa-trash text-xs"></i>
							Supprimer
						</button>
					</div>
				</div>

				<div class="flex items-center gap-3">
					<div class="h-10 w-10 sm:h-11 sm:w-11 overflow-hidden rounded-full bg-[#d6e7ff]">
						@if (!string.IsNullOrWhiteSpace(post.AuthorAvatar))
						{
							<img src="@post.AuthorAvatar" alt="@post.AuthorName" class="h-full w-full object-cover" />
						}
						else
						{
							<div class="flex h-full w-full items-center justify-center text-xs sm:text-sm font-bold text-secondary">@GetInitial(post.AuthorName)</div>
						}
					</div>
					<div>
						<p class="text-sm sm:text-[15px] font-semibold text-gray-900">@post.AuthorName</p>
						<p class="text-[11px] sm:text-xs text-gray-500">Article administré • @post.PublishedAt?.ToString("dd MMM yyyy")</p>
					</div>
				</div>

				<hr class="border-gray-200" />

				<div class="overflow-hidden rounded-lg bg-[#0b1220] shadow-[0_18px_40px_rgba(15,23,42,0.16)]">
					<img src="@GetCoverImage()" alt="@post.Title" class="h-56 w-full object-cover sm:h-[330px]" />
				</div>

				<div class="space-y-8 sm:space-y-10 pt-1">
					<div class="space-y-5 sm:space-y-6 text-sm sm:text-[15px] leading-7 text-gray-600">
						@if (!string.IsNullOrWhiteSpace(post.Excerpt))
						{
							<div class="italic border-l-4 border-[#5b4df5] pl-4 py-2 bg-[#f6f3f7] text-sm sm:text-base text-gray-700 font-medium">
								@post.Excerpt
							</div>
						}
						@if (!string.IsNullOrWhiteSpace(post.Content))
						{
							<div class="prose prose-sm max-w-none" @onmouseover="@(() => { })" @onmouseout="@(() => { })">
								@((MarkupString)HtmlSanitizer.Sanitize(post.Content))
							</div>
						}
						else
						{
							<p>Contenu de l'article non disponible.</p>
						}
					</div>

					<div class="space-y-3 pt-2">
						@if (post.Tags?.Any() == true)
						{
							<p class="text-[10px] sm:text-[11px] font-semibold uppercase tracking-[0.2em] text-gray-500">é‰TIQUETTES</p>
							<div class="flex flex-wrap gap-2">
								@foreach (var tag in post.Tags)
								{
									<span class="rounded-full bg-[#edf1f6] px-3 sm:px-4 py-1.5 sm:py-2 text-[10px] sm:text-xs font-semibold text-gray-700 shadow-sm cursor-pointer hover:bg-[#d6e7ff] transition">
										#@tag.Name
									</span>
								}
							</div>
						}
					</div>

					<div class="rounded-lg bg-white border-t p-4 sm:p-6 border-gray-200">
						<div class="flex items-center justify-between">
							<h2 class="text-xl sm:text-2xl font-semibold text-gray-900">Métadonnées</h2>
						</div>

						<div class="mt-5 sm:mt-6 space-y-3 text-sm text-gray-600">
							<div class="flex items-center justify-between gap-4 border-b border-gray-100 pb-2">
								<span>ID</span>
								<span class="font-mono text-gray-900">@post.Id</span>
							</div>
							<div class="flex items-center justify-between gap-4 border-b border-gray-100 pb-2">
								<span>Slug</span>
								<span class="font-mono text-gray-900">@post.Slug</span>
							</div>
							<div class="flex items-center justify-between gap-4 border-b border-gray-100 pb-2">
								<span>Créé le</span>
								<span class="font-mono text-gray-900">@post.PublishedAt?.ToString("dd/MM/yyyy HH:mm")</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		}
	</div>
</section>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private PostDto? post;
    private bool isLoading = true;

    private bool IsPublished => post?.PublishedAt != DateTime.MinValue;

    protected override async Task OnInitializedAsync()
    {
        if (Id == Guid.Empty)
        {
            isLoading = false;
            return;
        }

        post = await PostService.GetPostByIdAsync(Id);
        isLoading = false;
    }

    private string GetPostTypeLabel()
    {
        return string.IsNullOrWhiteSpace(post?.PostType) ? "Sans catégorie" : post!.PostType;
    }

    private string GetCoverImage()
    {
        return string.IsNullOrWhiteSpace(post?.CoverImageUrl)
            ? "/Images/ImageBlog.jpg"
            : post.CoverImageUrl;
    }

    private static string GetInitial(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[0].ToString().ToUpperInvariant();
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/admin/blog");
    }

    private void EditPost(Guid postId)
    {
        NavigationManager.NavigateTo($"/admin/blog/edit/{postId}");
    }

    private async Task DeletePost(Guid postId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "éÅ tes-vous sé»r de vouloir supprimer cet article ?");
        if (confirmed)
        {
            try
            {
                await PostService.DeletePostAsync(postId);
                ToastService.ShowToast("Article supprimé.", ToastLevel.Success);
                NavigationManager.NavigateTo("/admin/blog");
            }
            catch
            {
                ToastService.ShowToast("Erreur lors de la suppression.", ToastLevel.Error);
            }
        }
    }

    private async Task PublishPost(Guid postId)
    {
        if (post is null) return;

        try
        {
            var request = new UpdatePostRequest
            {
                Title = post.Title,
                Content = post.Content,
                Excerpt = post.Excerpt,
                CoverImageUrl = post.CoverImageUrl,
                PostType = post.PostType,
                SeoDescription = string.IsNullOrWhiteSpace(post.Excerpt) ? post.Title : post.Excerpt,
                CategoryIds = post.Categories?.Select(c => c.Id).ToList() ?? new(),
                TagNames = post.Tags?.Select(t => t.Name).ToList() ?? new(),
                IsPublished = true
            };

            await PostService.UpdatePostAsync(postId, request);
            post.PublishedAt = DateTime.UtcNow;
            ToastService.ShowToast("Article publié.", ToastLevel.Success);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            ToastService.ShowToast("Erreur lors de la publication.", ToastLevel.Error);
        }
    }

    private async Task UnpublishPost(Guid postId)
    {
        if (post is null) return;

        try
        {
            var request = new UpdatePostRequest
            {
                Title = post.Title,
                Content = post.Content,
                Excerpt = post.Excerpt,
                CoverImageUrl = post.CoverImageUrl,
                PostType = post.PostType,
                SeoDescription = string.IsNullOrWhiteSpace(post.Excerpt) ? post.Title : post.Excerpt,
                CategoryIds = post.Categories?.Select(c => c.Id).ToList() ?? new(),
                TagNames = post.Tags?.Select(t => t.Name).ToList() ?? new(),
                IsPublished = false
            };

            await PostService.UpdatePostAsync(postId, request);
            post.PublishedAt = DateTime.MinValue;
            ToastService.ShowToast("Article dépublié.", ToastLevel.Success);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            ToastService.ShowToast("Erreur lors de la dépublication.", ToastLevel.Error);
        }
    }
}
