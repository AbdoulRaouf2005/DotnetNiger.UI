@page "/admin/team"
@using DotnetNiger.UI.Models.Responses
@using DotnetNiger.UI.Components.Admin.Cards
@inject NavigationManager Navigation
@inject IUserService UserService
@inject IToastService ToastService

@if (isLoading)
{
    <div class="min-h-screen px-4 py-6 md:px-8 md:py-8">
        <div class="mx-auto max-w-7xl">
            <div class="mb-8 flex items-center justify-between gap-4">
                <div class="space-y-2">
                    <Skeleton Type="SkeletonType.Title" Class="w-48" />
                    <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-64" />
                </div>
                <Skeleton Type="SkeletonType.Button" Width="160px" />
            </div>
            <div class="overflow-hidden rounded-lg bg-white shadow-[0_10px_30px_rgba(15,23,42,0.08)] ring-1 ring-black/5">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="border-b border-gray-100 bg-gray-50">
                            <tr>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Membre</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Position</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Email</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Rôle</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Statut</th>
                                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @for (int i = 0; i < 5; i++)
                            {
                                <tr>
                                    <td class="px-6 py-4"><div class="flex items-center gap-3"><Skeleton Type="SkeletonType.Custom" Class="h-10 w-10 rounded-full" /><Skeleton Type="SkeletonType.Text" Lines="1" Class="w-32" /></div></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Text" Lines="1" Class="w-24" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Text" Lines="1" Class="w-36" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Badge" Width="60px" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Badge" Width="60px" /></td>
                                    <td class="px-6 py-4"><Skeleton Type="SkeletonType.Button" Width="32px" Class="h-8" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="min-h-screen px-4 py-6 md:px-8 md:py-8">
        <div class="mx-auto max-w-7xl">
            <div class="mb-8 flex items-center justify-between gap-4">
                <section>
                    <AdminBreadcrumb />
                    <p class="mt-2 max-w-2xl text-sm leading-6 text-body md:text-base">Gérez les membres de l'équipe visible sur la page À propos.</p>
                </section>
                <div class="flex items-center gap-3">
                    <ViewToggle @bind-IsListView="isListView" />
                    <button @onclick="NavigateToUsers"
                            class="inline-flex items-center gap-2 rounded-lg bg-red-500 px-4 py-2 text-sm font-semibold text-white shadow-[0_10px_20px_rgba(91,77,245,0.25)] transition hover:brightness-95">
                        <i class="fas fa-plus text-sm"></i>
                        <span class="hidden sm:block">Nouveau membre</span>
                    </button>
                </div>
            </div>

            @if (isListView)
            {
                <div class="overflow-hidden rounded-lg bg-white shadow-[0_10px_30px_rgba(15,23,42,0.08)] ring-1 ring-black/5">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="border-b border-gray-100 bg-gray-50">
                                <tr>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Membre</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Position</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Email</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Rôle</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Statut</th>
                                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                @if (teamMembers.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="px-6 py-10 text-center text-sm text-gray-500">Aucun membre dans l'équipe.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var member in teamMembers)
                                    {
                                        <tr @key="member.Id" class="transition hover:bg-gray-50/80">
                                            <td class="px-6 py-4">
                                                <div class="flex items-center gap-3">
                                                    <div class="h-10 w-10 flex-shrink-0 overflow-hidden rounded-full bg-gray-100">
                                                        @if (!string.IsNullOrWhiteSpace(member.AvatarUrl))
                                                        {
                                                            <img src="@member.AvatarUrl" alt="@member.FullName" class="h-full w-full object-cover" />
                                                        }
                                                        else
                                                        {
                                                            <div class="flex h-full w-full items-center justify-center text-sm font-semibold text-gray-400">
                                                                @GetInitial(member.FullName)
                                                            </div>
                                                        }
                                                    </div>
                                                    <div class="min-w-0">
                                                        <p class="truncate text-sm font-semibold text-title">@member.FullName</p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-body">
                                                @if (!string.IsNullOrWhiteSpace(member.Position))
                                                {
                                                    <span>@member.Position</span>
                                                }
                                                else
                                                {
                                                    <span class="text-gray-400">—</span>
                                                }
                                            </td>
                                            <td class="px-6 py-4 text-sm text-body">@member.Email</td>
                                            <td class="px-6 py-4 text-sm">
                                                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-secondary/10 text-secondary">
                                                    @GetPrimaryRole(member)
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-sm">
                                                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold @(member.IsActive ? "bg-success-bg text-success" : "bg-gray-100 text-gray-700")">
                                                    @(member.IsActive ? "Actif" : "Inactif")
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-sm">
                                                <AdminActionDropdown ItemId="member.Id"
                                                                      Status="Published"
                                                                      ViewLabel="Voir"
                                                                      EditLabel="Modifier"
                                                                      DeleteLabel="Retirer de l'équipe"
                                                                      OnView="HandleView"
                                                                      OnEdit="HandleEdit"
                                                                      OnDelete="HandleRemoveFromTeam" />
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                @if (teamMembers.Count == 0)
                {
                    <div class="rounded-lg bg-white p-10 text-center text-sm text-gray-500 shadow-[0_10px_30px_rgba(15,23,42,0.08)] ring-1 ring-black/5">
                        Aucun membre dans l'équipe.
                    </div>
                }
                else
                {
                    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                        @foreach (var member in teamMembers)
                        {
                            <AdminTeamCard User="member"
                                           OnView="HandleView"
                                           OnEdit="HandleEdit"
                                           OnRemoveFromTeam="HandleRemoveFromTeam" />
                        }
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isListView = true;
    private List<UserDto> teamMembers = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadTeamAsync();
    }

    private async Task LoadTeamAsync()
    {
        isLoading = true;
        try
        {
            var all = await UserService.GetUsersAsync();
            teamMembers = all.Where(u => u.IsTeamMember).ToList();
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task HandleView(Guid id)
    {
        Navigation.NavigateTo($"/admin/profile/{id}");
        return Task.CompletedTask;
    }

    private Task HandleEdit(Guid id)
    {
        Navigation.NavigateTo($"/admin/users");
        return Task.CompletedTask;
    }

    private async Task HandleRemoveFromTeam(Guid id)
    {
        try
        {
            var user = await UserService.GetUserByIdAsync(id);
            if (user is null) return;

            user.IsTeamMember = false;
            user.Position = string.Empty;
            await UserService.UpdateUserAsync(user);
            ToastService.ShowToast($"{user.FullName} retiré de l'équipe.", ToastLevel.Success);
            await LoadTeamAsync();
        }
        catch
        {
            ToastService.ShowToast("Erreur lors du retrait de l'équipe.", ToastLevel.Error);
        }
    }

    private static string GetInitial(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        return name.Trim().Substring(0, 1).ToUpperInvariant();
    }

    private void NavigateToUsers()
    {
        Navigation.NavigateTo("/admin/users");
    }

    private static string GetPrimaryRole(UserDto user)
        => user.Roles.FirstOrDefault() ?? "Member";
}
