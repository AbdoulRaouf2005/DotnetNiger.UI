@page "/notifications"
@implements IDisposable
@inject IUserStateService UserStateService
@inject IProfileService ProfileService
@inject INotificationService NotificationService
@inject NavigationManager Navigation
@inject IConfiguration Config

<div class="mx-auto max-w-5xl px-4 py-6 md:px-6 md:py-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <h1 class="text-2xl font-semibold tracking-tight text-slate-800 sm:text-3xl">Notifications</h1>
            <p class="mt-2 text-slate-600">Consulte les messages liés à ton compte et marque-les comme lus.</p>
        </div>

        <div class="flex gap-3">
            <button type="button"
                    class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50"
                    @onclick="ReloadAsync">
                Actualiser
            </button>
            <button type="button"
                    class="inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 disabled:cursor-not-allowed disabled:bg-slate-300"
                    disabled="@(!HasUnreadNotifications)"
                    @onclick="MarkAllAsReadAsync">
                Tout marquer comme lu
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-8 text-slate-500 shadow-sm">
            Chargement des notifications...
        </div>
    }
    else if (notifications.Count == 0)
    {
        <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-10 text-center shadow-sm">
            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-slate-100 text-slate-500">
                <i class="fas fa-bell text-xl"></i>
            </div>
            <h2 class="text-lg font-semibold text-slate-800">Aucune notification</h2>
            <p class="mt-2 text-sm text-slate-500">Les messages reçus apparaîtront ici.</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var notification in notifications)
            {
                <article class="rounded-2xl border bg-white p-5 shadow-sm transition @(notification.IsRead ? "border-slate-200" : "border-indigo-200 bg-indigo-50/40")">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                        <div class="flex gap-4">
                            <div class="mt-1 flex h-10 w-10 items-center justify-center rounded-full @(notification.IsRead ? "bg-slate-100 text-slate-400" : "bg-indigo-100 text-indigo-600")">
                                <i class="fas fa-bell"></i>
                            </div>
                            <div>
                                <div class="flex flex-wrap items-center gap-2">
                                    <h2 class="text-sm font-semibold text-slate-800">@notification.Message</h2>
                                    @if (!notification.IsRead)
                                    {
                                        <span class="inline-flex items-center rounded-full bg-indigo-600 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white">Non lu</span>
                                    }
                                </div>
                                <p class="mt-1 text-sm text-slate-500">@notification.CreatedAt.ToLocalTime().ToString("dd MMM yyyy à HH:mm")</p>
                            </div>
                        </div>

                        @if (!notification.IsRead)
                        {
                            <button type="button"
                                    class="inline-flex items-center justify-center rounded-xl border border-indigo-200 bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm transition hover:bg-indigo-50"
                                    @onclick="() => MarkAsReadAsync(notification.Id)">
                                Marquer comme lu
                            </button>
                        }
                    </div>
                </article>
            }
        </div>
    }
</div>

@code {
    private readonly List<NotificationDto> notifications = new();
    private bool isLoading = true;

    // Utilise UserStateService comme source unique de vérité.
    private Guid CurrentUserId => UserStateService.UserId;
    private bool HasUnreadNotifications => notifications.Any(n => !n.IsRead);

    protected override async Task OnInitializedAsync()
    {
        NotificationService.NotificationsChanged += HandleNotificationsChanged;

        // Charger l'état utilisateur si nécessaire.
        if (UserStateService.CurrentUser is null)
            await UserStateService.LoadUserFromStorageAsync();

        if (UserStateService.CurrentUser is null)
        {
            var profil = await ProfileService.GetProfileAsync();
            if (profil.Id != Guid.Empty)
                await UserStateService.SetUserAsync(profil);
        }

        await LoadAsync();
    }

    public void Dispose()
    {
        NotificationService.NotificationsChanged -= HandleNotificationsChanged;
    }

    private async Task LoadAsync()
    {
        isLoading = true;

        try
        {
            if (CurrentUserId == Guid.Empty)
            {
                notifications.Clear();
                var returnUrl = $"{Navigation.BaseUri.TrimEnd('/')}/auth/external-callback";
                var apiBase = Config["ApiBaseUrl"];
                if (string.IsNullOrWhiteSpace(apiBase)) return;
                var path = Config["IdentityEndpoints:Login"] ?? "/Account/Login";
                var loginUrl = $"{apiBase}{path}?returnUrl={Uri.EscapeDataString(returnUrl)}";
                Navigation.NavigateTo(loginUrl);
                return;
            }

            var loaded = await NotificationService.GetNotificationsAsync(CurrentUserId);
            notifications.Clear();
            notifications.AddRange(loaded);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ReloadAsync() => await LoadAsync();

    private async Task MarkAsReadAsync(Guid notificationId)
    {
        if (CurrentUserId == Guid.Empty) return;
        await NotificationService.MarkAsReadAsync(CurrentUserId, notificationId);
    }

    private async Task MarkAllAsReadAsync()
    {
        if (CurrentUserId == Guid.Empty) return;
        await NotificationService.MarkAllAsReadAsync(CurrentUserId);
    }

    private void HandleNotificationsChanged(Guid userId)
    {
        if (userId != CurrentUserId) return;
        _ = InvokeAsync(LoadAsync);
    }
}
