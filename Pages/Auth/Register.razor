@page "/register"
@inject IAuthService Auth
@inject IRegistrationService RegistrationService
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>Inscription - .NET Niger</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
    <div class="w-full max-w-2xl bg-white rounded-2xl shadow-lg p-8">

        <a href="javascript:history.back()" class="text-orange-500 text-sm flex items-center gap-2 mb-4">
            <i class="fas fa-arrow-left"></i>
            Retour
        </a>

        <div class="flex flex-col items-center text-center space-y-3 mb-6">
            <div class="w-16 h-16 rounded-full bg-purple-100 flex items-center justify-center">
                <i class="fas fa-users text-purple-600 text-2xl"></i>
            </div>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-800">Rejoindre la Communauté</h1>
            <p class="text-gray-500 max-w-xl">Créez votre profil de bâtisseur au sein de l'écosystème .NET au Niger.</p>
        </div>

        @* Stepper / étapes *@
        <div class="flex items-center justify-center gap-4 mb-6">
            <div class="flex items-center gap-2 text-sm @(currentStep >= 1 ? "text-gray-600" : "text-gray-400")">
                <span class="w-8 h-8 rounded-full @(currentStep >= 1 ? "bg-purple-600 text-white" : "bg-gray-100 text-gray-500") flex items-center justify-center">1</span>
                <span>Inscription</span>
            </div>
            <div class="w-8 h-px bg-gray-200"></div>
            <div class="flex items-center gap-2 text-sm @(currentStep >= 2 ? "text-gray-600" : "text-gray-400")">
                <span class="w-8 h-8 rounded-full @(currentStep >= 2 ? "bg-purple-600 text-white" : "bg-gray-100 text-gray-500") flex items-center justify-center">2</span>
                <span>Certificat</span>
            </div>
        </div>

        @if (currentStep == 1)
        {
            @if (isReturnedFromIdentity)
            {
                <div class="text-center py-6">
                    <div class="w-16 h-16 rounded-full bg-green-50 flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-check-circle text-green-600 text-3xl"></i>
                    </div>

                    <h2 class="text-xl font-bold text-gray-800">Compte créé avec succès</h2>

                    <p class="text-gray-700 mt-3 text-lg font-medium">
                        Bienvenue, @registeredName !
                    </p>

                    <p class="text-gray-500 mt-2 max-w-md mx-auto">
                        Votre compte a été créé sur la plateforme .NET Niger.
                    </p>

                    <div class="mt-6 bg-green-50 border border-green-100 rounded-lg p-4 text-sm text-green-700 text-left max-w-md mx-auto">
                        <i class="fas fa-check-circle mr-1"></i>
                        Votre adresse email a été confirmée lors de l'inscription.
                    </div>

                    <button type="button" class="mt-6 rounded-full bg-purple-700 text-white py-3 px-8 font-semibold hover:bg-purple-800 shadow-md" @onclick="GoToStep2">
                        Continuer vers votre certificat →
                    </button>
                </div>
            }
            else
            {
                <div class="text-center py-6">
                    <div class="w-16 h-16 rounded-full bg-purple-50 flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-user-plus text-purple-600 text-2xl"></i>
                    </div>

                    <h2 class="text-xl font-bold text-gray-800">Créer votre compte</h2>

                    <p class="text-gray-500 mt-2 max-w-md mx-auto">
                        Vous allez être redirigé vers la plateforme d'authentification pour créer votre compte. Votre email sera confirmé automatiquement.
                    </p>

                    <button type="button" class="mt-6 rounded-full bg-purple-700 text-white py-3 px-8 font-semibold hover:bg-purple-800 shadow-md" @onclick="RedirectToIdentityRegister">
                        Créer mon compte sur Identity
                    </button>

                    <p class="text-center text-sm text-gray-500 mt-6">
                        Déjà membre ? <a href="/login" class="text-orange-500 font-medium">Se connecter</a>
                    </p>
                </div>
            }
        }

        @if (currentStep == 2)
        {
            <RegistrationStep3
                Model="step3Model"
                ErrorMessage="step3ErrorMessage"
                IsLoading="isStep3Loading"
                IsSubmitted="isStep3Submitted"
                Status="step3Status"
                OnSubmit="HandleStep3Submit"
                OnBack="GoToStep1"
                OnContinue="NavigateToLogin" />
        }

    </div>
</div>

@code {
    private Uri IdentityRegisterUri => new($"{Config["ApiBaseUrl"] ?? Navigation.BaseUri.TrimEnd('/')}{Config["IdentityEndpoints:Register"] ?? "/Account/Register"}");

    private readonly CertificateSubmissionDto step3Model = new();
    private CertificateStatusDto? step3Status;

    private int currentStep = 1;
    private Guid tempUserId;
    private string registeredName = string.Empty;
    private string registeredEmail = string.Empty;

    private bool isReturnedFromIdentity;
    private bool isStep3Submitted;

    private string? step3ErrorMessage;

    private bool isStep3Loading;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var userIdStr = query["userId"];
        var email = query["email"];
        var fullName = query["fullName"];

        if (!string.IsNullOrWhiteSpace(userIdStr) && Guid.TryParse(userIdStr, out var uid)
            && !string.IsNullOrWhiteSpace(email))
        {
            tempUserId = uid;
            registeredEmail = email;
            registeredName = fullName ?? email;
            step3Model.UserId = uid;
            isReturnedFromIdentity = true;
        }
    }

    private void RedirectToIdentityRegister()
    {
        var returnUrl = $"{Navigation.BaseUri}register";
        var redirectUrl = $"{IdentityRegisterUri}?returnUrl={Uri.EscapeDataString(returnUrl)}";
        Navigation.NavigateTo(redirectUrl);
    }

    private async Task HandleStep3Submit(CertificateSubmissionDto request)
    {
        isStep3Loading = true;
        step3ErrorMessage = null;

        request.UserId = tempUserId;
        var result = await RegistrationService.SubmitStep2Async(request);
        isStep3Loading = false;

        if (result.Success && result.Data is not null)
        {
            step3Status = result.Data;
            isStep3Submitted = true;
        }
        else
        {
            step3ErrorMessage = result.Message ?? "Erreur lors de la soumission de la certification.";
        }
    }

    private Task GoToStep1()
    {
        currentStep = 1;
        return Task.CompletedTask;
    }

    private Task GoToStep2()
    {
        currentStep = 2;
        return Task.CompletedTask;
    }

    private void NavigateToLogin()
    {
        var returnUrl = $"{Navigation.BaseUri.TrimEnd('/')}/auth/external-callback";
        var apiBase = Config["ApiBaseUrl"];
        if (string.IsNullOrWhiteSpace(apiBase)) return;
        var path = Config["IdentityEndpoints:Login"] ?? "/Account/Login";
        var loginUrl = $"{apiBase}{path}?returnUrl={Uri.EscapeDataString(returnUrl)}";
        Navigation.NavigateTo(loginUrl);
    }
}
