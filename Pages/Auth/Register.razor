@page "/register"
@inject IAuthService Auth
@inject IRegistrationService RegistrationService
@inject NavigationManager Navigation

<PageTitle>Inscription - .NET Niger</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
    <div class="w-full max-w-2xl bg-white rounded-2xl shadow-lg p-8">

        <a href="javascript:history.back()" class="text-orange-500 text-sm flex items-center gap-2 mb-4">
            <i class="fas fa-arrow-left"></i>
            Retour
        </a>

        <div class="flex flex-col items-center text-center space-y-3 mb-6">
            <div class="w-16 h-16 rounded-full bg-purple-100 flex items-center justify-center">
                <i class="fas fa-users text-purple-600 text-2xl"></i>
            </div>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-800">Rejoindre la Communauté</h1>
            <p class="text-gray-500 max-w-xl">Créez votre profil de bâtisseur au sein de l'écosystème .NET au Niger.</p>
        </div>

        @* Stepper / étapes *@
        <div class="flex items-center justify-center gap-4 mb-6">
            <div class="flex items-center gap-2 text-sm @(currentStep >= 1 ? "text-gray-600" : "text-gray-400")">
                <span class="w-8 h-8 rounded-full @(currentStep >= 1 ? "bg-purple-600 text-white" : "bg-gray-100 text-gray-500") flex items-center justify-center">1</span>
                <span>Inscription</span>
            </div>
            <div class="w-8 h-px bg-gray-200"></div>
            <div class="flex items-center gap-2 text-sm @(currentStep >= 2 ? "text-gray-600" : "text-gray-400")">
                <span class="w-8 h-8 rounded-full @(currentStep >= 2 ? "bg-purple-600 text-white" : "bg-gray-100 text-gray-500") flex items-center justify-center">2</span>
                <span>Validation</span>
            </div>
            <div class="w-8 h-px bg-gray-200"></div>
            <div class="flex items-center gap-2 text-sm @(currentStep >= 3 ? "text-gray-600" : "text-gray-400")">
                <span class="w-8 h-8 rounded-full @(currentStep >= 3 ? "bg-purple-600 text-white" : "bg-gray-100 text-gray-500") flex items-center justify-center">3</span>
                <span>Terminé</span>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(globalSuccessMessage))
        {
            <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-green-700 text-sm">
                @globalSuccessMessage
            </div>
        }

        @if (currentStep == 1)
        {
            <RegistrationStep1
                Model="step1Model"
                ErrorMessage="step1ErrorMessage"
                IsLoading="isStep1Loading"
                OnSubmit="HandleStep1Submit" />
        }

        @if (currentStep == 2)
        {
            <RegistrationStep2
                Model="step2Model"
                ErrorMessage="step2ErrorMessage"
                IsLoading="isStep2Loading"
                OnSubmit="HandleStep2Submit"
                OnBack="GoToStep1" />
        }

        @if (currentStep == 3)
        {
            <RegistrationStep3
                Model="step3Model"
                ErrorMessage="null"
                IsLoading="isStep3Loading"
                OnContinue="NavigateToLogin" />
        }

    </div>
</div>

@code {
    private readonly RegisterRequest step1Model = new();
    private readonly CertificateSubmissionDto step2Model = new();
    private CertificateStatusDto step3Model = new()
    {
        Status = "Pending",
        SubmissionDate = DateTime.UtcNow,
        EstimatedWaitTime = "24-48 heures",
        SupportEmail = "support@dotnetniger.org"
    };

    private int currentStep = 1;
    private Guid tempUserId;

    private string? globalSuccessMessage;
    private string? step1ErrorMessage;
    private string? step2ErrorMessage;

    private bool isStep1Loading;
    private bool isStep2Loading;
    private bool isStep3Loading;

    private async Task HandleStep1Submit(RegisterRequest request)
    {
        isStep1Loading = true;
        step1ErrorMessage = null;
        step2ErrorMessage = null;
        globalSuccessMessage = null;

        var result = await Auth.RegisterStep1Async(request);
        isStep1Loading = false;

        if (result.Success && result.Data is Guid userId && userId != Guid.Empty)
        {
            tempUserId = userId;
            step2Model.UserId = tempUserId;
            globalSuccessMessage = "Compte créé. Veuillez valider votre expertise.";
            currentStep = 2;
        }
        else
        {
            step1ErrorMessage = result.Message ?? "Erreur lors de l'inscription.";
        }
    }

    private async Task HandleStep2Submit(CertificateSubmissionDto request)
    {
        isStep2Loading = true;
        step2ErrorMessage = null;
        globalSuccessMessage = null;

        request.UserId = tempUserId;
        var result = await RegistrationService.SubmitStep2Async(request);
        isStep2Loading = false;

        if (result.Success && result.Data is not null)
        {
            step3Model = result.Data;
            globalSuccessMessage = result.Message;
            currentStep = 3;
            return;
        }

        step2ErrorMessage = result.Message ?? "Erreur lors de la soumission de la certification.";
    }

    private Task GoToStep1()
    {
        step2ErrorMessage = null;
        globalSuccessMessage = null;
        currentStep = 1;
        return Task.CompletedTask;
    }

    private Task NavigateToLogin()
    {
        isStep3Loading = true;
        Navigation.NavigateTo("/login");
        return Task.CompletedTask;
    }
}
