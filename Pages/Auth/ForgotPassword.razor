@page "/forgot-password"
@* Page d'authentification : demande de lien de réinitialisation de mot de passe. *@
@inject IAuthService Auth

<PageTitle>Mot de passe oublié - .NET Niger</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
    <div class="w-full max-w-2xl">
        <a href="/login" class="inline-flex items-center text-sm text-gray-500 mb-6"><i class="fas fa-arrow-left mr-2"></i> Retour</a>

n        <div class="bg-white rounded-lg shadow-xl p-10 md:p-12">
            <div class="max-w-md mx-auto">
                <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">Mot de passe oublié ?</h1>
                <p class="text-gray-500 mb-6">Entrez votre adresse e-mail pour recevoir un lien de réinitialisation.</p>

n                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="mb-4 rounded-lg px-4 py-3 text-sm @(isSuccess ? "bg-green-50 border border-green-200 text-green-700" : "bg-red-50 border border-red-200 text-red-700")">
                        @message
                    </div>
                }

n                <EditForm Model="model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

n                    <div class="mb-4">
                        <label class="block text-xs font-medium text-gray-600 mb-2">ADRESSE E-MAIL</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"><i class="fas fa-envelope"></i></span>
                            <InputText @bind-Value="model.Email" type="email"
                                class="w-full rounded-lg bg-gray-50 border border-transparent px-4 py-3 pl-12 text-sm focus:border-violet-500 focus:ring-1 focus:ring-violet-500 outline-none transition"
                                placeholder="nom@exemple.ne" />
                        </div>
                        <ValidationMessage For="@(() => model.Email)" class="text-xs text-red-500 mt-1" />
                    </div>

                    <button type="submit" disabled="@isLoading"
                        class="w-full rounded-lg bg-violet-600 hover:bg-violet-700 text-white py-3 mt-2 font-medium shadow-md transition disabled:opacity-60">
                        @(isLoading ? "Envoi en cours..." : "Envoyer le lien de réinitialisation")
                    </button>
                </EditForm>

n                <p class="text-center text-sm text-gray-500 mt-6">
                    <a href="/login" class="text-violet-600 font-medium hover:underline">← Retour à la connexion</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private ForgotPasswordRequest model = new();
    private string message = "";
    private bool isSuccess;
    private bool isLoading;

    private async Task HandleSubmit()
    {
        isLoading = true;
        message = "";
        isSuccess = await Auth.ForgotPasswordAsync(model);
        isLoading = false;
        message = isSuccess
            ? "Un email de réinitialisation a été envoyé à votre adresse."
            : "Aucun compte associé à cet email.";
    }
}
