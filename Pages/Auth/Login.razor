@page "/login"
@using System.Security.Claims
@inject IAuthService Auth
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IConfiguration Config

<PageTitle>Connexion - .NET Niger</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-b from-[#e8e3f6] to-white px-4 py-12">
    <div class="w-full max-w-md">
        <div class="rounded-lg bg-white p-8 shadow-lg">
            <div class="text-center mb-8">
                <img src="/Logo.svg" alt="logo" class="h-16 w-16 mx-auto mb-4" />
                <h1 class="text-2xl font-bold text-secondary">Connexion</h1>
                <p class="text-sm text-gray-500 mt-1">Connectez-vous à votre compte</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600">@ErrorMessage</div>
            }

            <EditForm Model="@Model" OnValidSubmit="HandleLoginAsync" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <InputText @bind-Value="Model.Email"
                               class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                               placeholder="exemple@email.com" />
                    <ValidationMessage For="@(() => Model.Email)" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
                    <InputText @bind-Value="Model.Password" type="password"
                               class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                               placeholder="Votre mot de passe" />
                    <ValidationMessage For="@(() => Model.Password)" />
                </div>

                <button type="submit" disabled="@IsLoading"
                        class="w-full rounded-lg bg-secondary px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-hover disabled:opacity-50">
                    @(IsLoading ? "Connexion en cours..." : "Se connecter")
                </button>
            </EditForm>

            <div class="mt-6 text-center text-sm text-gray-500">
                <p>Comptes de démonstration :</p>
                <p class="mt-1"><strong>admin&#64;dotnet.niger</strong> / password123</p>
                <p><strong>fatima&#64;dotnet.niger</strong> / password123</p>
            </div>
        </div>
    </div>
</div>

@code {
    private FormModel Model { get; set; } = new();
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }

    private async Task HandleLoginAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var request = new LoginRequest
            {
                Email = Model.Email,
                Password = Model.Password
            };

            var result = await Auth.LoginAsync(request);

            if (result.Success && result.Data is not null)
            {
                if (AuthStateProvider is MockAuthenticationStateProvider mockProvider)
                {
                    mockProvider.SetAuthenticated(result.Data.User);
                }

                var redirectPath = Auth.GetPostLoginRedirectPath(result.Data.User.Roles);
                Navigation.NavigateTo(redirectPath);
            }
            else
            {
                ErrorMessage = result.Message ?? "Email ou mot de passe incorrect.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "L'email est requis")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Email invalide")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Le mot de passe est requis")]
        public string Password { get; set; } = string.Empty;
    }
}
