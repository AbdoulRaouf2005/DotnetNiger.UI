@page "/login"
@* Page d'authentification : connexion utilisateur (design refait) *@
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@inject IAuthService AuthService
@inject IUserStateService UserStateService
@inject DotnetNiger.UI.Services.Contracts.ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@inject DotnetNiger.UI.Services.Auth.CustomAuthStateProvider AuthProvider
@inject Microsoft.Extensions.Configuration.IConfiguration Config

<PageTitle>Connexion - .NET Niger</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
    <div class="w-full max-w-2xl">
        <a href="/" class="inline-flex items-center text-sm text-gray-500 mb-6"><i class="fas fa-arrow-left mr-2"></i> RETOUR</a>

        <div class="bg-white rounded-2xl shadow-xl p-10 md:p-12">
            <div class="max-w-md mx-auto">
                <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">Se connecter</h1>
                <p class="text-gray-500 mb-6">Bon retour parmi nous ! Veuillez entrer vos identifiants.</p>

                <div class="flex gap-3 mb-6">
                    <button @onclick='() => NavigateToExternalLogin("Google")' class="flex-1 flex items-center justify-center gap-2 border rounded-lg px-4 py-2 text-sm bg-white hover:bg-gray-50">
                        <i class="fab fa-google text-xl"></i>
                        <span>Google</span>
                    </button>
                    <button @onclick='() => NavigateToExternalLogin("GitHub")' class="flex-1 flex items-center justify-center gap-2 border rounded-lg px-4 py-2 text-sm bg-white hover:bg-gray-50">
                        <i class="fab fa-github text-xl"></i>
                        <span>GitHub</span>
                    </button>
                    <button class="flex-1 flex items-center justify-center gap-2 border rounded-lg px-4 py-2 text-sm bg-white hover:bg-gray-50">
                        <i class="fab fa-microsoft text-xl"></i>
                        <span>Microsoft</span>
                    </button>
                </div>

                <div class="relative my-4">
                    <div class="border-t"></div>
                    <span class="absolute -top-3 left-1/2 transform -translate-x-1/2 bg-white px-3 text-sm text-gray-400">ou</span>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-red-700 text-sm">
                        @errorMessage
                    </div>
                }

                <EditForm Model="model" OnValidSubmit="HandleLogin">
                    <DataAnnotationsValidator />

                    <div class="mb-4">
                        <label class="block text-xs font-medium text-gray-600 mb-2">ADRESSE EMAIL</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"><i class="fas fa-envelope"></i></span>
                            <InputText @bind-Value="model.Email" type="email"
                                class="w-full rounded-xl bg-gray-50 border border-transparent px-4 py-3 pl-12 text-sm focus:border-violet-500 focus:ring-1 focus:ring-violet-500 outline-none transition"
                                placeholder="nom@exemple.com" />
                        </div>
                        <ValidationMessage For="@(() => model.Email)" class="text-xs text-red-500 mt-1" />
                    </div>

                    <div class="mb-4">
                        <div class="flex justify-between items-center mb-2">
                            <label class="block text-xs font-medium text-gray-600">MOT DE PASSE</label>
                            <a href="/forgot-password" class="text-sm text-violet-600 hover:underline">Oublié ?</a>
                        </div>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"><i class="fas fa-lock"></i></span>
                            <InputText @bind-Value="model.Password" type="@(showPassword ? "text" : "password")"
                                class="w-full rounded-xl bg-gray-50 border border-transparent px-4 py-3 pl-12 pr-10 text-sm focus:border-violet-500 focus:ring-1 focus:ring-violet-500 outline-none transition"
                                placeholder="••••••••" />

                            <button type="button" @onclick="() => showPassword = !showPassword"
                                class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600 transition"
                                title="@(showPassword ? "Masquer" : "Afficher") le mot de passe">
                                @if (showPassword)
                                {
                                    <i class="fas fa-eye"></i>
                                }
                                else
                                {
                                    <i class="fas fa-eye-slash"></i>
                                }
                            </button>
                        </div>
                        <ValidationMessage For="@(() => model.Password)" class="text-xs text-red-500 mt-1" />
                    </div>

                    <button type="submit" disabled="@isLoading"
                        class="w-full rounded-xl bg-violet-600 hover:bg-violet-700 text-white py-3 mt-2 font-medium shadow-md transition disabled:opacity-60">
                        @(isLoading ? "Connexion en cours..." : "Se connecter")
                    </button>
                </EditForm>

                <p class="text-center text-sm text-gray-500 mt-6">
                    Pas encore membre ?
                    <a href="/register" class="text-violet-600 font-medium hover:underline">Rejoindre la communauté</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginRequest model = new();
    private bool isLoading = false;
    private string errorMessage = string.Empty;
    private bool showPassword = false;

    private void NavigateToExternalLogin(string provider)
    {
        var apiBase = Config["ApiBaseUrl"] ?? "http://localhost:5000";
        var returnUrl = $"{Navigation.BaseUri}auth/external-callback";
        var url = $"{apiBase}/api/auth/external-login?provider={provider}&returnUrl={Uri.EscapeDataString(returnUrl)}&target=frontend";
        Navigation.NavigateTo(url, forceLoad: true);
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = string.Empty;
        
        var response = await AuthService.LoginAsync(model);
        
        if (response.Success && response.Data != null)
        {
            var userInfo = response.Data.User;

            await UserStateService.SetUserAsync(userInfo);

            await AuthProvider.SaveTokensAsync(response.Data.Token.AccessToken, response.Data.Token.RefreshToken);

            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = response.Message ?? "Erreur de connexion";
        }

        isLoading = false;
    }
}
