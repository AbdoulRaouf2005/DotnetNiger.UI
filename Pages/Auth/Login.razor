@page "/login"
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Configuration.IConfiguration Config

@code {
    protected override void OnInitialized()
    {
        var apiBase = Config["ApiBaseUrl"];
        if (string.IsNullOrWhiteSpace(apiBase))
        {
            Navigation.NavigateTo("/");
            return;
        }
        var returnUrl = $"{Navigation.BaseUri.TrimEnd('/')}/auth/external-callback";
        var path = Config["IdentityEndpoints:Login"] ?? "/Account/Login";
        var loginUrl = $"{apiBase}{path}?returnUrl={Uri.EscapeDataString(returnUrl)}";
        Navigation.NavigateTo(loginUrl, forceLoad: true);
    }
}
