@page "/projets/soumettre"
@using System.ComponentModel.DataAnnotations
@inject NavigationManager NavigationManager

<PageTitle>Soumettre un projet</PageTitle>

<div class="min-h-screen bg-[#F4F2F2] px-4 py-8 text-gray-900 sm:px-6 sm:py-10 lg:px-8">
    <div class="mx-auto max-w-5xl">
        <a href="/Community" class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 transition hover:text-indigo-700">
            <i class="fas fa-arrow-left"></i>
            Retour aux projets
        </a>

        <div class="mt-5 sm:mt-6 max-w-3xl">
            <h1 class="text-2xl font-extrabold tracking-tight text-gray-900 sm:text-3xl md:text-4xl">Lancer un nouveau projet</h1>
            <p class="mt-3 sm:mt-4 text-sm sm:text-base leading-6 sm:leading-7 text-gray-600 sm:text-lg">
                Donnez vie à vos idées et rassemblez la communauté .NET Niger autour de l'excellence open source.
            </p>
        </div>

        <EditForm Model="submission" OnValidSubmit="HandleValidSubmit" class="mt-10 space-y-8">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700 shadow-sm">
                    @successMessage
                </div>
            }

            <div class="rounded-lg bg-white p-5 sm:p-6 shadow-[0_20px_50px_rgba(15,23,42,0.06)] sm:p-8">
                <div class="flex items-start gap-4">
                    <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-100 text-xl text-indigo-600">
                        <i class="fas fa-rocket"></i>
                    </div>
                    <div>
                        <h2 class="text-base sm:text-lg font-semibold text-gray-900">Identité du Projet</h2>
                        <p class="mt-1 text-xs sm:text-sm leading-6 text-gray-500">Comment la communauté identifiera votre travail.</p>
                    </div>
                </div>

                <div class="mt-8 grid gap-6">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-gray-700" for="project-title">Titre du projet</label>
                        <InputText id="project-title" @bind-Value="submission.Title" class="w-full rounded-lg border border-gray-200 bg-[#eef1f5] px-4 py-3 text-gray-900 placeholder:text-gray-400 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-indigo-100" placeholder="Ex: NigerPay Gateway" />
                        <ValidationMessage For="@(() => submission.Title)" />
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-medium text-gray-700" for="project-description">Description</label>
                        <InputTextArea id="project-description" @bind-Value="submission.Description" class="min-h-[9rem] w-full rounded-lg border border-gray-200 bg-[#eef1f5] px-4 py-3 text-gray-900 placeholder:text-gray-400 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-indigo-100" placeholder="Décrivez l'objectif, le problème résolu et la vision du projet..." />
                        <ValidationMessage For="@(() => submission.Description)" />
                    </div>
                </div>
            </div>

            <div class="grid gap-6 lg:grid-cols-2">
                <div class="rounded-lg bg-white p-5 sm:p-6 shadow-[0_20px_50px_rgba(15,23,42,0.06)] sm:p-8">
                    <div class="flex items-start gap-4">
                        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-100 text-lg text-indigo-600">
                            <i class="fas fa-code-branch"></i>
                        </div>
                        <div>
                            <h2 class="text-base sm:text-lg font-semibold text-gray-900">Stack technique</h2>
                            <p class="mt-1 text-xs sm:text-sm leading-6 text-gray-500">Ajoutez un tag pour mieux qualifier votre projet.</p>
                        </div>
                    </div>

                        <div class="mt-5 sm:mt-6">
                        <div class="flex flex-col gap-3 sm:flex-row">
                            <InputText @bind-Value="techStackInput" class="flex-1 rounded-lg border border-gray-200 bg-[#eef1f5] px-4 py-3 text-sm text-gray-900 placeholder:text-gray-400 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-indigo-100" placeholder="Ajouter un tag (C#, ASP.NET Core...)" />
                            <button type="button" class="rounded-lg border border-indigo-600 bg-indigo-600 px-4 py-3 text-xs sm:text-sm font-semibold text-white transition hover:bg-indigo-700" @onclick="AddTechStack">
                                Ajouter
                            </button>
                        </div>

                        <div class="mt-4 flex flex-wrap gap-2">
                            @foreach (var tag in techStackTags)
                            {
                                <button type="button" class="rounded-lg bg-emerald-50 px-3 py-1 text-xs sm:text-sm font-medium text-emerald-600 transition hover:bg-emerald-100" @onclick="() => AddSuggestedTag(tag)">
                                    @tag
                                </button>
                            }
                        </div>

                        @if (selectedTechStacks.Count > 0)
                        {
                            <div class="mt-4 flex flex-wrap gap-2">
                                @foreach (var tag in selectedTechStacks)
                                {
                                    <span class="rounded-lg bg-indigo-50 px-3 py-1 text-xs sm:text-sm font-medium text-indigo-700">@tag</span>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="rounded-lg bg-white p-5 sm:p-6 shadow-[0_20px_50px_rgba(15,23,42,0.06)] sm:p-8">
                    <div class="flex items-start gap-4">
                        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-100 text-lg text-indigo-600">
                            <i class="fas fa-link"></i>
                        </div>
                        <div>
                            <h2 class="text-base sm:text-lg font-semibold text-gray-900">Dépôt GitHub</h2>
                            <p class="mt-1 text-xs sm:text-sm leading-6 text-gray-500">Assurez-vous que le dépôt est public.</p>
                        </div>
                    </div>

                    <div class="mt-6">
                        <label class="mb-2 block text-xs sm:text-sm font-medium text-gray-700" for="project-repository">URL du dépôt</label>
                        <InputText id="project-repository" @bind-Value="submission.RepositoryUrl" class="w-full rounded-lg border border-gray-200 bg-[#eef1f5] px-4 py-3 text-gray-900 placeholder:text-gray-400 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-indigo-100" placeholder="https://github.com/votre-compte/projet" />
                        <ValidationMessage For="@(() => submission.RepositoryUrl)" />
                    </div>

                    <div class="mt-4 rounded-lg bg-gray-50 px-4 py-3 text-xs sm:text-sm leading-6 text-gray-500">
                        <i class="fas fa-circle-info mr-2 text-indigo-500"></i>
                        Ajoutez un README clair pour faciliter la revue par la communauté.
                    </div>
                </div>
            </div>

            <div class="flex flex-col-reverse items-stretch justify-end gap-3 sm:flex-row sm:items-center">
                <button type="button" class="rounded-lg px-5 py-3 text-xs sm:text-sm font-semibold text-indigo-600 transition hover:bg-indigo-50" @onclick="Cancel">
                    Annuler
                </button>
                <button type="submit" class="rounded-lg bg-indigo-600 px-6 py-3 text-xs sm:text-sm font-semibold text-white shadow-lg shadow-indigo-200 transition hover:bg-indigo-700">
                    Publier le projet
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly ProjectSubmissionModel submission = new();
    private readonly List<string> techStackTags = new() { ".NET 8", "Entity Framework", "PostgreSQL" };
    private readonly List<string> selectedTechStacks = new();
    private string techStackInput = string.Empty;
    private string successMessage = string.Empty;

    private void AddTechStack()
    {
        var value = techStackInput.Trim();

        if (string.IsNullOrWhiteSpace(value) || selectedTechStacks.Contains(value, StringComparer.OrdinalIgnoreCase))
        {
            techStackInput = string.Empty;
            return;
        }

        selectedTechStacks.Add(value);
        techStackInput = string.Empty;
    }

    private void AddSuggestedTag(string tag)
    {
        if (selectedTechStacks.Contains(tag, StringComparer.OrdinalIgnoreCase))
        {
            return;
        }

        selectedTechStacks.Add(tag);
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/Community");
    }

    private Task HandleValidSubmit()
    {
        successMessage = "Votre projet est prêt à être envoyé à la communauté. Le backend pourra être branché à cette interface ensuite.";
        return Task.CompletedTask;
    }

    private sealed class ProjectSubmissionModel
    {
        [Required(ErrorMessage = "Le titre du projet est obligatoire.")]
        [StringLength(120, MinimumLength = 3, ErrorMessage = "Le titre doit contenir entre 3 et 120 caractères.")]
        public string Title { get; set; } = string.Empty;

        [Required(ErrorMessage = "La description du projet est obligatoire.")]
        [StringLength(1000, MinimumLength = 20, ErrorMessage = "La description doit contenir au moins 20 caractères.")]
        public string Description { get; set; } = string.Empty;

        [Required(ErrorMessage = "L'URL du dépôt est obligatoire.")]
        [Url(ErrorMessage = "Veuillez saisir une URL GitHub valide.")]
        public string RepositoryUrl { get; set; } = string.Empty;
    }
}
