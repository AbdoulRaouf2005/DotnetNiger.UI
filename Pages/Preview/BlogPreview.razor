@page "/preview/blog"
@using DotnetNiger.UI.Models.Responses
@inject PreviewStateService PreviewState
@inject NavigationManager Navigation

<PageTitle>Aperçu - @(post?.Title ?? "Blog") - .NET Niger</PageTitle>

@if (post is null)
{
    <div class="flex flex-col items-center justify-center py-20 text-center">
        <i class="fa-solid fa-eye-slash text-4xl text-gray-300 mb-4"></i>
        <h1 class="text-2xl font-bold text-gray-900">Aucun aperçu disponible</h1>
        <p class="mt-2 text-sm text-gray-500">Veuillez d'abord remplir le formulaire de création.</p>
        <button @onclick="GoBack" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-secondary px-6 py-3 text-sm font-semibold text-white transition hover:brightness-110">
            <i class="fas fa-arrow-left"></i>
            Retour au formulaire
        </button>
    </div>
}
else
{
    <section class="bg-section-alt px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
        <div class="mx-auto w-full max-w-6xl">
            <div class="mb-6 flex items-center justify-between">
                <button @onclick="GoBack" class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-black/5 transition hover:bg-gray-50">
                    <i class="fas fa-arrow-left text-sm"></i>
                    <span>Retour</span>
                </button>
                <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Aperçu</span>
            </div>

            <div class="lg:grid lg:grid-cols-3 lg:gap-6">
                <div class="lg:col-span-2 space-y-6 sm:space-y-7">
                    <div class="flex flex-wrap items-center gap-2 text-[11px] sm:text-[13px] text-gray-500">
                        <div class="flex flex-wrap items-center gap-2">
                            @if (!string.IsNullOrWhiteSpace(post.PostType))
                            {
                                <span class="rounded-full bg-info-bg px-2.5 py-1 text-[9px] sm:text-[10px] font-semibold uppercase tracking-[0.12em] text-info-text">@post.PostType</span>
                            }
                            <span>@post.AuthorName</span>
                            <span>•</span>
                            <span>@post.PublishedAt?.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>

                    <h1 class="text-2xl sm:text-3xl md:text-[2.8rem] font-extrabold leading-[1.1] tracking-[-0.03em] text-gray-900">
                        @post.Title
                    </h1>

                    <div class="flex items-center gap-3">
                        <div class="h-10 w-10 sm:h-11 sm:w-11 overflow-hidden rounded-full bg-info-bg">
                            @if (!string.IsNullOrWhiteSpace(post.AuthorAvatar))
                            {
                                <img src="@post.AuthorAvatar" alt="@post.AuthorName" class="h-full w-full object-cover" />
                            }
                            else
                            {
                                <div class="flex h-full w-full items-center justify-center text-xs sm:text-sm font-bold text-secondary">@GetInitial(post.AuthorName)</div>
                            }
                        </div>
                        <div>
                            <p class="text-sm sm:text-[15px] font-semibold text-gray-900">@post.AuthorName</p>
                            <p class="text-[11px] sm:text-xs text-gray-500">@post.PublishedAt?.ToString("dd MMM yyyy")</p>
                        </div>
                    </div>

                    <hr class="border-gray-200" />

                    <div class="overflow-hidden rounded-3xl bg-[#0b1220] shadow-[0_18px_40px_rgba(15,23,42,0.16)] aspect-video">
                        <img src="@GetCoverImage()" alt="@post.Title" class="h-full w-full object-cover" />
                    </div>

                    <div class="space-y-8 sm:space-y-10 pt-1">
                        <div class="space-y-5 sm:space-y-6 text-sm sm:text-[15px] leading-7 text-gray-600">
                            @if (!string.IsNullOrWhiteSpace(post.Excerpt))
                            {
                                <div class="italic border-l-4 border-accent pl-4 py-2 bg-section-alt text-sm sm:text-base text-gray-700 font-medium">
                                    @post.Excerpt
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(post.Content))
                            {
                                <div class="prose prose-sm max-w-none">
                                    @((MarkupString)post.Content)
                                </div>
                            }
                            else
                            {
                                <p>Contenu de l'article non disponible.</p>
                            }
                        </div>

                        @if (post.Tags?.Any() == true)
                        {
                            <div class="space-y-3 pt-2">
                                <p class="text-[10px] sm:text-[11px] font-semibold uppercase tracking-[0.2em] text-gray-500">ÉTIQUETTES</p>
                                <div class="flex flex-wrap gap-2">
                                    @foreach (var tag in post.Tags)
                                    {
                                        <span class="rounded-full bg-tag-bg px-3 sm:px-4 py-1.5 sm:py-2 text-[10px] sm:text-xs font-semibold text-gray-700 shadow-sm cursor-pointer hover:bg-info-bg transition">
                                            #@tag.Name
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="hidden lg:block lg:col-span-1"></div>
            </div>
        </div>
    </section>
}

@code {
    private PostDto? post;

    protected override void OnInitialized()
    {
        post = PreviewState.BlogPreview;
    }

    private void GoBack()
    {
        var returnUrl = PreviewState.ReturnUrl ?? "/admin/blog/create";
        PreviewState.Clear();
        Navigation.NavigateTo(returnUrl);
    }

    private string GetCoverImage()
    {
        return string.IsNullOrWhiteSpace(post?.CoverImageUrl)
            ? "/Images/ImageBlog.jpg"
            : post.CoverImageUrl;
    }

    private static string GetInitial(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[0].ToString().ToUpperInvariant();
    }
}
