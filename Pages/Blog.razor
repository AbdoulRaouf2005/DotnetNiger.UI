@page "/blog"
@using DotnetNiger.UI.Components
@inject IPostService PostService

<PageTitle>Blog - .NET Niger</PageTitle>

<section class="bg-[#e8e3f6] px-4 py-14 sm:px-6 lg:px-10">
	<div class="mx-auto w-full max-w-6xl">
		<div class="mb-8 text-center">
			<h1 class="text-3xl font-extrabold text-secondary sm:text-5xl">Blog à suivre</h1>
			<p class="mt-3 text-sm text-secondary/80 sm:text-base">Actualité .NET, projets locaux et échanges avec
				des développeurs</p>
			</div>

			<div class="mb-10 flex flex-wrap items-center gap-3 rounded-md bg-white p-3 shadow-sm">
				<button type="button"
					  class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-gray-200 text-gray-500 transition hover:text-secondary"
					  aria-label="Filtrer les contenus du blog">
					<i class="fa-solid fa-sliders text-base"></i>
				</button>

				<label class="relative min-w-[220px] flex-1">
					<span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-gray-500">
						<i class="fa-solid fa-magnifying-glass text-sm"></i>
					</span>
					<input type="search" placeholder="Rechercher un événement..."
						 class="h-10 w-full rounded-md border border-gray-200 bg-white pl-10 pr-3 text-sm text-gray-600 placeholder:text-gray-400 focus:border-secondary focus:outline-none" />
				</label>

				<select
					class="h-10 min-w-[120px] rounded-md border border-gray-200 px-3 text-sm text-gray-600 focus:border-secondary focus:outline-none">
					<option>Rôle</option>
					<option>Étudiant</option>
					<option>Junior</option>
					<option>Senior</option>
				</select>

				<select
					class="h-10 min-w-[120px] rounded-md border border-gray-200 px-3 text-sm text-gray-600 focus:border-secondary focus:outline-none">
					<option>Type</option>
					<option>Article</option>
					<option>Guide</option>
					<option>Projet</option>
				</select>

				<select
					class="h-10 min-w-[120px] rounded-md border border-gray-200 px-3 text-sm text-gray-600 focus:border-secondary focus:outline-none">
					<option>Rôle</option>
					<option>Auteur</option>
					<option>Lecteur</option>
					<option>Mentor</option>
				</select>
			</div>

			<h2 class="mb-8 text-center text-3xl font-extrabold text-secondary sm:text-5xl">Nouveauté .NET</h2>

			<div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
				@foreach (var article in allPosts)
				{
					<BlogCard post="article"/>
				}
				</div>
			</div>
		</section>

		<section class="bg-[#f5f5f7] px-4 py-14 sm:px-6 lg:px-10">
			<div class="mx-auto w-full max-w-6xl">
				<h2 class="mb-10 text-center text-3xl font-extrabold text-secondary sm:text-5xl">Projets Locaux</h2>

				<div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
					@foreach (var project in LocalProjects)
					{
						<article class="rounded-xl bg-white p-4 shadow-sm">
							<div class="space-y-3 rounded-lg border border-[#ece8f8] p-4">
								<div class="h-7 w-7 rounded-md bg-[#f1eff8]"></div>
								<h3 class="text-2xl font-bold text-secondary">@project.Title</h3>
								<p class="text-sm leading-relaxed text-gray-700">@project.Description</p>

								<a href="@project.Link"
								   class="inline-flex h-9 min-w-[110px] items-center justify-center rounded-md bg-secondary px-4 text-sm font-semibold text-white transition hover:brightness-110">Accéder</a>
							</div>
						</article>
					}
				</div>
			</div>
		</section>

		<section class="bg-[#e8e3f6] px-4 py-14 sm:px-6 lg:px-10">
			<div class="mx-auto w-full max-w-6xl">
				<h2 class="mb-10 text-center text-3xl font-extrabold text-secondary sm:text-5xl">Interviews de Développeurs
				</h2>

				<div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
					@foreach (var interview in Interviews)
					{
						<article class="overflow-hidden rounded-xl bg-white shadow-sm">
							<div class="h-36 bg-secondary"></div>
							<div class="space-y-4 p-5">
								<h3 class="text-xl font-bold text-secondary">@interview.Title</h3>
								<p class="text-sm leading-relaxed text-gray-700">@interview.Description</p>

								<a href="@interview.Link"
									   class="inline-flex h-10 w-full items-center justify-center rounded-md bg-secondary text-sm font-semibold text-white transition hover:brightness-110">Lire
									l'article</a>
								</div>
							</article>
						}
					</div>
				</div>
			</section>

<Footer />

