@page "/blog/{Id}"
@using DotnetNiger.UI.Models.Responses
@using DotnetNiger.UI.Services.Contracts
@using DotnetNiger.UI.Components
@inject IPostService PostService
@inject ICommentService CommentService
@inject ILocalStorageService LocalStorage

@inject NavigationManager NavManager

<PageTitle>@(post?.Title ?? "Blog") - .NET Niger</PageTitle>

@if (post is not null)
{
	<HeadContent>
		<meta property="og:title" content="@post.Title" />
		<meta property="og:description" content="@post.Excerpt" />
		<meta property="og:image" content="@GetAbsoluteUrl(GetCoverImage())" />
		<meta property="og:url" content="@GetAbsoluteUrl(NavManager.Uri)" />
		<meta property="og:type" content="article" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="@post.Title" />
		<meta name="twitter:description" content="@post.Excerpt" />
		<meta name="twitter:image" content="@GetAbsoluteUrl(GetCoverImage())" />
	</HeadContent>
}

<section class="bg-section-alt px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
	<div class="mx-auto w-full max-w-6xl">
		@if (isLoading)
		{
			<div class="lg:grid lg:grid-cols-3 lg:gap-6">
				<div class="lg:col-span-2 space-y-6 sm:space-y-7">
					<div class="flex flex-wrap items-center gap-2">
						<Skeleton Type="SkeletonType.Badge" Width="100px" />
						<Skeleton Type="SkeletonType.Text" Lines="1" Class="w-32" />
					</div>
					<div class="space-y-3">
						<Skeleton Type="SkeletonType.Title" Class="w-full" />
						<Skeleton Type="SkeletonType.Title" Class="w-3/4" />
					</div>
					<div class="flex items-center gap-3">
						<Skeleton Type="SkeletonType.Avatar" Size="44px" Class="h-11 w-11" />
						<div class="space-y-1">
							<Skeleton Type="SkeletonType.Text" Lines="1" Class="w-40" />
							<Skeleton Type="SkeletonType.Text" Lines="1" Class="w-32" />
						</div>
					</div>
					<Skeleton Type="SkeletonType.Custom" Class="h-56 sm:h-[330px] w-full rounded-3xl" />
					<div class="space-y-3">
						<Skeleton Type="SkeletonType.Text" Lines="8" />
					</div>
				</div>
				<div class="hidden lg:block lg:col-span-1 space-y-4">
					<div class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
						<Skeleton Type="SkeletonType.Title" Class="w-24" />
						<Skeleton Type="SkeletonType.Text" Lines="3" Class="mt-2" />
					</div>
					<div class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
						<Skeleton Type="SkeletonType.Badge" Width="80px" />
						<Skeleton Type="SkeletonType.Title" Class="w-full mt-2" />
						<div class="mt-4 space-y-3">
							@for (int i = 0; i < 3; i++)
							{
								<div class="flex gap-3">
									<Skeleton Type="SkeletonType.Custom" Class="w-20 h-14 rounded-lg" />
									<div class="flex-1 space-y-2">
										<Skeleton Type="SkeletonType.Text" Lines="2" />
									</div>
								</div>
							}
						</div>
					</div>
				</div>
			</div>
		}
		else if (post is null)
		{
			<div class="py-20 text-center">
				<h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900">Article non trouvé</h1>
				<p class="mt-3 text-sm sm:text-base text-gray-600">L'article demandé n'existe pas.</p>
			</div>
		}
		else
		{
			<div class="lg:grid lg:grid-cols-3 lg:gap-6">
				@* --- Bloc 1 : Contenu principal --- *@
				<div class="lg:col-span-2 space-y-6 sm:space-y-7">
					<div class="flex flex-wrap items-center justify-between gap-2 text-[11px] sm:text-[13px] text-gray-500">
						<div class="flex flex-wrap items-center gap-2">
							@if (post.Categories?.Any() == true)
							{
								@foreach (var category in post.Categories.Take(1))
								{
									<span class="rounded-full bg-info-bg px-2.5 py-1 text-[9px] sm:text-[10px] font-semibold uppercase tracking-[0.12em] text-info-text">@category.Name</span>
								}
							}
							<span>@post.AuthorName</span>
							<span>•</span>
							<span>@post.PublishedAt?.ToString("dd MMM yyyy")</span>
							@if (post.ViewCount > 0)
							{
								<span>•</span>
								<span><i class="fa-solid fa-eye text-[10px] mr-1"></i>@post.ViewCount vues</span>
							}
						</div>
						<button type="button"
								class="lg:hidden text-gray-400 hover:text-gray-600 transition"
								aria-label="Partager" aria-expanded="@IsShared"
								aria-controls="mobile-share-panel" @onclick="ToggleSharePanel">
							<i class="fa-solid fa-share-nodes text-sm"></i>
						</button>
					</div>

					<h1 class="text-2xl sm:text-3xl md:text-[2.8rem] font-extrabold leading-[1.1] tracking-[-0.03em] text-gray-900">
						@post.Title
					</h1>

					<div class="flex items-center gap-3">
						<div class="h-10 w-10 sm:h-11 sm:w-11 overflow-hidden rounded-full bg-info-bg">
							@if (!string.IsNullOrWhiteSpace(post.AuthorAvatar))
							{
								<img src="@post.AuthorAvatar" alt="@post.AuthorName" class="h-full w-full object-cover" />
							}
							else
							{
								<div class="flex h-full w-full items-center justify-center text-xs sm:text-sm font-bold text-secondary">@GetInitial(post.AuthorName)</div>
							}
						</div>
						<div>
							<p class="text-sm sm:text-[15px] font-semibold text-gray-900">@post.AuthorName</p>
							<p class="text-[11px] sm:text-xs text-gray-500">Architecte Cloud Senior • @post.PublishedAt?.ToString("dd MMM yyyy")</p>
						</div>
					</div>

					<hr class="border-gray-200" />

					<div class="overflow-hidden rounded-md bg-[#0b1220] shadow-[0_18px_40px_rgba(15,23,42,0.16)] aspect-video">
						<img src="@GetCoverImage()" alt="@post.Title" class="h-full w-full object-cover" />
					</div>

					<div class="space-y-8 sm:space-y-10 pt-1">
						<div class="space-y-5 sm:space-y-6 text-sm sm:text-[15px] leading-7 text-gray-600">
							@if (!string.IsNullOrWhiteSpace(post.Content))
							{
								<div class="prose prose-sm max-w-none break-words">
									@((MarkupString)post.Content)
								</div>
							}
							else
							{
								<p>Contenu de l'article non disponible.</p>
							}
						</div>

						<div class="space-y-3 pt-2">
							@if (post.Tags?.Any() == true)
							{
								<p class="text-[10px] sm:text-[11px] font-semibold uppercase tracking-[0.2em] text-gray-500">ÉTIQUETTES</p>
								<div class="flex flex-wrap gap-2">
									@foreach (var tag in post.Tags)
									{
										<span class="rounded-full bg-tag-bg px-3 sm:px-4 py-1.5 sm:py-2 text-[10px] sm:text-xs font-semibold text-gray-700 shadow-sm cursor-pointer hover:bg-info-bg transition">
											#@tag.Name
										</span>
									}
								</div>
							}
						</div>

						<div class="rounded-xl bg-white border-t p-4 sm:p-6 border-gray-200">
							<div class="flex items-center justify-between">
								<h2 class="text-xl sm:text-2xl font-semibold text-gray-900">Commentaires & Feedback</h2>
								@if (comments.Any())
								{
									<span class="text-xs sm:text-sm text-gray-500">@comments.Count commentaire@(comments.Count > 1 ? "s" : "")</span>
								}
							</div>

							<div class="mt-5 sm:mt-6">
								<CommentForm
									PostId="@post.Id.ToString()"
									OnCommentAdded="RefreshComments" />
							</div>

							@if (isLoadingComments)
							{
								<div class="mt-6 sm:mt-8 space-y-4">
									@for (int i = 0; i < 3; i++)
									{
										<div class="flex gap-3 rounded-lg border border-gray-100 bg-white p-4">
											<Skeleton Type="SkeletonType.Avatar" Size="40px" Class="h-10 w-10" />
											<div class="flex-1 space-y-2">
												<div class="flex items-center gap-2">
													<Skeleton Type="SkeletonType.Text" Lines="1" Class="w-32" />
													<Skeleton Type="SkeletonType.Text" Lines="1" Class="w-20" />
												</div>
												<Skeleton Type="SkeletonType.Text" Lines="3" />
												<Skeleton Type="SkeletonType.Button" Width="80px" Class="h-8" />
											</div>
										</div>
									}
								</div>
							}
							else if (comments.Any())
							{
								<div class="mt-6 sm:mt-8">
									<CommentThread
										Comments="comments"
										OnReplySubmitted="RefreshComments"
										OnCommentUpdated="RefreshComments"
										OnCommentDeleted="RefreshComments" />
								</div>
							}
							else
							{
								<div class="mt-6 sm:mt-8 rounded-lg border border-dashed border-gray-300 bg-gray-50 p-6 sm:p-8 text-center">
									<i class="fa-solid fa-comments text-2xl sm:text-3xl text-gray-300 mb-3 sm:mb-4 block"></i>
									<p class="text-xs sm:text-sm text-gray-500">Aucun commentaire pour le moment. Soyez le premier à commenter !</p>
								</div>
							}
						</div>
					</div>
				</div>

				@* --- Articles similaires (mobile) --- *@
				@if (RelatedPosts.Any())
				{
					<div class="lg:hidden">
						<aside class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
							<p class="text-[10px] sm:text-sm font-semibold uppercase tracking-[0.18em] text-gray-400">
								Similaires
							</p>
							<h2 class="mt-1 text-lg sm:text-xl font-bold text-gray-800">
								Articles similaires
							</h2>
							<div class="mt-4 space-y-4">
								@foreach (var article in RelatedPosts)
								{
									<a href="/blog/@(article.Slug ?? article.Id.ToString())" class="flex gap-3 group">
										<div class="w-20 h-14 flex-shrink-0 rounded-lg overflow-hidden bg-gray-100">
											@if (!string.IsNullOrWhiteSpace(article.CoverImageUrl))
											{
												<img src="@article.CoverImageUrl" alt="@article.Title" class="h-full w-full object-cover" />
											}
											else
											{
												<div class="flex h-full w-full items-center justify-center text-gray-400">
													<i class="fa-solid fa-newspaper text-sm"></i>
												</div>
											}
										</div>
										<div class="min-w-0">
											<p class="text-sm font-semibold text-gray-800 group-hover:text-secondary transition line-clamp-2">
												@article.Title
											</p>
											<p class="mt-1 text-xs text-gray-500">
												@article.PublishedAt?.ToString("dd MMM yyyy")
											</p>
										</div>
									</a>
								}
							</div>
						</aside>
					</div>
				}

				@* --- Bloc 2 : Sidebar (desktop seulement) --- *@
				<div class="hidden lg:block lg:col-span-1 lg:sticky lg:top-8 lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto space-y-4">
					@* --- Partage --- *@
					<aside class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-[10px] sm:text-sm font-semibold uppercase tracking-[0.18em] text-gray-400">
									Partage
								</p>
								<h2 class="mt-1 text-lg sm:text-xl font-bold text-gray-800">
									Partager cet article
								</h2>
								<p class="mt-2 text-xs sm:text-sm leading-relaxed text-gray-500">
									Diffusez cet article sur vos réseaux ou copiez le lien direct.
								</p>
							</div>
							<div class="flex h-11 w-11 items-center justify-center rounded-lg bg-indigo-50 text-secondary">
								<i class="fa-solid fa-share-nodes"></i>
							</div>
						</div>
						<ShareButtons Title="@post.Title"
									  Url="@GetAbsoluteUrl(NavManager.Uri)"
									  Description="@post.Excerpt" />
					</aside>

					@* --- Articles similaires --- *@
					@if (RelatedPosts.Any())
					{
						<aside class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
							<p class="text-[10px] sm:text-sm font-semibold uppercase tracking-[0.18em] text-gray-400">
								Similaires
							</p>
							<h2 class="mt-1 text-lg sm:text-xl font-bold text-gray-800">
								Articles similaires
							</h2>
							<div class="mt-4 space-y-4">
								@foreach (var article in RelatedPosts)
								{
									<a href="/blog/@(article.Slug ?? article.Id.ToString())" class="flex gap-3 group">
										<div class="w-20 h-14 flex-shrink-0 rounded-lg overflow-hidden bg-gray-100">
											@if (!string.IsNullOrWhiteSpace(article.CoverImageUrl))
											{
												<img src="@article.CoverImageUrl" alt="@article.Title" class="h-full w-full object-cover" />
											}
											else
											{
												<div class="flex h-full w-full items-center justify-center text-gray-400">
													<i class="fa-solid fa-newspaper text-sm"></i>
												</div>
											}
										</div>
										<div class="min-w-0">
											<p class="text-sm font-semibold text-gray-800 group-hover:text-secondary transition line-clamp-2">
												@article.Title
											</p>
											<p class="mt-1 text-xs text-gray-500">
												@article.PublishedAt?.ToString("dd MMM yyyy")
											</p>
										</div>
									</a>
								}
							</div>
						</aside>
					}
				</div>
			</div>

			@* --- Mobile share overlay --- *@
			<div class="fixed inset-0 z-10 bg-black/50 sm:hidden @(IsShared ? "" : "hidden")"
				 @onclick="ToggleSharePanel"></div>
			<aside id="mobile-share-panel"
				   class="overflow-hidden z-20 w-[91%] fixed top-20 rounded-lg border border-gray-100 bg-white shadow-sm transition-all duration-300 lg:hidden @(IsShared ? "max-h-80 p-4 opacity-100 pointer-events-auto translate-x-0" : "max-h-0 p-0 opacity-0 pointer-events-none translate-x-full")">
				<div class="flex items-center justify-between gap-3">
					<div>
						<p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-gray-400">
							Partage
						</p>
						<h2 class="mt-1 text-base sm:text-lg font-bold text-gray-800">
							Partager cet article
						</h2>
					</div>
					<button type="button"
							class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-gray-100 text-gray-500 transition hover:bg-gray-200"
							aria-label="Fermer le partage" @onclick="ToggleSharePanel">
						<i class="fa-solid fa-xmark"></i>
					</button>
				</div>
				<ShareButtons Title="@post.Title"
							  Url="@GetAbsoluteUrl(NavManager.Uri)"
							  Description="@post.Excerpt" />
			</aside>
		}
	</div>
</section>

@code {
	[Parameter]
	public string? Id { get; set; }

	private PostDto? post;
	private List<CommentResponse> comments = new();
	private bool isLoading = true;
	private bool isLoadingComments = true;
	private bool IsShared;
	private List<PostDto> RelatedPosts { get; set; } = new();

	protected override async Task OnInitializedAsync()
	{
		if (string.IsNullOrWhiteSpace(Id))
		{
			isLoading = false;
			return;
		}

		if (Guid.TryParse(Id, out var postId))
		{
			post = await PostService.GetPostByIdAsync(postId);
		}
		else
		{
			post = await PostService.GetPostBySlugAsync(Id);
		}

		if (post is not null)
		{
			bool alreadyViewed = await LocalStorage.GetItemAsync<bool>($"viewed_post_{post.Id}");
			if (!alreadyViewed)
			{
				post.ViewCount++;
				_ = PostService.IncrementViewCountAsync(post.Id);
				await LocalStorage.SetItemAsync($"viewed_post_{post.Id}", true);
			}
		}

		isLoading = false;

		// Load comments for this post
		if (post?.Id != Guid.Empty)
		{
			await RefreshComments();
		}

		// Load related posts (same tags)
		if (post is not null)
		{
			var tagNames = post.Tags.Select(t => t.Name).ToHashSet();
			var allPosts = await PostService.GetAllPostsAsync();
			RelatedPosts = allPosts
				.Where(p => p.Id != post.Id && p.PublishedAt.HasValue)
				.Select(p => new
				{
					Post = p,
					MatchCount = p.Tags.Count(t => tagNames.Contains(t.Name))
				})
				.Where(x => x.MatchCount > 0)
				.OrderByDescending(x => x.MatchCount)
				.ThenByDescending(x => x.Post.PublishedAt)
				.Take(3)
				.Select(x => x.Post)
				.ToList();
		}
	}

	private void ToggleSharePanel()
	{
		IsShared = !IsShared;
	}

	private async Task RefreshComments()
	{
		if (post?.Id == Guid.Empty)
			return;

		isLoadingComments = true;
		comments = await CommentService.GetCommentsByPostIdAsync(post!.Id);
		isLoadingComments = false;
	}

	private string GetCoverImage()
	{
		return string.IsNullOrWhiteSpace(post?.CoverImageUrl)
			? "/Images/ImageBlog.jpg"
			: post.CoverImageUrl;
	}

	private static string GetInitial(string? value)
	{
		return string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[0].ToString().ToUpperInvariant();
	}

	private string GetAbsoluteUrl(string relativeUrl)
	{
		var baseUri = NavManager.BaseUri.TrimEnd('/');
		var url = relativeUrl.TrimStart('/');
		return $"{baseUri}/{url}";
	}
}
