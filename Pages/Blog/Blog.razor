@page "/blog"
@using DotnetNiger.UI.Components
@using DotnetNiger.UI.Components.Admin.Cards
@inject IPostService PostService

<PageTitle>Blog - .NET Niger</PageTitle>

<section class="bg-[#e8e3f6] px-4 py-8 sm:py-12 md:py-14 lg:px-10">
	<div class="mx-auto w-full max-w-6xl">
		<div class="mb-6 sm:mb-8 text-center">
			<h1 class="text-lg sm:text-xl md:text-2xl lg:text-3xl xl:text-4xl font-extrabold text-secondary">DotnetBlog</h1>
			<p class="mt-2 sm:mt-3 text-xs sm:text-sm md:text-base leading-6 sm:leading-7 text-secondary/80">un espace ouvert à tous les acteurs du numérique : technologies, actualités, projets, événements, partage d'expérience.</p>
		</div>

			<div class="mb-8 sm:mb-10 flex flex-wrap items-center gap-2 sm:gap-3 md:gap-4 rounded-md bg-white p-3 sm:p-4 shadow-sm">
				<button type="button"
					class="inline-flex h-10 sm:h-12 w-10 sm:w-12 items-center justify-center rounded-md border border-gray-100 bg-white text-gray-500 shadow-sm flex-shrink-0"
					aria-label="Filtrer les contenus du blog">
					<i class="fa-solid fa-sliders text-base sm:text-lg"></i>
				</button>

				<label class="relative flex-1 w-full min-w-[220px]">
					<span class="pointer-events-none absolute inset-y-0 left-3 sm:left-4 flex items-center text-gray-400">
						<i class="fa-solid fa-magnifying-glass text-xs sm:text-sm"></i>
					</span>
					<input type="search" placeholder="Rechercher un article..."
						class="h-10 sm:h-12 w-full rounded-md border border-gray-100 bg-white pl-10 sm:pl-12 pr-3 sm:pr-4 text-xs sm:text-sm text-gray-600 placeholder:text-gray-400 focus:border-secondary focus:outline-none" />
				</label>

				<select
					class="h-10 sm:h-10 min-w-[170px] sm:min-w-[140px] rounded-lg border border-gray-100 bg-white px-3 sm:px-4 text-xs sm:text-sm text-gray-700 shadow-sm focus:border-secondary focus:outline-none flex-shrink-0">
					<option>Catégorie</option>
					<option>Auteur</option>
					<option>Lecteur</option>
					<option>Mentor</option>
				</select>
			</div>

			<h2 class="mb-6 sm:mb-8 text-center text-base sm:text-lg md:text-2xl lg:text-3xl xl:text-4xl font-extrabold text-secondary">Nouveauté .NET</h2>

			<div class="grid grid-cols-1 gap-4 sm:gap-6 md:grid-cols-2 xl:grid-cols-3">
				@if (IsLoading)
				{
					<p class="col-span-full text-center text-xs sm:text-sm md:text-base text-secondary/70">Chargement des articles...</p>
				}
				else if (!string.IsNullOrWhiteSpace(LoadError))
				{
					<p class="col-span-full text-center text-xs sm:text-sm md:text-base text-red-600">@LoadError</p>
				}
				else if (pagedPosts.Count == 0)
				{
					<p class="col-span-full text-center text-xs sm:text-sm md:text-base text-secondary/70">Aucun article publié pour le moment.</p>
				}
				else
				{
					@foreach (var article in pagedPosts)
					{
						<BlogCard post="@article" />
					}
				}
				
				</div>
				@if (allPosts is not null && allPosts.Count > 0)
				{
					<div>
						<Paginated @bind-CurrentPage="currentPage" TotalPages="@totalPages" />
					</div>
				}
			</div>
		</section>

@code {
	private List<PostDto>? allPosts;
	private int currentPage = 1;
	private bool IsLoading { get; set; } = true;
	private string? LoadError { get; set; }

	private int pageSize = 7;
	protected override async Task OnInitializedAsync()
	{
		IsLoading = true;
		try
		{
			allPosts = await PostService.GetPublishedPostsAsync();
			currentPage = 1;
			await JS.InvokeVoidAsync("console.log", $"Blog: loaded {allPosts?.Count ?? 0} posts");
		}
		catch (Exception ex)
		{
			LoadError = "Impossible de charger les articles du blog.";
			await JS.InvokeVoidAsync("console.error", ex.ToString());
		}
		finally
		{
			IsLoading = false;
		}
	}

	private int totalPages => Math.Max(1, (int)Math.Ceiling((double)(allPosts?.Count ?? 0) / pageSize));

	private List<PostDto> pagedPosts => (allPosts ?? new List<PostDto>())
		.Skip((SafeCurrentPage - 1) * pageSize)
		.Take(pageSize)
		.ToList();

	private int SafeCurrentPage => Math.Clamp(currentPage, 1, totalPages);

	[Inject] private IJSRuntime JS { get; set; } = default!;
}
