@page "/evenements/{Slug}"
@page "/evenements/{Id:guid}"
@inject IEventService EventService
@inject ICommentService CommentService
@using System.Globalization
@using DotnetNiger.UI.Models.Requests;
@using DotnetNiger.UI.Models.Responses;
@using DotnetNiger.UI.Components;

<PageTitle>@(CurrentEvent is null ? "Détails de l'événement - .NET Niger" : $"{CurrentEvent.Title} - .NET Niger")
</PageTitle>

<section class="min-h-screen bg-[#ececef] px-4 py-10 sm:px-6 lg:px-10">
	<div class="mx-auto w-full max-w-6xl space-y-4">
		@if (IsLoading)
		{
			<div class="rounded-xl bg-white p-6 text-sm text-gray-600 shadow-sm">Chargement de l'événement...</div>
		}
		else if (!string.IsNullOrWhiteSpace(LoadError))
		{
			<div class="rounded-xl bg-red-50 p-6 text-sm text-red-600 shadow-sm">@LoadError</div>
			<a href="/evenements" class="inline-flex text-sm font-semibold text-secondary hover:underline">Retour aux
				événements</a>
			}
		else if (CurrentEvent is not null)
			{
				<article class="overflow-hidden rounded-xl bg-white shadow-sm">
					<div class="h-64 bg-secondary bg-cover bg-center sm:h-80"
					     style="@BuildCoverStyle(CurrentEvent.CoverImageUrl)"></div>
					<div class="space-y-5 p-6 sm:p-8">
						<span
							class="inline-flex items-center gap-1 rounded-md bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
							<i class="fa-solid fa-satellite-dish text-[10px]"></i>
							@GetEventTypeLabel(CurrentEvent.EventType)
						</span>

						<h1 class="text-xl md:text-3xl font-extrabold text-gray-700 sm:text-5xl">@CurrentEvent.Title</h1>

						<div class="flex flex-wrap items-center gap-4 text-sm text-gray-600">
							<span class="inline-flex items-center gap-2">
								<i class="fa-regular fa-calendar text-secondary"></i>
								@CurrentEvent.StartDate.ToString("dd MMMM yyyy HH:mm", FrCulture)
							</span>
							<span class="inline-flex items-center gap-2">
								<i class="fa-solid fa-location-dot text-secondary"></i>
								@CurrentEvent.Location
							</span>
						</div>

						<div class="flex flex-wrap items-center gap-4 pt-1">
							<a href="#inscription"
								   class="inline-flex h-11 items-center justify-center rounded-lg bg-secondary px-6 text-sm font-semibold text-white transition hover:brightness-110">Réserver
								ma place</a>
								<div>
									<p class="text-sm font-semibold text-gray-700">@CurrentEvent.RegisteredCount
										inscrits</p>
										<p class="text-xs text-gray-500">Capacité : @CurrentEvent.Capacity</p>
										<button type="button"
											  class="mt-3 inline-flex h-11 items-center gap-2 rounded-lg bg-gray-900 px-4 text-sm font-semibold text-white transition hover:bg-gray-800 lg:hidden"
											  aria-label="Partager l'événement" aria-expanded="@IsShared"
											  aria-controls="mobile-share-panel" @onclick="ToggleSharePanel">
											<i class="fa-solid fa-share-nodes text-[13px]"></i>
											Partager
										</button>
									</div>
								</div>
							</div>
						</article>

						<div class="grid grid-cols-1 gap-4 lg:grid-cols-3 relative">
							<article class="rounded-xl bg-white p-6 shadow-sm lg:col-span-2">
								<h2 class="text-xl md:text-3xl font-bold text-gray-700">À propos de l'événement</h2>
								<p class="mt-4 text-sm leading-relaxed text-gray-600 sm:text-base">
									@CurrentEvent.Description
								</p>
							</article>

							@* Format desktop *@

							<aside
								class="hidden rounded-2xl border border-gray-100 bg-white p-5 shadow-sm lg:sticky lg:top-0 lg:block">
								<div class="flex items-start justify-between gap-4">
									<div>
										<p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-400">Partage
										</p>
										<h2 class="mt-1 text-xl font-bold text-gray-800">Partager cet événement</h2>
										<p class="mt-2 text-sm leading-relaxed text-gray-500">Diffusez l'événement sur vos
											réseaux ou copiez le lien direct.</p>
										</div>
										<div
											class="flex h-11 w-11 items-center justify-center rounded-md bg-indigo-50 text-secondary">
											<i class="fa-solid fa-share-nodes"></i>
										</div>
									</div>

									<div class="mt-5 grid grid-cols-3 gap-3">
										<button type="button"
											  class="inline-flex h-11 items-center justify-center gap-2 rounded-xl border border-gray-200 bg-gray-50 text-sm font-semibold text-gray-700 transition hover:bg-gray-100"
											  aria-label="Partager sur X">
											<i class="fa-brands fa-x-twitter"></i>
											X
										</button>
										<button type="button"
											  class="inline-flex h-11 items-center justify-center gap-2 rounded-xl border border-gray-200 bg-gray-50 text-sm font-semibold text-gray-700 transition hover:bg-gray-100"
											  aria-label="Partager sur Discord">
											<i class="fa-brands fa-discord"></i>
											Discord
										</button>
										<button type="button"
											  class="inline-flex h-11 items-center justify-center gap-2 rounded-xl border border-gray-200 bg-gray-50 text-sm font-semibold text-gray-700 transition hover:bg-gray-100"
											  aria-label="Partager sur LinkedIn">
											<i class="fa-brands fa-linkedin-in"></i>
											LinkedIn
										</button>
									</div>

									<a href="@CurrentPageUrl"
										   class="mt-4 inline-flex h-11 w-full items-center justify-center gap-2 rounded-xl bg-indigo-50 text-sm font-semibold text-secondary transition hover:bg-indigo-100">
										<i class="fa-solid fa-link"></i>
										Copier le lien
									</a>
								</aside>


								<aside id="mobile-share-panel"
									 class="overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition-all duration-300 lg:hidden @(IsShared ? "max-h-80 p-4 opacity-100" : "max-h-0 p-0 opacity-0") @(IsShared ? "pointer-events-auto" : "pointer-events-none")">
									<div class="flex items-center justify-between gap-3">
										<div>
											<p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-400">Partage
											</p>
											<h2 class="mt-1 text-lg font-bold text-gray-800">Partager cet événement</h2>
										</div>
										<button type="button"
											  class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-gray-100 text-gray-500 transition hover:bg-gray-200"
											  aria-label="Fermer le partage" @onclick="ToggleSharePanel">
											<i class="fa-solid fa-xmark"></i>
										</button>
									</div>

									<div class="mt-4 grid grid-cols-3 gap-2">
										<button type="button"
											  class="inline-flex h-10 items-center justify-center rounded-xl bg-gray-100 text-sm font-semibold text-gray-700 transition hover:bg-gray-200"
											  aria-label="Partager sur X">
											<i class="fa-brands fa-x-twitter"></i>
										</button>
										<button type="button"
											  class="inline-flex h-10 items-center justify-center rounded-xl bg-gray-100 text-sm font-semibold text-gray-700 transition hover:bg-gray-200"
											  aria-label="Partager sur Discord">
											<i class="fa-brands fa-discord"></i>
										</button>
										<button type="button"
											  class="inline-flex h-10 items-center justify-center rounded-xl bg-gray-100 text-sm font-semibold text-gray-700 transition hover:bg-gray-200"
											  aria-label="Partager sur LinkedIn">
											<i class="fa-brands fa-linkedin-in"></i>
										</button>
									</div>

									<a href="@CurrentPageUrl"
										   class="mt-3 inline-flex h-10 w-full items-center justify-center gap-2 rounded-xl bg-indigo-50 text-sm font-semibold text-secondary transition hover:bg-indigo-100">
										<i class="fa-solid fa-link"></i>
										Copier le lien
									</a>
								</aside>
							</div>

							<div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
								<article class="rounded-xl bg-white p-6 shadow-sm lg:col-span-2">
									<div class="text-center">
										<h2 class="text-xl md:text-3xl font-bold text-gray-700">Intervenants</h2>
										<p class="mt-2 text-sm text-gray-500 sm:text-base">Des experts passionnés partageant leur
											savoir.</p>
										</div>

										<div class="mt-7 grid grid-cols-2 gap-5 sm:grid-cols-4">
											@foreach (var speaker in Speakers)
											{
												<div class="text-center">
													<div
														class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-secondary to-indigo-700 text-lg font-bold text-white ring-2 ring-indigo-200">
														@speaker.Initials
													</div>
													<h3 class="mt-3 text-sm font-semibold text-gray-700">@speaker.Name</h3>
													<p class="text-xs text-gray-500">@speaker.Role</p>
												</div>
											}
										</div>
									</article>
								</div>

								<div class="grid grid-cols-1 gap-4 lg:grid-cols-3" id="inscription">
									<article class="rounded-xl bg-white p-6 shadow-sm lg:col-span-2">
										<h2 class="text-xl md:text-3xl font-bold text-gray-700">Commentaires &amp; Feedback</h2>

										@if (CurrentEvent is not null)
										{
											<div class="mt-5">
												<CommentForm EventId="CurrentEvent.Id" OnCommentAdded="RefreshComments" />
											</div>

											<div class="mt-7">
												@if (EventComments.Count == 0)
												{
													<p class="text-sm text-gray-500">Aucun commentaire pour le moment. Soyez le premier à
														commenter !</p>
													}
											else
													{
														<CommentThread Comments="EventComments" OnReplySubmitted="RefreshComments"
																   OnCommentUpdated="RefreshComments" OnCommentDeleted="RefreshComments" />
													}
												</div>

												<a href="#" class="mt-8 inline-flex text-sm font-semibold text-secondary hover:underline">Voir
													plus de commentaires</a>
												}
											</article>
										</div>
									}
								</div>
							</section>

<Footer />

@code {
	[Parameter] public string? Slug { get; set; }
	[Parameter] public Guid? Id { get; set; }

	private static readonly CultureInfo FrCulture = CultureInfo.GetCultureInfo("fr-FR");
	private EventDto? CurrentEvent { get; set; }
	private List<CommentResponse> EventComments { get; set; } = new();
	private bool IsLoading { get; set; }
	private bool IsShared { get; set; } = false;
	private string? LoadError { get; set; }
	private string CurrentPageUrl { get; set; } = "/evenements";

	void ToggleSharePanel()
	{
		IsShared = !IsShared;
	}

	private async Task RefreshComments()
	{
		if (CurrentEvent is null)
			return;

		EventComments = await CommentService.GetCommentsByEventIdAsync(CurrentEvent.Id);
	}

	protected override async Task OnParametersSetAsync()
	{
		IsLoading = true;
		LoadError = null;
		CurrentEvent = null;
		EventComments = new();

		try
		{
			if (Id.HasValue)
			{
				CurrentEvent = await EventService.GetEventByIdAsync(Id.Value);
			}
			else if (!string.IsNullOrWhiteSpace(Slug))
			{
				CurrentEvent = await EventService.GetEventBySlugAsync(Slug);
			}

			if (CurrentEvent is null)
			{
				LoadError = "Événement introuvable.";
				return;
			}

			// Charger les commentaires pour cet événement
			EventComments = await CommentService.GetCommentsByEventIdAsync(CurrentEvent.Id);

			CurrentPageUrl = !string.IsNullOrWhiteSpace(CurrentEvent.Slug)
				? $"/evenements/{CurrentEvent.Slug}"
				: $"/evenements/{CurrentEvent.Id}";
		}
		catch
		{
			LoadError = "Impossible de charger cet événement pour le moment.";
		}
		finally
		{
			IsLoading = false;
		}
	}

	private static string BuildCoverStyle(string coverImageUrl)
	{
		if (string.IsNullOrWhiteSpace(coverImageUrl))
		{
			return string.Empty;
		}

		return $"background-image: linear-gradient(rgba(46, 26, 122, 0.45), rgba(46, 26, 122, 0.45)), url('{coverImageUrl}');";
	}

	private static string GetEventTypeLabel(string eventType)
	{
		return eventType.ToLowerInvariant() switch
		{
			"online" => "En ligne",
			"physical" => "Présentiel",
			"hybrid" => "Hybride",
			_ => string.IsNullOrWhiteSpace(eventType) ? "Événement" : eventType
		};
	}

	private static readonly IReadOnlyList<SpeakerViewModel> Speakers =
	[
		new("Ahmed Moussa", "Senior .NET Architect", "AM"),
		new("Awa Issa", "Cloud Engineer", "AI"),
		new("Boubacar Adamou", "Tech Lead", "BA"),
		new("Mariam Oumarou", "AI Specialist", "MO")
	];

	private sealed record SpeakerViewModel(string Name, string Role, string Initials);
}
