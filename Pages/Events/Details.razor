@page "/evenements/{Slug}"
@page "/evenements/{Id:guid}"
@inject IEventService EventService
@inject ICommentService CommentService
@inject IUserStateService UserStateService
@inject IToastService ToastService
@inject NavigationManager NavManager
@using System.Globalization
@using DotnetNiger.UI.Models.Requests;
@using DotnetNiger.UI.Models.Responses;
@using DotnetNiger.UI.Components;

<PageTitle>@(CurrentEvent is null ? "Détails de l'événement - .NET Niger" : $"{CurrentEvent.Title} - .NET Niger")</PageTitle>

@if (CurrentEvent is not null)
{
    <HeadContent>
        <meta property="og:title" content="@CurrentEvent.Title" />
        <meta property="og:description" content="@CurrentEvent.Description" />
        <meta property="og:image"
              content="@GetAbsoluteUrl(string.IsNullOrWhiteSpace(CurrentEvent.CoverImageUrl) ? "/Images/Fond1.jpeg" : CurrentEvent.CoverImageUrl)" />
        <meta property="og:url" content="@GetAbsoluteUrl(CurrentPageUrl)" />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="@CurrentEvent.Title" />
        <meta name="twitter:description" content="@CurrentEvent.Description" />
        <meta name="twitter:image"
              content="@GetAbsoluteUrl(string.IsNullOrWhiteSpace(CurrentEvent.CoverImageUrl) ? "/Images/Fond1.jpeg" : CurrentEvent.CoverImageUrl)" />
    </HeadContent>
}

<section class="min-h-screen bg-[#ececef] px-4 py-8 sm:px-6 sm:py-10 lg:px-10">
    <div class="mx-auto w-full max-w-6xl space-y-4">
        @if (IsLoading)
        {
            <div class="lg:grid lg:grid-cols-3 lg:gap-6">
                <div class="lg:col-span-2 space-y-4">
                    <div class="overflow-hidden rounded-lg bg-white shadow-sm">
                        <Skeleton Type="SkeletonType.Image" Class="h-64 sm:h-80 w-full rounded-none" Style="border-radius:0" />
                        <div class="space-y-4 p-4 sm:p-8">
                            <Skeleton Type="SkeletonType.Badge" Width="100px" />
                            <Skeleton Type="SkeletonType.Title" Class="w-3/4" />
                            <div class="flex gap-3">
                                <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-1/3" />
                                <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-1/3" />
                            </div>
                            <Skeleton Type="SkeletonType.Text" Lines="4" />
                            <Skeleton Type="SkeletonType.Button" Width="160px" />
                        </div>
                    </div>
                    <div class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                        <Skeleton Type="SkeletonType.Title" Class="w-1/2" />
                        <Skeleton Type="SkeletonType.Text" Lines="5" Class="mt-3" />
                    </div>
                </div>
                <div class="hidden lg:block lg:col-span-1 space-y-4">
                    <aside class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1 space-y-2">
                                <Skeleton Type="SkeletonType.Badge" Width="60px" />
                                <Skeleton Type="SkeletonType.Title" Class="w-3/4" />
                                <Skeleton Type="SkeletonType.Text" Lines="2" />
                            </div>
                            <Skeleton Type="SkeletonType.Avatar" Size="44px" />
                        </div>
                        <div class="mt-4 space-y-2">
                            <Skeleton Type="SkeletonType.Button" Width="100%" Class="h-9" />
                            <Skeleton Type="SkeletonType.Button" Width="100%" Class="h-9" />
                        </div>
                    </aside>
                    <aside class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                        <Skeleton Type="SkeletonType.Badge" Width="60px" />
                        <Skeleton Type="SkeletonType.Title" Class="w-3/4" />
                        <div class="mt-4 space-y-4">
                            @for (int i = 0; i < 3; i++)
                            {
                                <div class="flex gap-3">
                                    <Skeleton Type="SkeletonType.Image" Class="w-20 h-14 rounded-lg flex-shrink-0" />
                                    <div class="flex-1 space-y-2">
                                        <Skeleton Type="SkeletonType.Text" Lines="2" Class="h-4" />
                                    </div>
                                </div>
                            }
                        </div>
                    </aside>
                </div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(LoadError))
        {
            <div class="rounded-lg bg-red-50 p-4 sm:p-6 text-xs sm:text-sm text-red-600 shadow-sm">
                @LoadError
            </div>
            <a href="/evenements" class="inline-flex text-xs sm:text-sm font-semibold text-secondary hover:underline">
                Retour aux événements
            </a>
        }
        else if (CurrentEvent is not null)
        {
            <div class="lg:grid lg:grid-cols-3 lg:gap-6">
                @* --- Bloc 1 : Contenu principal --- *@
                <div class="lg:col-span-2 space-y-4">
                    @* --- Hero card --- *@
                    <article class="overflow-hidden rounded-lg bg-white shadow-sm">
                        <div class="overflow-hidden rounded-3xl bg-[#0b1220] shadow-[0_18px_40px_rgba(15,23,42,0.16)] mx-4 sm:mx-8 mt-4 sm:mt-8">
                            <img src="@GetEventCoverUrl()" alt="@CurrentEvent.Title" class="h-64 w-full object-cover sm:h-80" />
                        </div>
                        <div class="space-y-4 p-4 sm:space-y-5 sm:p-8">
                            <div class="flex justify-between items-center">
                                <span class="inline-flex items-center gap-1 rounded-lg bg-blue-100 px-2.5 py-1 text-[10px] sm:text-xs font-semibold text-blue-700">
                                    <i class="fa-solid fa-satellite-dish text-[9px] sm:text-[10px]"></i>
                                    @GetEventTypeLabel(CurrentEvent.EventType)
                                </span>
                                <button type="button"
                                        class="items-center rounded-lg bg-white text-black transition hover:bg-gray-800 lg:hidden"
                                        aria-label="Partager l'événement" aria-expanded="@IsShared"
                                        aria-controls="mobile-share-panel" @onclick="ToggleSharePanel">
                                    <i class="fa-solid fa-share-nodes text-[12px] sm:text-[13px]"></i>
                                </button>
                            </div>

                            <h1 class="text-xl sm:text-2xl md:text-3xl font-extrabold leading-tight text-gray-700">
                                @CurrentEvent.Title
                            </h1>

                            <div class="flex flex-wrap items-center gap-3 text-xs sm:text-sm text-gray-600">
                                <span class="inline-flex items-center gap-1.5 sm:gap-2">
                                    <i class="fa-regular fa-calendar text-secondary"></i>
                                    @CurrentEvent.StartDate.ToString("dd MMMM yyyy HH:mm", FrCulture)
                                </span>
                                <span class="inline-flex items-center gap-1.5 sm:gap-2">
                                    <i class="fa-solid fa-location-dot text-secondary"></i>
                                    @CurrentEvent.Location
                                </span>
                            </div>

                            @* Meetup link *@
                            @if (!string.IsNullOrWhiteSpace(CurrentEvent.MeetupLink) && CurrentEvent.EventType is "Online" or "Hybrid")
                            {
                                <a href="@CurrentEvent.MeetupLink" target="_blank" rel="noopener noreferrer"
                                   class="inline-flex items-center gap-2 rounded-lg bg-secondary px-4 py-2 text-xs sm:text-sm font-semibold text-white transition hover:brightness-110">
                                    <i class="fa-solid fa-video"></i>
                                    Rejoindre en @(CurrentEvent.EventType == "Online" ? "ligne" : "visioconférence")
                                </a>
                            }

                            @* Registration *@
                            @if (_isPastEvent)
                            {
                                <div class="flex flex-wrap items-center gap-3 rounded-lg bg-gray-50 px-4 py-3">
                                    <span class="inline-flex items-center gap-1.5 text-xs sm:text-sm text-gray-500">
                                        <i class="fa-regular fa-clock"></i>
                                        é‰vénement passé
                                    </span>
                                    @if (IsRegistered)
                                    {
                                        <span class="inline-flex items-center gap-1.5 text-xs sm:text-sm text-gray-500">
                                            <i class="fa-solid fa-check"></i>
                                            Vous étiez inscrit
                                        </span>
                                    }
                                    <div class="flex items-center gap-2 ml-auto">
                                        <div class="flex -space-x-2">
                                            @{
                                                var pastAvatars = Registrations?.Take(3).ToList() ?? new();
                                            }
                                            @foreach (var reg in pastAvatars)
                                            {
                                                <div class="w-6 h-6 sm:w-7 sm:h-7 rounded-full border-2 border-white flex items-center justify-center text-white text-[8px] sm:text-xs font-bold flex-shrink-0 overflow-hidden @(string.IsNullOrWhiteSpace(reg.AvatarUrl) ? "bg-green-100" : "")">
                                                    @if (!string.IsNullOrWhiteSpace(reg.AvatarUrl))
                                                    {
                                                        <img src="@reg.AvatarUrl" alt="@reg.UserName" class="h-full w-full object-cover" />
                                                    }
                                                    else
                                                    {
                                                        <span class="text-gray-600">
                                                            @(reg.UserName.Length > 0 ? reg.UserName[0].ToString() : "?")
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            @for (int i = pastAvatars.Count; i < 3; i++)
                                            {
                                                <div class="w-6 h-6 sm:w-7 sm:h-7 bg-green-100 rounded-full border-2 border-white flex-shrink-0"></div>
                                            }
                                        </div>
                                        <div>
                                            <p class="text-xs sm:text-sm font-semibold text-gray-700">
                                                @CurrentEvent.RegisteredCount inscrits
                                            </p>
                                            <p class="text-[11px] sm:text-xs text-gray-500">
                                                Capacité : @CurrentEvent.Capacity
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="flex flex-wrap items-center gap-3 pt-1">
                                    @if (IsRegistered)
                                    {
                                        <button type="button" @onclick="HandleCancelRegistration"
                                                disabled="@IsCancelling"
                                                class="inline-flex h-10 sm:h-11 items-center justify-center rounded-lg bg-red-500 px-4 sm:px-6 text-xs sm:text-sm font-semibold text-white transition hover:brightness-110 @(IsCancelling ? "opacity-50 cursor-not-allowed" : "")">
                                            @if (IsCancelling)
                                            {
                                                <i class="fa-solid fa-spinner fa-spin mr-2"></i>
                                            }
                                            Se désinscrire
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" @onclick="HandleRegister"
                                                disabled="@IsRegistering"
                                                class="inline-flex h-10 sm:h-11 items-center justify-center rounded-lg bg-secondary px-4 sm:px-6 text-xs sm:text-sm font-semibold text-white transition hover:brightness-110 @(IsRegistering ? "opacity-50 cursor-not-allowed" : "")">
                                            @if (IsRegistering)
                                            {
                                                <i class="fa-solid fa-spinner fa-spin mr-2"></i>
                                            }
                                            S'inscrire
                                        </button>
                                    }
                                    <div class="flex items-center gap-2">
                                        <div class="flex -space-x-2">
                                            @{
                                                var currentAvatars = Registrations?.Take(3).ToList() ?? new();
                                            }
                                            @foreach (var reg in currentAvatars)
                                            {
                                                <div class="w-6 h-6 sm:w-7 sm:h-7 rounded-full border-2 border-white flex items-center justify-center text-white text-[8px] sm:text-xs font-bold flex-shrink-0 overflow-hidden @(string.IsNullOrWhiteSpace(reg.AvatarUrl) ? "bg-green-100" : "")">
                                                    @if (!string.IsNullOrWhiteSpace(reg.AvatarUrl))
                                                    {
                                                        <img src="@reg.AvatarUrl" alt="@reg.UserName" class="h-full w-full object-cover" />
                                                    }
                                                    else
                                                    {
                                                        <span class="text-gray-600">
                                                            @(reg.UserName.Length > 0 ? reg.UserName[0].ToString() : "?")
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            @for (int i = currentAvatars.Count; i < 3; i++)
                                            {
                                                <div class="w-6 h-6 sm:w-7 sm:h-7 bg-green-100 rounded-full border-2 border-white flex-shrink-0"></div>
                                            }
                                        </div>
                                        <div>
                                            <p class="text-xs sm:text-sm font-semibold text-gray-700">
                                                @CurrentEvent.RegisteredCount inscrits
                                            </p>
                                            <p class="text-[11px] sm:text-xs text-gray-500">
                                                Capacité : @CurrentEvent.Capacity
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </article>

                    @* --- À propos --- *@
                    <article class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                        <h2 class="text-lg sm:text-xl md:text-3xl font-bold text-gray-700">
                            À propos de l'événement
                        </h2>
                        <p class="mt-3 sm:mt-4 text-xs sm:text-sm leading-relaxed text-gray-600 sm:text-base">
                            @CurrentEvent.Description
                        </p>
                    </article>

                    @* --- Intervenants --- *@
                    @if (CurrentEvent.Speakers.Count > 0)
                    {
                        <article class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                            <div class="text-center">
                                <h2 class="text-lg sm:text-xl md:text-3xl font-bold text-gray-700">Intervenants</h2>
                                <p class="mt-2 text-xs sm:text-sm text-gray-500 sm:text-base">
                                    Des experts passionnés partageant leur savoir.
                                </p>
                            </div>
                            <div class="mt-5 sm:mt-7 grid grid-cols-2 gap-3 sm:gap-5 sm:grid-cols-4">
                                @foreach (var speaker in CurrentEvent.Speakers)
                                {
                                    <div class="text-center">
                                        <div class="mx-auto flex h-16 w-16 sm:h-20 sm:w-20 items-center justify-center rounded-full bg-gradient-to-br from-secondary to-indigo-700 text-sm sm:text-lg font-bold text-white ring-2 ring-indigo-200 overflow-hidden">
                                            @if (!string.IsNullOrWhiteSpace(speaker.AvatarUrl))
                                            {
                                                <img src="@speaker.AvatarUrl" alt="@speaker.Name" class="h-full w-full object-cover" />
                                            }
                                            else
                                            {
                                                <span>@(speaker.Name.Length > 0 ? speaker.Name[..1].ToUpper() : "?")</span>
                                            }
                                        </div>
                                        <h3 class="mt-2 sm:mt-3 text-xs sm:text-sm font-semibold text-gray-700">
                                            @speaker.Name
                                        </h3>
                                        <p class="text-[10px] sm:text-xs text-gray-500">@speaker.Role</p>
                                    </div>
                                }
                            </div>
                        </article>
                    }

                    @* --- Galerie photos --- *@
                    @if (_galleryImages.Count > 0)
                    {
                        <article class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                            <h2 class="text-lg sm:text-xl md:text-3xl font-bold text-gray-700">Galerie photos</h2>
                            <div class="mt-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
                                @foreach (var img in _galleryImages)
                                {
                                    <a href="@img" target="_blank" class="block">
                                        <img src="@img"
                                             class="h-28 sm:h-32 w-full rounded-lg object-cover border border-gray-200 hover:opacity-90 transition" />
                                    </a>
                                }
                            </div>
                        </article>
                    }
                    else if (_isPastEvent)
                    {
                        <article class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                            <div class="flex flex-col items-center justify-center py-10 text-center">
                                <div class="flex h-16 w-16 items-center justify-center rounded-full bg-gray-100">
                                    <i class="fas fa-images text-2xl text-gray-400"></i>
                                </div>
                                <h3 class="mt-4 text-base sm:text-lg font-bold text-gray-700">
                                    Aucune photo disponible
                                </h3>
                                <p class="mt-1 text-xs sm:text-sm text-gray-500">
                                    Cet événement ne dispose pas de galerie photos.
                                </p>
                            </div>
                        </article>
                    }
                    else
                    {
                        <article class="rounded-lg bg-white p-4 sm:p-6 shadow-sm">
                            <div class="flex flex-col items-center justify-center py-10 text-center">
                                <div class="flex h-16 w-16 items-center justify-center rounded-full bg-gray-100">
                                    <i class="fas fa-images text-2xl text-gray-400"></i>
                                </div>
                                <h3 class="mt-4 text-base sm:text-lg font-bold text-gray-700">
                                    Galerie de l'événement à venir
                                </h3>
                                <p class="mt-1 text-xs sm:text-sm text-gray-500">
                                    Les photos souvenirs seront disponibles après l'événement.
                                </p>
                            </div>
                        </article>
                    }

                    @* --- Commentaires --- *@
                    <div class="rounded-xl bg-white border-t p-4 sm:p-6 border-gray-200">
                        <div class="flex items-center justify-between">
                            <h2 class="text-xl sm:text-2xl font-semibold text-gray-900">Commentaires & Feedback</h2>
                            @if (EventComments.Any())
                            {
                                <span class="text-xs sm:text-sm text-gray-500">@EventComments.Count commentaire@(EventComments.Count > 1 ? "s" : "")</span>
                            }
                        </div>

                        <div class="mt-5 sm:mt-6">
                            <CommentForm EventId="CurrentEvent.Id" OnCommentAdded="RefreshComments" />
                        </div>

                        @if (isLoadingComments)
                        {
                            <div class="mt-6 sm:mt-8 space-y-4">
                                @for (int i = 0; i < 3; i++)
                                {
                                    <div class="flex gap-3 rounded-lg bg-white p-4 border border-gray-100">
                                        <Skeleton Type="SkeletonType.Avatar" Size="40px" Class="h-10 w-10" />
                                        <div class="flex-1 space-y-2">
                                            <div class="flex items-center gap-2">
                                                <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-24 h-3" />
                                                <Skeleton Type="SkeletonType.Text" Lines="1" Class="w-16 h-2" />
                                            </div>
                                            <Skeleton Type="SkeletonType.Text" Lines="3" />
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else if (EventComments.Any())
                        {
                            <div class="mt-6 sm:mt-8">
                                <CommentThread Comments="EventComments"
                                               OnReplySubmitted="RefreshComments"
                                               OnCommentUpdated="RefreshComments"
                                               OnCommentDeleted="RefreshComments" />
                            </div>
                        }
                        else
                        {
                            <div class="mt-6 sm:mt-8 rounded-lg border border-dashed border-gray-300 bg-gray-50 p-6 sm:p-8 text-center">
                                <i class="fa-solid fa-comments text-2xl sm:text-3xl text-gray-300 mb-3 sm:mb-4 block"></i>
                                <p class="text-xs sm:text-sm text-gray-500">Aucun commentaire pour le moment. Soyez le premier à commenter !</p>
                            </div>
                        }
                    </div>
                </div>

                @* --- Événements à venir (mobile) --- *@
                @if (UpcomingEvents.Any())
                {
                    <div class="lg:hidden">
                        <aside class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                            <p class="text-[10px] sm:text-sm font-semibold uppercase tracking-[0.18em] text-gray-400">
                                À venir
                            </p>
                            <h2 class="mt-1 text-lg sm:text-xl font-bold text-gray-800">
                                Autres événements
                            </h2>
                            <div class="mt-4 space-y-4">
                                @foreach (var evt in UpcomingEvents.Take(3))
                                {
                                    <a href="@GetEventUrl(evt)" class="flex gap-3 group">
                                        <div class="w-20 h-14 flex-shrink-0 rounded-lg overflow-hidden bg-gray-100">
                                            @if (!string.IsNullOrWhiteSpace(evt.CoverImageUrl))
                                            {
                                                <img src="@evt.CoverImageUrl" alt="@evt.Title" class="h-full w-full object-cover" />
                                            }
                                            else
                                            {
                                                <div class="flex h-full w-full items-center justify-center text-gray-400">
                                                    <i class="fa-solid fa-calendar text-sm"></i>
                                                </div>
                                            }
                                        </div>
                                        <div class="min-w-0">
                                            <p class="text-sm font-semibold text-gray-800 group-hover:text-secondary transition line-clamp-2">
                                                @evt.Title
                                            </p>
                                            <p class="mt-1 text-xs text-gray-500">
                                                @evt.StartDate.ToString("dd MMM", FrCulture)
                                            </p>
                                        </div>
                                    </a>
                                }
                            </div>
                        </aside>
                    </div>
                }

                @* --- Bloc 2 : Sidebar (desktop seulement) --- *@
                <div class="hidden lg:block lg:col-span-1 lg:sticky lg:top-8 lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto space-y-4">
                    @* --- Partage --- *@
                    <aside class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-[10px] sm:text-sm font-semibold uppercase tracking-[0.18em] text-gray-400">
                                    Partage
                                </p>
                                <h2 class="mt-1 text-lg sm:text-xl font-bold text-gray-800">
                                    Partager cet événement
                                </h2>
                                <p class="mt-2 text-xs sm:text-sm leading-relaxed text-gray-500">
                                    Diffusez l'événement sur vos réseaux ou copiez le lien direct.
                                </p>
                            </div>
                            <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-indigo-50 text-secondary">
                                <i class="fa-solid fa-share-nodes"></i>
                            </div>
                        </div>
                        <ShareButtons Title="@CurrentEvent.Title" Url="@GetAbsoluteUrl(CurrentPageUrl)"
                                      Description="@CurrentEvent.Description" />
                    </aside>

                    @* --- 3 événements à venir --- *@
                    @if (UpcomingEvents.Any())
                    {
                        <aside class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                            <p class="text-[10px] sm:text-sm font-semibold uppercase tracking-[0.18em] text-gray-400">
                                À venir
                            </p>
                            <h2 class="mt-1 text-lg sm:text-xl font-bold text-gray-800">
                                Autres événements
                            </h2>
                            <div class="mt-4 space-y-4">
                                @foreach (var evt in UpcomingEvents.Take(3))
                                {
                                    <a href="@GetEventUrl(evt)" class="flex gap-3 group">
                                        <div class="w-20 h-14 flex-shrink-0 rounded-lg overflow-hidden bg-gray-100">
                                            @if (!string.IsNullOrWhiteSpace(evt.CoverImageUrl))
                                            {
                                                <img src="@evt.CoverImageUrl" alt="@evt.Title" class="h-full w-full object-cover" />
                                            }
                                            else
                                            {
                                                <div class="flex h-full w-full items-center justify-center text-gray-400">
                                                    <i class="fa-solid fa-calendar text-sm"></i>
                                                </div>
                                            }
                                        </div>
                                        <div class="min-w-0">
                                            <p class="text-sm font-semibold text-gray-800 group-hover:text-secondary transition line-clamp-2">
                                                @evt.Title
                                            </p>
                                            <p class="mt-1 text-xs text-gray-500">
                                                @evt.StartDate.ToString("dd MMM", FrCulture)
                                            </p>
                                        </div>
                                    </a>
                                }
                            </div>
                        </aside>
                    }
                </div>
            </div>

            @* --- Mobile share overlay --- *@
            <div class="fixed inset-0 z-10 bg-black/50 sm:hidden @(IsShared ? "" : "hidden")"
                 @onclick="ToggleSharePanel"></div>
            <aside id="mobile-share-panel"
                   class="overflow-hidden z-20 w-[91%] fixed top-20 rounded-lg border border-gray-100 bg-white shadow-sm transition-all duration-300 lg:hidden @(IsShared ? "max-h-80 p-4 opacity-100 pointer-events-auto translate-x-0" : "max-h-0 p-0 opacity-0 pointer-events-none translate-x-full")">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-gray-400">
                            Partage
                        </p>
                        <h2 class="mt-1 text-base sm:text-lg font-bold text-gray-800">
                            Partager cet événement
                        </h2>
                    </div>
                    <button type="button"
                            class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-gray-100 text-gray-500 transition hover:bg-gray-200"
                            aria-label="Fermer le partage" @onclick="ToggleSharePanel">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <ShareButtons Title="@CurrentEvent.Title" Url="@GetAbsoluteUrl(CurrentPageUrl)"
                              Description="@CurrentEvent.Description" />
            </aside>
        }
    </div>
</section>

@code {
    [Parameter] public string? Slug { get; set; }
    [Parameter] public Guid? Id { get; set; }

    private static readonly CultureInfo FrCulture = CultureInfo.GetCultureInfo("fr-FR");
    private EventDto? CurrentEvent { get; set; }
    private List<CommentResponse> EventComments { get; set; } = new();
    private bool IsLoading { get; set; }
    private bool isLoadingComments;
    private bool IsShared { get; set; }
    private string? LoadError { get; set; }
    private string CurrentPageUrl { get; set; } = "/evenements";
    private List<string> _galleryImages { get; set; } = new();
    private bool _isPastEvent { get; set; }
    private List<EventRegistrationDto> Registrations { get; set; } = new();
    private bool IsRegistered { get; set; }
    private bool IsRegistering { get; set; }
    private bool IsCancelling { get; set; }
    private List<EventDto> UpcomingEvents { get; set; } = new();

    private string GetEventUrl(EventDto evt)
    {
        return !string.IsNullOrWhiteSpace(evt.Slug)
            ? $"/evenements/{evt.Slug}"
            : $"/evenements/{evt.Id}";
    }

    private async Task HandleRegister()
    {
        if (CurrentEvent is null) return;

        if (!UserStateService.IsAuthenticated)
        {
            ToastService.ShowToast("Vous devez être connecté pour vous inscrire.", ToastLevel.Warning);
            NavManager.NavigateTo("/auth/login");
            return;
        }

        if (IsRegistered)
        {
            ToastService.ShowToast("Vous êtes déjà inscrit à cet événement.", ToastLevel.Info);
            return;
        }

        IsRegistering = true;
        try
        {
            var avatarUrl = UserStateService.CurrentUser?.AvatarUrl ?? string.Empty;
            var request = new RegisterEventRequest { EventId = CurrentEvent.Id, AvatarUrl = avatarUrl };
            var result = await EventService.RegisterToEventAsync(request, UserStateService.UserId, UserStateService.UserName);

            if (result is null)
            {
                ToastService.ShowToast("Impossible de s'inscrire. L'événement est peut-être complet.", ToastLevel.Error);
                return;
            }

            ToastService.ShowToast("Inscription réussie !", ToastLevel.Success);
            IsRegistered = true;
            CurrentEvent.RegisteredCount++;
            Registrations = await EventService.GetRegistrationsByEventAsync(CurrentEvent.Id);
            StateHasChanged();
        }
        catch
        {
            ToastService.ShowToast("Erreur lors de l'inscription.", ToastLevel.Error);
        }
        finally
        {
            IsRegistering = false;
        }
    }

    private async Task HandleCancelRegistration()
    {
        if (CurrentEvent is null) return;

        if (!UserStateService.IsAuthenticated) return;

        IsCancelling = true;
        try
        {
            var success = await EventService.CancelRegistrationAsync(CurrentEvent.Id, UserStateService.UserId);

            if (!success)
            {
                ToastService.ShowToast("Impossible d'annuler l'inscription.", ToastLevel.Error);
                return;
            }

            ToastService.ShowToast("Inscription annulée.", ToastLevel.Success);
            IsRegistered = false;
            CurrentEvent.RegisteredCount--;
            Registrations = await EventService.GetRegistrationsByEventAsync(CurrentEvent.Id);
            StateHasChanged();
        }
        catch
        {
            ToastService.ShowToast("Erreur lors de l'annulation.", ToastLevel.Error);
        }
        finally
        {
            IsCancelling = false;
        }
    }

    private void ToggleSharePanel()
    {
        IsShared = !IsShared;
    }

    private async Task RefreshComments()
    {
        if (CurrentEvent is null) return;

        isLoadingComments = true;
        EventComments = await CommentService.GetCommentsByEventIdAsync(CurrentEvent.Id);
        isLoadingComments = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        IsLoading = true;
        LoadError = null;
        CurrentEvent = null;
        EventComments = new();

        if (UserStateService.CurrentUser is null)
            await UserStateService.LoadUserFromStorageAsync();

        try
        {
            if (Id.HasValue)
            {
                CurrentEvent = await EventService.GetEventByIdAsync(Id.Value);
            }
            else if (!string.IsNullOrWhiteSpace(Slug))
            {
                CurrentEvent = await EventService.GetEventBySlugAsync(Slug);
            }

            if (CurrentEvent is null)
            {
                LoadError = "é‰vénement introuvable.";
                return;
            }

            EventComments = await CommentService.GetCommentsByEventIdAsync(CurrentEvent.Id);

            CurrentPageUrl = !string.IsNullOrWhiteSpace(CurrentEvent.Slug)
                ? $"/evenements/{CurrentEvent.Slug}"
                : $"/evenements/{CurrentEvent.Id}";

            _galleryImages = CurrentEvent.GalleryImageUrls ?? new();
            _isPastEvent = CurrentEvent.EndDate < DateTime.Now;
            Registrations = await EventService.GetRegistrationsByEventAsync(CurrentEvent.Id);
            IsRegistered = UserStateService.IsAuthenticated && Registrations.Any(r => r.UserId == UserStateService.UserId);

            var allUpcoming = await EventService.GetUpcomingEventsAsync();
            UpcomingEvents = allUpcoming
                .Where(e => e.Id != CurrentEvent.Id)
                .Take(3)
                .ToList();
        }
        catch
        {
            LoadError = "Impossible de charger cet événement pour le moment.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string GetEventCoverUrl()
    {
        return string.IsNullOrWhiteSpace(CurrentEvent?.CoverImageUrl)
            ? "/Images/Fond1.jpeg"
            : CurrentEvent.CoverImageUrl;
    }

    private static string GetEventTypeLabel(string eventType)
    {
        return eventType.ToLowerInvariant() switch
        {
            "online" => "En ligne",
            "physical" => "Présentiel",
            "hybrid" => "Hybride",
            _ => string.IsNullOrWhiteSpace(eventType) ? "é‰vénement" : eventType
        };
    }

    private string GetAbsoluteUrl(string relativeUrl)
    {
        var baseUri = NavManager.BaseUri.TrimEnd('/');
        var url = relativeUrl.TrimStart('/');
        return $"{baseUri}/{url}";
    }
}
