@page "/evenements/{Slug}"
@page "/evenements/{Id:guid}"
@inject IEventService EventService
@using System.Globalization

<PageTitle>@(CurrentEvent is null ? "Détails de l'événement - .NET Niger" : $"{CurrentEvent.Title} - .NET Niger")</PageTitle>

<section class="min-h-screen bg-[#ececef] px-4 py-10 sm:px-6 lg:px-10">
	<div class="mx-auto w-full max-w-6xl space-y-4">
		@if (IsLoading)
		{
			<div class="rounded-xl bg-white p-6 text-sm text-gray-600 shadow-sm">Chargement de l'événement...</div>
		}
		else if (!string.IsNullOrWhiteSpace(LoadError))
		{
			<div class="rounded-xl bg-red-50 p-6 text-sm text-red-600 shadow-sm">@LoadError</div>
			<a href="/evenements" class="inline-flex text-sm font-semibold text-secondary hover:underline">Retour aux événements</a>
		}
		else if (CurrentEvent is not null)
		{
			<article class="overflow-hidden rounded-xl bg-white shadow-sm">
				<div class="h-64 bg-secondary bg-cover bg-center sm:h-80" style="@BuildCoverStyle(CurrentEvent.CoverImageUrl)"></div>
				<div class="space-y-5 p-6 sm:p-8">
					<span class="inline-flex items-center gap-1 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
						<i class="fa-solid fa-satellite-dish text-[10px]"></i>
						@GetEventTypeLabel(CurrentEvent.EventType)
					</span>

					<h1 class="text-3xl font-extrabold text-gray-700 sm:text-5xl">@CurrentEvent.Title</h1>

					<div class="flex flex-wrap items-center gap-4 text-sm text-gray-600">
						<span class="inline-flex items-center gap-2">
							<i class="fa-regular fa-calendar text-secondary"></i>
							@CurrentEvent.StartDate.ToString("dd MMMM yyyy HH:mm", FrCulture)
						</span>
						<span class="inline-flex items-center gap-2">
							<i class="fa-solid fa-location-dot text-secondary"></i>
							@CurrentEvent.Location
						</span>
					</div>

					<div class="flex flex-wrap items-center gap-4 pt-1">
						<a href="#inscription" class="inline-flex h-11 items-center justify-center rounded-lg bg-secondary px-6 text-sm font-semibold text-white transition hover:brightness-110">Réserver ma place</a>
						<div>
							<p class="text-sm font-semibold text-gray-700">@CurrentEvent.RegisteredCount inscrits</p>
							<p class="text-xs text-gray-500">Capacité : @CurrentEvent.Capacity</p>
						</div>
					</div>
				</div>
			</article>

			<div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
				<article class="rounded-xl bg-white p-6 shadow-sm lg:col-span-2">
					<h2 class="text-3xl font-bold text-gray-700">À propos de l'événement</h2>
					<p class="mt-4 text-sm leading-relaxed text-gray-600 sm:text-base">
						@CurrentEvent.Description
					</p>
				</article>

				<aside class="rounded-xl bg-white p-6 shadow-sm">
					<h2 class="text-3xl font-bold text-gray-700">Partager cet événement</h2>
					<div class="mt-5 flex items-center gap-3">
						<button type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gray-200 text-gray-600 transition hover:bg-gray-300" aria-label="Partager sur X">
							<i class="fa-solid fa-share-nodes"></i>
						</button>
						<button type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gray-200 text-gray-600 transition hover:bg-gray-300" aria-label="Partager sur Discord">
							<i class="fa-brands fa-x-twitter"></i>
						</button>
						<button type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gray-200 text-gray-600 transition hover:bg-gray-300" aria-label="Partager sur LinkedIn">
							<i class="fa-brands fa-linkedin-in"></i>
						</button>
					</div>

					<a href="@CurrentPageUrl" class="mt-5 inline-flex h-10 w-full items-center justify-center gap-2 rounded-md bg-indigo-100 text-sm font-semibold text-secondary transition hover:bg-indigo-200">
						<i class="fa-solid fa-link"></i>
						Copier le lien
					</a>
				</aside>
			</div>

			<div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
				<article class="rounded-xl bg-white p-6 shadow-sm lg:col-span-2">
					<div class="text-center">
						<h2 class="text-3xl font-bold text-gray-700">Intervenants</h2>
						<p class="mt-2 text-sm text-gray-500 sm:text-base">Des experts passionnés partageant leur savoir.</p>
					</div>

					<div class="mt-7 grid grid-cols-2 gap-5 sm:grid-cols-4">
						@foreach (var speaker in Speakers)
						{
							<div class="text-center">
								<div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-secondary to-indigo-700 text-lg font-bold text-white ring-2 ring-indigo-200">
									@speaker.Initials
								</div>
								<h3 class="mt-3 text-sm font-semibold text-gray-700">@speaker.Name</h3>
								<p class="text-xs text-gray-500">@speaker.Role</p>
							</div>
						}
					</div>
				</article>
			</div>

			<div class="grid grid-cols-1 gap-4 lg:grid-cols-3" id="inscription">
				<article class="rounded-xl bg-white p-6 shadow-sm lg:col-span-2">
					<h2 class="text-3xl font-bold text-gray-700">Commentaires &amp; Feedback</h2>

					<form class="mt-5 rounded-xl border border-gray-100 p-3">
						<div class="flex items-center gap-2">
							<input type="text" placeholder="Tapez votre commentaire..." class="h-10 flex-1 rounded-full border border-gray-200 px-4 text-sm text-gray-600 focus:border-secondary focus:outline-none" />
							<button type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-secondary text-white transition hover:brightness-110" aria-label="Envoyer commentaire">
								<i class="fa-regular fa-paper-plane"></i>
							</button>
						</div>
					</form>

					<div class="mt-7 space-y-6">
						@foreach (var comment in Comments)
						{
							<article class="flex gap-4">
								<div class="h-10 w-10 rounded-full bg-gray-200"></div>
								<div>
									<div class="flex flex-wrap items-center gap-2">
										<p class="text-sm font-semibold text-gray-700">@comment.Author</p>
										<span class="text-xs text-gray-500">@comment.RelativeDate</span>
									</div>
									<p class="mt-1 text-sm text-gray-600">@comment.Message</p>
								</div>
							</article>
						}
					</div>

					<a href="#" class="mt-8 inline-flex text-sm font-semibold text-secondary hover:underline">Voir plus de commentaires</a>
				</article>
			</div>
		}
	</div>
</section>

<Footer />

@code {
	[Parameter] public string? Slug { get; set; }
	[Parameter] public Guid? Id { get; set; }

	private static readonly CultureInfo FrCulture = CultureInfo.GetCultureInfo("fr-FR");
	private EventDto? CurrentEvent { get; set; }
	private bool IsLoading { get; set; }
	private string? LoadError { get; set; }
	private string CurrentPageUrl { get; set; } = "/evenements";

	protected override async Task OnParametersSetAsync()
	{
		IsLoading = true;
		LoadError = null;
		CurrentEvent = null;

		try
		{
			if (Id.HasValue)
			{
				CurrentEvent = await EventService.GetEventByIdAsync(Id.Value);
			}
			else if (!string.IsNullOrWhiteSpace(Slug))
			{
				CurrentEvent = await EventService.GetEventBySlugAsync(Slug);
			}

			if (CurrentEvent is null)
			{
				LoadError = "Événement introuvable.";
				return;
			}

			CurrentPageUrl = !string.IsNullOrWhiteSpace(CurrentEvent.Slug)
				? $"/evenements/{CurrentEvent.Slug}"
				: $"/evenements/{CurrentEvent.Id}";
		}
		catch
		{
			LoadError = "Impossible de charger cet événement pour le moment.";
		}
		finally
		{
			IsLoading = false;
		}
	}

	private static string BuildCoverStyle(string coverImageUrl)
	{
		if (string.IsNullOrWhiteSpace(coverImageUrl))
		{
			return string.Empty;
		}

		return $"background-image: linear-gradient(rgba(46, 26, 122, 0.45), rgba(46, 26, 122, 0.45)), url('{coverImageUrl}');";
	}

	private static string GetEventTypeLabel(string eventType)
	{
		return eventType.ToLowerInvariant() switch
		{
			"online" => "En ligne",
			"physical" => "Présentiel",
			"hybrid" => "Hybride",
			_ => string.IsNullOrWhiteSpace(eventType) ? "Événement" : eventType
		};
	}

	private static readonly IReadOnlyList<SpeakerViewModel> Speakers =
	[
		new("Ahmed Moussa", "Senior .NET Architect", "AM"),
		new("Awa Issa", "Cloud Engineer", "AI"),
		new("Boubacar Adamou", "Tech Lead", "BA"),
		new("Mariam Oumarou", "AI Specialist", "MO")
	];

	private static readonly IReadOnlyList<CommentViewModel> Comments =
	[
		new("Abdoulaye T.", "il y a 2 jours", "Est-ce qu'il y aura un atelier pratique sur .NET Aspire pendant la session cloud ? C'est le sujet qui m'intéresse le plus en ce moment."),
		new("Mariam O.", "il y a 3 jours", "Hâte de participer à cette édition ! Les intervenants sont vraiment de grande qualité cette année. Le format hybride est une excellente idée.")
	];

	private sealed record SpeakerViewModel(string Name, string Role, string Initials);

	private sealed record CommentViewModel(string Author, string RelativeDate, string Message);
}
