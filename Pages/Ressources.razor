@page "/ressources"

<PageTitle>Ressources - .NET Niger</PageTitle>

<section class="bg-[#e8e3f6] px-4 py-14 sm:px-6 lg:px-10">
	<div class="mx-auto w-full max-w-6xl">
		<h1 class="mb-12 text-center text-3xl font-extrabold text-secondary sm:text-5xl">Les Ressources du DotNet niger</h1>

		<h2 class="mb-8 text-center text-2xl font-bold text-gray-900 sm:text-4xl">Formations et Tutorials</h2>

		<div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
			@foreach (var training in Trainings)
			{
				<article class="overflow-hidden rounded-xl bg-white shadow-md">
					<div class="h-36 bg-[#e6e4e4]"></div>
					<div class="space-y-3 p-4">
						<h3 class="text-2xl font-bold text-gray-900">@training.Title</h3>
						<p class="text-sm leading-relaxed text-gray-600">@training.Description</p>
						<a href="@training.Link" class="inline-flex h-10 w-full items-center justify-center rounded-md bg-secondary text-sm font-semibold text-white transition hover:brightness-110">Accéder</a>
					</div>
				</article>
			}
		</div>
	</div>
</section>

<section class="bg-[#f5f5f7] px-4 py-14 sm:px-6 lg:px-10">
	<div class="mx-auto w-full max-w-6xl">
		<h2 class="mb-10 text-center text-2xl font-bold text-gray-900 sm:text-5xl">Articles de Blog et Guides</h2>

		<div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
			@foreach (var article in Articles)
			{
				<article class="overflow-hidden rounded-xl bg-white shadow-md">
					<div class="h-44 bg-secondary"></div>
					<div class="space-y-3 p-4">
						<span class="inline-flex rounded-sm bg-[#e8e3f6] px-2 py-1 text-xs font-semibold text-secondary">Projet Local</span>
						<h3 class="text-xl font-bold leading-snug text-gray-900">@article.Title</h3>
						<p class="text-sm leading-relaxed text-gray-600">@article.Description</p>

						<div class="flex items-center justify-between gap-3 text-xs text-gray-700">
							<span class="font-semibold text-gray-800">@article.Author</span>
							<span>@article.DateLabel</span>
						</div>
					</div>
				</article>
			}
		</div>
	</div>
</section>

<section class="bg-[#e8e3f6] px-4 py-14 sm:px-6 lg:px-10">
	<div class="mx-auto w-full max-w-6xl">
		<h2 class="mb-10 text-center text-3xl font-extrabold text-secondary sm:text-5xl">Bibliothèque et Outils</h2>

		<div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
			@foreach (var tool in Tools)
			{
				<article class="overflow-hidden rounded-xl bg-[#efeff2] shadow-sm">
					<div class="space-y-2 px-6 py-5">
						<h3 class="text-2xl font-bold text-secondary">@tool.Title</h3>
						<p class="text-sm text-gray-700">@tool.Description</p>
					</div>
					<a href="@tool.Link" class="inline-flex h-11 w-full items-center justify-center border-t border-white/70 bg-[#e6e2f4] text-sm font-medium text-gray-800 transition hover:text-secondary">
						@tool.CategoryLabel
						<span class="ml-3 text-base">&gt;</span>
					</a>
				</article>
			}
		</div>
	</div>
</section>

<Footer />

